<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:vm="using:ApixPress.App.ViewModels"
             xmlns:views="using:ApixPress.App.Views.Controls"
             x:Class="ApixPress.App.Views.Controls.MainWindowOverlaysView"
             x:DataType="vm:MainWindowViewModel"
             mc:Ignorable="d">
  <Grid>
    <views:NotificationCenterOverlayView />
    <views:EnvironmentManagerDialogView />
    <views:QuickRequestSaveDialogView />
    <views:WorkspaceDeleteConfirmDialogView />
    <views:ProjectImportDialogView />
    <views:ImportOverwriteConfirmDialogView />
    <views:SettingsDialogView />
    <views:CreateProjectDialogView />
  </Grid>
</UserControl>
