<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:iri="https://irihi.tech/shared"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:u="https://irihi.tech/ursa"
             xmlns:vm="using:ApixPress.App.ViewModels"
             x:Class="ApixPress.App.Views.Controls.HttpInterfaceWorkbenchView"
             x:DataType="vm:ProjectTabViewModel"
             mc:Ignorable="d">
  <Grid RowDefinitions="Auto,2*,3*"
        HorizontalAlignment="Stretch"
        VerticalAlignment="Stretch"
        RowSpacing="{StaticResource Space.3}"
        MinHeight="0"
        ClipToBounds="True"
        IsVisible="{Binding Editor.ShowHttpWorkbenchContent}">
    <Border Grid.Row="0"
            Classes="PanelCard HttpDesignMetaCard"
            IsVisible="{Binding Editor.IsHttpDesignEditorMode}">
      <StackPanel Spacing="{StaticResource Space.3}">
        <StackPanel Spacing="2">
          <TextBlock Classes="SectionTitle"
                     Text="接口设计" />
          <TextBlock Classes="CaptionText"
                     Text="这里只保留接口说明，用于补充接口用途、前置条件和返回约定。" />
        </StackPanel>

        <StackPanel Spacing="{StaticResource Space.2}">
          <TextBlock Classes="CaptionText"
                     Text="接口说明" />
          <TextBox Classes="SectionInput HttpDesignMultilineInput"
                   AcceptsReturn="True"
                   Text="{Binding ConfigTab.RequestDescription}"
                   TextWrapping="Wrap"
                   VerticalContentAlignment="Top"
                   Watermark="补充接口用途、前置条件和返回约定" />
        </StackPanel>
      </StackPanel>
    </Border>

    <Border Grid.Row="1"
            Classes="PanelCard ProjectWorkspaceSettingsCard HttpWorkbenchConfigCard"
            Padding="0">
      <Grid RowDefinitions="Auto,*">
        <TabControl Grid.Row="0"
                    Classes="ConfigTabControl HttpRequestTabs"
                    SelectedIndex="{Binding ConfigTab.SelectedTabIndex}">
          <TabItem Header="Params" />
          <TabItem Header="Body" />
          <TabItem Header="Headers" />
        </TabControl>
        <Grid x:Name="ConfigTabContentHost"
              Grid.Row="1"
              MinHeight="0"
              ClipToBounds="True" />
      </Grid>
    </Border>

    <Border Grid.Row="2"
            Classes="PanelCard HttpResponseCard">
      <Grid RowDefinitions="Auto,*"
            RowSpacing="{StaticResource Space.3}">
        <Grid Grid.Row="0"
              ColumnDefinitions="Auto,*"
              ColumnSpacing="{StaticResource Space.3}">
          <TextBlock Grid.Column="0"
                     Classes="SectionTitle"
                     Text="返回响应" />
          <Grid Grid.Column="1"
                ColumnDefinitions="Auto,Auto,Auto"
                ColumnSpacing="{StaticResource Space.3}"
                HorizontalAlignment="Right"
                IsVisible="{Binding ResponseSection.HasResponse}">
            <u:Badge Grid.Column="0"
                     Header="{Binding ResponseSection.StatusText}"
                     iri:ClassHelper.Classes="{Binding ResponseSection.StatusBadgeClass}" />
            <TextBlock Grid.Column="1"
                       Classes="CaptionText"
                       VerticalAlignment="Center"
                       Text="{Binding ResponseSection.DurationText}" />
            <TextBlock Grid.Column="2"
                       Classes="CaptionText"
                       VerticalAlignment="Center"
                       Text="{Binding ResponseSection.SizeText}" />
          </Grid>
        </Grid>

        <Border Grid.Row="1"
                Classes="HttpResponsePlaceholderHost"
                IsVisible="{Binding ResponseSection.ShowPlaceholder}">
          <StackPanel Classes="HttpResponsePlaceholderContent"
                      Spacing="{StaticResource Space.2}">
            <TextBlock Classes="HttpResponsePlaceholderIcon"
                       FontFamily="Segoe Fluent Icons, Segoe MDL2 Assets"
                       Text="&#xE7C3;" />
            <TextBlock Classes="SubtleText HttpResponsePlaceholderText"
                       Text="点击“发送”按钮获取返回结果" />
          </StackPanel>
        </Border>

        <Grid Grid.Row="1"
              IsVisible="{Binding ResponseSection.HasResponse}"
              RowDefinitions="*">
          <TabControl Grid.Row="0"
                      Classes="ResponseTabs"
                      SelectedIndex="{Binding ResponseSection.SelectedResponseTab}">
            <TabItem Header="Body">
              <TextBox AcceptsReturn="True"
                       BorderThickness="0"
                       Background="Transparent"
                       IsReadOnly="True"
                       TextWrapping="Wrap"
                       VerticalContentAlignment="Top"
                       Text="{Binding ResponseSection.BodyText}"
                       FontFamily="{StaticResource Font.Monospace}" />
            </TabItem>
            <TabItem Header="Headers">
              <TextBox AcceptsReturn="True"
                       BorderThickness="0"
                       Background="Transparent"
                       IsReadOnly="True"
                       TextWrapping="Wrap"
                       VerticalContentAlignment="Top"
                       Text="{Binding ResponseSection.HeadersText}"
                       FontFamily="{StaticResource Font.Monospace}" />
            </TabItem>
          </TabControl>
        </Grid>

        <Border Grid.Row="1"
                Classes="HttpResponseLoadingOverlay"
                IsVisible="{Binding ResponseSection.IsLoading}">
          <StackPanel Classes="HttpResponseLoadingContent"
                      Spacing="{StaticResource Space.3}">
            <ProgressBar Classes="HttpResponseLoadingProgress"
                         IsIndeterminate="True" />
            <TextBlock Classes="SubtleText HttpResponseLoadingText"
                       Text="{Binding ResponseSection.LoadingText}" />
          </StackPanel>
        </Border>
      </Grid>
    </Border>
  </Grid>
</UserControl>
