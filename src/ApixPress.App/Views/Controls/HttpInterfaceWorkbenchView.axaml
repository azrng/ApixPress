<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:iri="https://irihi.tech/shared"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:u="https://irihi.tech/ursa"
             xmlns:vm="using:ApixPress.App.ViewModels"
             x:Class="ApixPress.App.Views.Controls.HttpInterfaceWorkbenchView"
             x:DataType="vm:ProjectTabViewModel"
             mc:Ignorable="d">
  <Grid RowDefinitions="Auto,2*,3*"
        HorizontalAlignment="Stretch"
        VerticalAlignment="Stretch"
        RowSpacing="{StaticResource Space.3}"
        MinHeight="0"
        ClipToBounds="True"
        IsVisible="{Binding Editor.ShowHttpWorkbenchContent}">
    <Border Grid.Row="0"
            Classes="PanelCard HttpDesignMetaCard"
            IsVisible="{Binding Editor.IsHttpDesignEditorMode}">
      <StackPanel Spacing="{StaticResource Space.3}">
        <StackPanel Spacing="2">
          <TextBlock Classes="SectionTitle"
                     Text="接口设计" />
          <TextBlock Classes="CaptionText"
                     Text="这里只保留接口说明，用于补充接口用途、前置条件和返回约定。" />
        </StackPanel>

        <StackPanel Spacing="{StaticResource Space.2}">
          <TextBlock Classes="CaptionText"
                     Text="接口说明" />
          <TextBox Classes="SectionInput HttpDesignMultilineInput"
                   AcceptsReturn="True"
                   Text="{Binding ConfigTab.RequestDescription}"
                   TextWrapping="Wrap"
                   VerticalContentAlignment="Top"
                   Watermark="补充接口用途、前置条件和返回约定" />
        </StackPanel>
      </StackPanel>
    </Border>

    <Border Grid.Row="1"
            Classes="PanelCard ProjectWorkspaceSettingsCard HttpWorkbenchConfigCard"
            Padding="0">
      <Grid RowDefinitions="*">
        <TabControl Grid.Row="0"
                    Classes="ConfigTabControl HttpRequestTabs"
                    SelectedIndex="{Binding ConfigTab.SelectedTabIndex}">
          <TabItem Header="Params">
            <DockPanel Margin="{StaticResource Pad.3}"
                       HorizontalAlignment="Stretch"
                       MinHeight="0">
              <Border DockPanel.Dock="Top"
                      Classes="HttpRequestTableHeader">
                <Grid ColumnDefinitions="32,2.2*,2.2*,96,2.4*,48"
                      ColumnSpacing="{StaticResource Space.3}">
                  <TextBlock Grid.Column="1" Classes="CaptionText" Text="参数名" />
                  <TextBlock Grid.Column="2" Classes="CaptionText" Text="参数值" />
                  <TextBlock Grid.Column="3" Classes="CaptionText" Text="类型" />
                  <TextBlock Grid.Column="4" Classes="CaptionText" Text="说明" />
                </Grid>
              </Border>
              <Button DockPanel.Dock="Bottom"
                      Classes="AddButton"
                      HorizontalAlignment="Left"
                      Margin="0,8,0,0"
                      Content="添加参数"
                      Command="{Binding ConfigTab.AddQueryParameterCommand}" />
              <ScrollViewer HorizontalScrollBarVisibility="Disabled"
                            VerticalScrollBarVisibility="Auto">
                <ItemsControl ItemsSource="{Binding ConfigTab.QueryParameters}"
                              HorizontalAlignment="Stretch">
                  <ItemsControl.ItemTemplate>
                    <DataTemplate x:DataType="vm:RequestParameterItemViewModel">
                      <Border Classes="ParameterRow HttpRequestParameterRow"
                              HorizontalAlignment="Stretch">
                        <Grid ColumnDefinitions="32,2.2*,2.2*,96,2.4*,48"
                              ColumnSpacing="{StaticResource Space.3}">
                          <CheckBox Grid.Column="0" IsChecked="{Binding IsEnabled}" VerticalAlignment="Center" />
                          <TextBox Grid.Column="1" Classes="ParameterInput HttpTableInput" Text="{Binding Name}" Watermark="添加参数" />
                          <TextBox Grid.Column="2" Classes="ParameterInput HttpTableInput" Text="{Binding Value}" Watermark="参数值" />
                          <TextBlock Grid.Column="3" Classes="CaptionText" Text="String" VerticalAlignment="Center" />
                          <TextBox Grid.Column="4" Classes="ParameterInput HttpTableInput" Text="{Binding Description}" Watermark="说明" />
                          <u:IconButton Grid.Column="5"
                                        Classes="Danger"
                                        Theme="{DynamicResource BorderlessIconButton}"
                                        Icon="{StaticResource SemiIconDelete}"
                                        Command="{Binding $parent[Window].((vm:MainWindowViewModel)DataContext).ConfigTab.RemoveParameterCommand}"
                                        CommandParameter="{Binding}" />
                        </Grid>
                      </Border>
                    </DataTemplate>
                  </ItemsControl.ItemTemplate>
                </ItemsControl>
              </ScrollViewer>
            </DockPanel>
          </TabItem>

          <TabItem Header="Body">
            <Grid Margin="{StaticResource Pad.3}"
                  RowDefinitions="Auto,*"
                  RowSpacing="{StaticResource Space.3}"
                  HorizontalAlignment="Stretch">
              <u:SelectionList Grid.Row="0"
                               ItemsSource="{Binding ConfigTab.BodyModeOptions}"
                               SelectedItem="{Binding ConfigTab.SelectedBodyModeOption}">
                <u:SelectionList.ItemsPanel>
                  <ItemsPanelTemplate>
                    <StackPanel Orientation="Horizontal" />
                  </ItemsPanelTemplate>
                </u:SelectionList.ItemsPanel>
                <u:SelectionList.ItemTemplate>
                  <DataTemplate x:DataType="vm:BodyModeOptionViewModel">
                    <Border Padding="{StaticResource Pad.2}">
                      <TextBlock Text="{Binding DisplayName}" />
                    </Border>
                  </DataTemplate>
                </u:SelectionList.ItemTemplate>
              </u:SelectionList>

              <Grid Grid.Row="1"
                    HorizontalAlignment="Stretch"
                    VerticalAlignment="Stretch">
                <Grid IsVisible="{Binding ConfigTab.IsBodyModeFormData}"
                      RowDefinitions="Auto,*"
                      RowSpacing="{StaticResource Space.2}"
                      HorizontalAlignment="Stretch"
                      VerticalAlignment="Stretch">
                  <Button Grid.Row="0"
                          Classes="AddButton FormDataAddButton"
                          HorizontalAlignment="Right"
                          Content="添加字段"
                          Command="{Binding ConfigTab.AddFormFieldCommand}" />

                  <Border Grid.Row="1"
                          Classes="FormDataTableSurface">
                    <Grid RowDefinitions="Auto,*">
                      <Border Grid.Row="0"
                              Classes="HttpRequestTableHeader FormDataTableHeader">
                        <Grid ColumnDefinitions="32,2.2*,2.2*,96,2.4*,48"
                              ColumnSpacing="{StaticResource Space.3}">
                          <TextBlock Grid.Column="1" Classes="CaptionText" Text="字段名" />
                          <TextBlock Grid.Column="2" Classes="CaptionText" Text="字段值" />
                          <TextBlock Grid.Column="3" Classes="CaptionText" Text="类型" />
                          <TextBlock Grid.Column="4" Classes="CaptionText" Text="说明" />
                        </Grid>
                      </Border>

                      <Grid Grid.Row="1"
                            HorizontalAlignment="Stretch"
                            VerticalAlignment="Stretch">
                        <ScrollViewer HorizontalScrollBarVisibility="Disabled"
                                      VerticalScrollBarVisibility="Auto"
                                      IsVisible="{Binding ConfigTab.HasFormFields}">
                          <ItemsControl ItemsSource="{Binding ConfigTab.FormFields}"
                                        HorizontalAlignment="Stretch">
                            <ItemsControl.ItemTemplate>
                              <DataTemplate x:DataType="vm:RequestParameterItemViewModel">
                                <Border Classes="ParameterRow HttpRequestParameterRow"
                                        HorizontalAlignment="Stretch">
                                  <Grid ColumnDefinitions="32,2.2*,2.2*,96,2.4*,48"
                                        ColumnSpacing="{StaticResource Space.3}">
                                    <CheckBox Grid.Column="0" IsChecked="{Binding IsEnabled}" VerticalAlignment="Center" />
                                    <TextBox Grid.Column="1" Classes="ParameterInput HttpTableInput" Text="{Binding Name}" Watermark="字段名" />
                                    <TextBox Grid.Column="2" Classes="ParameterInput HttpTableInput" Text="{Binding Value}" Watermark="字段值" />
                                    <TextBlock Grid.Column="3" Classes="CaptionText" Text="String" VerticalAlignment="Center" />
                                    <TextBox Grid.Column="4" Classes="ParameterInput HttpTableInput" Text="{Binding Description}" Watermark="说明" />
                                    <u:IconButton Grid.Column="5"
                                                  Classes="Danger"
                                                  Theme="{DynamicResource BorderlessIconButton}"
                                                  Icon="{StaticResource SemiIconDelete}"
                                                  Command="{Binding $parent[Window].((vm:MainWindowViewModel)DataContext).ConfigTab.RemoveParameterCommand}"
                                                  CommandParameter="{Binding}" />
                                  </Grid>
                                </Border>
                              </DataTemplate>
                            </ItemsControl.ItemTemplate>
                          </ItemsControl>
                        </ScrollViewer>

                        <Border Classes="FormDataEmptyState"
                                IsVisible="{Binding ConfigTab.ShowFormDataEmptyState}">
                          <TextBlock Classes="CaptionText"
                                     Text="暂无字段" />
                        </Border>
                      </Grid>
                    </Grid>
                  </Border>
                </Grid>

                <Border IsVisible="{Binding ConfigTab.HasRawBodyEditor}"
                        Classes="RawEditorCard">
                  <TextBox AcceptsReturn="True"
                           BorderThickness="0"
                           Background="Transparent"
                           TextWrapping="Wrap"
                           VerticalContentAlignment="Top"
                           Watermark="{Binding ConfigTab.RequestBodyWatermark}"
                           Text="{Binding ConfigTab.RequestBody}"
                           FontFamily="{StaticResource Font.Monospace}" />
                </Border>
              </Grid>
            </Grid>
          </TabItem>

          <TabItem Header="Headers">
            <DockPanel Margin="{StaticResource Pad.3}"
                       HorizontalAlignment="Stretch"
                       MinHeight="0">
              <Border DockPanel.Dock="Top"
                      Classes="HttpRequestTableHeader">
                <Grid ColumnDefinitions="2.4*,2.4*,1.2*,2.2*,48"
                      ColumnSpacing="{StaticResource Space.3}">
                  <TextBlock Grid.Column="0" Classes="CaptionText" Text="Header 名" />
                  <TextBlock Grid.Column="1" Classes="CaptionText" Text="Header 值" />
                  <TextBlock Grid.Column="2" Classes="CaptionText" Text="类型" />
                  <TextBlock Grid.Column="3" Classes="CaptionText" Text="说明" />
                </Grid>
              </Border>
              <Button DockPanel.Dock="Bottom"
                      Classes="AddButton"
                      HorizontalAlignment="Left"
                      Margin="0,8,0,0"
                      Content="添加 Header"
                      Command="{Binding ConfigTab.AddHeaderCommand}" />
              <ScrollViewer HorizontalScrollBarVisibility="Disabled"
                            VerticalScrollBarVisibility="Auto">
                <ItemsControl ItemsSource="{Binding ConfigTab.Headers}"
                              HorizontalAlignment="Stretch">
                  <ItemsControl.ItemTemplate>
                    <DataTemplate x:DataType="vm:RequestParameterItemViewModel">
                      <Border Classes="ParameterRow HttpRequestParameterRow"
                              HorizontalAlignment="Stretch">
                        <Grid ColumnDefinitions="2.4*,2.4*,1.2*,2.2*,48"
                              ColumnSpacing="{StaticResource Space.3}">
                          <TextBox Grid.Column="0" Classes="ParameterInput HttpTableInput" Text="{Binding Name}" Watermark="Header 名" />
                          <TextBox Grid.Column="1" Classes="ParameterInput HttpTableInput" Text="{Binding Value}" Watermark="Header 值" />
                          <TextBlock Grid.Column="2" Classes="CaptionText" Text="String" VerticalAlignment="Center" />
                          <TextBox Grid.Column="3" Classes="ParameterInput HttpTableInput" Text="{Binding Description}" Watermark="说明" />
                          <u:IconButton Grid.Column="4"
                                        Classes="Danger"
                                        Theme="{DynamicResource BorderlessIconButton}"
                                        Icon="{StaticResource SemiIconDelete}"
                                        Command="{Binding $parent[Window].((vm:MainWindowViewModel)DataContext).ConfigTab.RemoveParameterCommand}"
                                        CommandParameter="{Binding}" />
                        </Grid>
                      </Border>
                    </DataTemplate>
                  </ItemsControl.ItemTemplate>
                </ItemsControl>
              </ScrollViewer>
            </DockPanel>
          </TabItem>
        </TabControl>
      </Grid>
    </Border>

    <Border Grid.Row="2"
            Classes="PanelCard HttpResponseCard">
      <Grid RowDefinitions="Auto,*"
            RowSpacing="{StaticResource Space.3}">
        <Grid Grid.Row="0">
          <TextBlock Classes="SectionTitle"
                     Text="返回响应" />
        </Grid>

        <Border Grid.Row="1"
                Classes="HttpResponsePlaceholderHost"
                IsVisible="{Binding ResponseSection.ShowPlaceholder}">
          <StackPanel Classes="HttpResponsePlaceholderContent"
                      Spacing="{StaticResource Space.2}">
            <TextBlock Classes="HttpResponsePlaceholderIcon"
                       FontFamily="Segoe Fluent Icons, Segoe MDL2 Assets"
                       Text="&#xE7C3;" />
            <TextBlock Classes="SubtleText HttpResponsePlaceholderText"
                       Text="点击“发送”按钮获取返回结果" />
          </StackPanel>
        </Border>

        <Grid Grid.Row="1"
              IsVisible="{Binding ResponseSection.HasResponse}"
              RowDefinitions="Auto,*"
              RowSpacing="{StaticResource Space.2}">
          <Grid ColumnDefinitions="Auto,Auto,Auto,*"
                ColumnSpacing="{StaticResource Space.3}">
            <u:Badge Grid.Column="0"
                     Header="{Binding ResponseSection.StatusText}"
                     iri:ClassHelper.Classes="{Binding ResponseSection.StatusBadgeClass}" />
            <TextBlock Grid.Column="1" Classes="CaptionText" Text="{Binding ResponseSection.DurationText}" />
            <TextBlock Grid.Column="2" Classes="CaptionText" Text="{Binding ResponseSection.SizeText}" />
          </Grid>

          <TabControl Grid.Row="1"
                      Classes="ResponseTabs"
                      SelectedIndex="{Binding ResponseSection.SelectedResponseTab}">
            <TabItem Header="Body">
              <TextBox AcceptsReturn="True"
                       BorderThickness="0"
                       Background="Transparent"
                       IsReadOnly="True"
                       TextWrapping="Wrap"
                       VerticalContentAlignment="Top"
                       Text="{Binding ResponseSection.BodyText}"
                       FontFamily="{StaticResource Font.Monospace}" />
            </TabItem>
            <TabItem Header="Headers">
              <TextBox AcceptsReturn="True"
                       BorderThickness="0"
                       Background="Transparent"
                       IsReadOnly="True"
                       TextWrapping="Wrap"
                       VerticalContentAlignment="Top"
                       Text="{Binding ResponseSection.HeadersText}"
                       FontFamily="{StaticResource Font.Monospace}" />
            </TabItem>
          </TabControl>
        </Grid>
      </Grid>
    </Border>
  </Grid>
</UserControl>
