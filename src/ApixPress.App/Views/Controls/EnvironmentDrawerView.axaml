<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:u="https://irihi.tech/ursa"
             xmlns:vm="using:ApixPress.App.ViewModels"
             x:Class="ApixPress.App.Views.Controls.EnvironmentDrawerView"
             x:DataType="vm:MainWindowViewModel"
             d:DesignWidth="380"
             d:DesignHeight="720"
             mc:Ignorable="d">
  <ScrollViewer>
    <StackPanel Spacing="{StaticResource Space.3}">
      <Grid ColumnDefinitions="*,Auto,Auto"
            ColumnSpacing="{StaticResource Space.2}">
        <TextBlock Classes="CaptionText"
                   Text="当前环境：Default。变量支持通过 {{key}} 形式在请求地址、Header 与请求体中引用。"
                   VerticalAlignment="Center" />
        <Button Grid.Column="1"
                Classes="SecondaryButton"
                Content="新增变量"
                Command="{Binding EnvironmentPanel.AddVariableCommand}" />
        <Button Grid.Column="2"
                Classes="PrimaryButton"
                Content="保存"
                Command="{Binding EnvironmentPanel.SaveVariablesCommand}" />
      </Grid>

      <ItemsControl ItemsSource="{Binding EnvironmentPanel.EnvironmentVariables}">
        <ItemsControl.ItemTemplate>
          <DataTemplate x:DataType="vm:EnvironmentVariableItemViewModel">
            <Border Classes="PanelCard"
                    Padding="{StaticResource Pad.3}">
              <Grid ColumnDefinitions="Auto,*,Auto"
                    ColumnSpacing="{StaticResource Space.2}"
                    RowDefinitions="Auto,Auto">
                <CheckBox Grid.RowSpan="2"
                          VerticalAlignment="Top"
                          IsChecked="{Binding IsEnabled}" />
                <TextBox Grid.Column="1"
                         Classes="SectionInput"
                         Watermark="变量键，例如 baseUrl"
                         Text="{Binding Key}" />
                <u:PopConfirm Grid.Column="2"
                              PopupHeader="确认删除该环境变量？"
                              PopupContent="删除后本环境下的变量引用将立即失效。"
                              ConfirmCommand="{Binding $parent[UserControl].((vm:MainWindowViewModel)DataContext).EnvironmentPanel.RemoveVariableCommand}"
                              ConfirmCommandParameter="{Binding}">
                  <Button Classes="SecondaryButton"
                          Content="删除" />
                </u:PopConfirm>
                <TextBox Grid.Row="1"
                         Grid.Column="1"
                         Grid.ColumnSpan="2"
                         Classes="SectionInput"
                         Watermark="变量值"
                         Text="{Binding Value}" />
              </Grid>
            </Border>
          </DataTemplate>
        </ItemsControl.ItemTemplate>
      </ItemsControl>
    </StackPanel>
  </ScrollViewer>
</UserControl>
