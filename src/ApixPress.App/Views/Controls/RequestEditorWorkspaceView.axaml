<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:views="using:ApixPress.App.Views.Controls"
             xmlns:vm="using:ApixPress.App.ViewModels"
             x:Class="ApixPress.App.Views.Controls.RequestEditorWorkspaceView"
             x:DataType="vm:ProjectTabViewModel"
             mc:Ignorable="d">
  <Grid IsVisible="{Binding Shell.ShowRequestEditorWorkspace}"
        RowDefinitions="Auto,Auto,*"
        RowSpacing="{StaticResource Space.3}"
        MinHeight="0"
        ClipToBounds="True">
    <views:ProjectWorkspaceToolbarView />

    <Grid Grid.Row="1"
          RowDefinitions="Auto,Auto,Auto"
          RowSpacing="{StaticResource Space.2}"
          MinHeight="0"
          ClipToBounds="True"
          IsVisible="{Binding Editor.IsQuickRequestEditor}">
      <TextBox Grid.Row="0"
               Classes="SectionInput HttpInterfaceNameInput"
               HorizontalAlignment="Stretch"
               Watermark="未命名请求"
               Text="{Binding Editor.CurrentQuickRequestName}" />

      <Grid Grid.Row="1"
            ColumnDefinitions="*,Auto,Auto,Auto"
            ColumnSpacing="{StaticResource Space.2}">
        <Border Grid.Column="0"
                Classes="HttpRequestUrlShell">
          <Grid ColumnDefinitions="Auto,Auto,*"
                ColumnSpacing="{StaticResource Space.1}">
            <ComboBox Grid.Column="0"
                      Classes="HttpMethodSelector"
                      ItemsSource="{Binding Editor.HttpMethods}"
                      SelectedItem="{Binding Editor.SelectedMethod}" />
            <Border Grid.Column="1"
                    Classes="BaseUrlPrefixCard HttpBaseUrlPrefixCard">
              <TextBlock Classes="HttpBaseUrlPrefixText"
                         Text="{Binding Editor.CurrentEditorBaseUrlCaption}"
                         VerticalAlignment="Center"
                         TextTrimming="CharacterEllipsis" />
            </Border>
            <TextBox Grid.Column="2"
                     Classes="HttpRequestPathInput"
                     Watermark="{Binding Editor.CurrentEditorUrlWatermark}"
                     Text="{Binding Editor.RequestUrl}" />
          </Grid>
        </Border>
        <Button Grid.Column="1"
                Classes="HttpSaveButton"
                Content="生成代码"
                Command="{Binding Editor.OpenRequestCodeDialogCommand}"
                IsEnabled="{Binding Editor.CanGenerateRequestCode}" />
        <Button Grid.Column="2"
                Classes="HttpSendButton"
                Content="发送"
                Command="{Binding SendRequestCommand}" />
        <Button Grid.Column="3"
                Classes="HttpSaveButton"
                Content="保存"
                Command="{Binding SaveCaseCommand}" />
      </Grid>

      <Border Grid.Row="2"
              Classes="RequestResolvedPreviewCard"
              IsVisible="{Binding Editor.HasResolvedRequestPreview}">
        <TextBlock Classes="CaptionText"
                   Text="{Binding Editor.ResolvedRequestPreviewText}"
                   TextTrimming="CharacterEllipsis" />
      </Border>
    </Grid>

    <Grid Grid.Row="1"
          RowDefinitions="Auto,Auto,Auto"
          RowSpacing="{StaticResource Space.2}"
          MinHeight="0"
          ClipToBounds="True"
          IsVisible="{Binding Editor.IsHttpInterfaceEditor}">
      <Grid ColumnDefinitions="Auto,*"
            ColumnSpacing="{StaticResource Space.3}">
        <Border Grid.Column="0"
                Classes="HttpEditorModeBar">
          <StackPanel Orientation="Horizontal"
                      Spacing="{StaticResource Space.1}">
            <ToggleButton Classes="HttpEditorModeButton"
                          Command="{Binding Editor.ShowHttpDebugEditorModeCommand}"
                          Content="调试"
                          IsChecked="{Binding Editor.IsHttpDebugEditorMode, Mode=OneWay}" />
            <ToggleButton Classes="HttpEditorModeButton"
                          Command="{Binding Editor.ShowHttpDesignEditorModeCommand}"
                          Content="设计"
                          IsChecked="{Binding Editor.IsHttpDesignEditorMode, Mode=OneWay}" />
            <ToggleButton Classes="HttpEditorModeButton"
                          Command="{Binding Editor.ShowHttpDocumentPreviewModeCommand}"
                          Content="文档预览"
                          IsChecked="{Binding Editor.IsHttpDocumentPreviewMode, Mode=OneWay}" />
          </StackPanel>
        </Border>

        <TextBox Grid.Column="1"
                 Classes="SectionInput HttpInterfaceNameInput"
                 HorizontalAlignment="Stretch"
                 Watermark="未命名接口"
                 Text="{Binding Editor.CurrentHttpInterfaceName}" />
      </Grid>

      <Grid Grid.Row="1"
            ColumnDefinitions="*,Auto,Auto,Auto,Auto,Auto"
            ColumnSpacing="{StaticResource Space.2}">
        <Border Grid.Column="0"
                Classes="HttpRequestUrlShell">
          <Grid ColumnDefinitions="Auto,Auto,*"
                ColumnSpacing="{StaticResource Space.1}">
            <ComboBox Grid.Column="0"
                      Classes="HttpMethodSelector"
                      ItemsSource="{Binding Editor.HttpMethods}"
                      SelectedItem="{Binding Editor.SelectedMethod}" />
            <Border Grid.Column="1"
                    Classes="BaseUrlPrefixCard HttpBaseUrlPrefixCard">
              <TextBlock Classes="HttpBaseUrlPrefixText"
                         Text="{Binding Editor.CurrentEditorBaseUrlCaption}"
                         VerticalAlignment="Center"
                         TextTrimming="CharacterEllipsis" />
            </Border>
            <TextBox Grid.Column="2"
                     Classes="HttpRequestPathInput"
                     Watermark="{Binding Editor.CurrentEditorUrlWatermark}"
                     Text="{Binding Editor.RequestUrl}" />
          </Grid>
        </Border>
        <TextBox Grid.Column="1"
                 Classes="SectionInput HttpInterfaceNameInput HttpCaseNameInput"
                 HorizontalAlignment="Stretch"
                 Watermark="用例名称"
                 Text="{Binding Editor.CurrentHttpCaseName}"
                 IsVisible="{Binding Editor.ShowSaveHttpCaseAction}" />
        <Button Grid.Column="2"
                Classes="HttpSaveButton"
                Content="生成代码"
                Command="{Binding Editor.OpenRequestCodeDialogCommand}"
                IsEnabled="{Binding Editor.CanGenerateRequestCode}" />
        <Button Grid.Column="3"
                Classes="HttpSendButton"
                Content="发送"
                Command="{Binding SendRequestCommand}" />
        <Button Grid.Column="4"
                Classes="HttpSaveButton"
                Content="保存测试用例"
                Command="{Binding SaveHttpCaseCommand}"
                IsVisible="{Binding Editor.ShowSaveHttpCaseAction}" />
        <Button Grid.Column="5"
                Classes="HttpSaveButton"
                Content="保存"
                Command="{Binding SaveCaseCommand}" />
      </Grid>

      <Border Grid.Row="2"
              Classes="RequestResolvedPreviewCard"
              IsVisible="{Binding Editor.HasResolvedRequestPreview}">
        <TextBlock Classes="CaptionText"
                   Text="{Binding Editor.ResolvedRequestPreviewText}"
                   TextTrimming="CharacterEllipsis" />
      </Border>
    </Grid>

    <Grid Grid.Row="2"
          MinHeight="0"
          ClipToBounds="True">
      <views:QuickRequestWorkbenchView IsVisible="{Binding Editor.IsQuickRequestEditor}" />
      <views:HttpInterfaceWorkbenchView IsVisible="{Binding Editor.ShowHttpWorkbenchContent}" />
      <views:HttpDocumentWorkspaceView IsVisible="{Binding Editor.ShowHttpDocumentPreviewContent}" />
    </Grid>

    <Border Grid.RowSpan="3"
            Classes="CreateProjectDialogBackdrop"
            IsVisible="{Binding Editor.IsRequestCodeDialogOpen}">
      <Grid HorizontalAlignment="Center"
            VerticalAlignment="Center">
        <Border Classes="RequestCodeDialogCard">
          <Grid RowDefinitions="Auto,Auto,*,Auto"
                RowSpacing="{StaticResource Space.3}">
            <Grid Grid.Row="0"
                  ColumnDefinitions="*,Auto"
                  ColumnSpacing="{StaticResource Space.3}">
              <StackPanel Grid.Column="0"
                          Spacing="{StaticResource Space.1}">
                <TextBlock Classes="DialogTitle"
                           Text="{Binding Editor.RequestCodeTitle}" />
                <TextBlock Classes="CaptionText"
                           Text="curl"
                           TextWrapping="Wrap" />
              </StackPanel>
              <Button Grid.Column="1"
                      Classes="DialogIconButton"
                      Content="×"
                      Command="{Binding Editor.CloseRequestCodeDialogCommand}" />
            </Grid>

            <Border Grid.Row="1"
                    Classes="CreateProjectDialogDivider" />

            <TextBox Grid.Row="2"
                     Classes="RequestCodeDialogTextBox"
                     AcceptsReturn="True"
                     IsReadOnly="True"
                     TextWrapping="NoWrap"
                     ScrollViewer.HorizontalScrollBarVisibility="Auto"
                     ScrollViewer.VerticalScrollBarVisibility="Auto"
                     Text="{Binding Editor.RequestCodeCurlCommand}"
                     FontFamily="{StaticResource Font.Monospace}" />

            <StackPanel Grid.Row="3"
                        Orientation="Horizontal"
                        HorizontalAlignment="Right"
                        Spacing="{StaticResource Space.2}">
              <Button Classes="DialogSecondaryButton"
                      Content="关闭"
                      Command="{Binding Editor.CloseRequestCodeDialogCommand}" />
            </StackPanel>
          </Grid>
        </Border>
      </Grid>
    </Border>
  </Grid>
</UserControl>
