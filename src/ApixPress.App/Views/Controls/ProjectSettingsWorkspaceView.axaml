<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:vm="using:ApixPress.App.ViewModels"
             x:Class="ApixPress.App.Views.Controls.ProjectSettingsWorkspaceView"
             x:DataType="vm:ProjectTabViewModel"
             mc:Ignorable="d">
  <Grid ColumnDefinitions="286,*"
        ColumnSpacing="{StaticResource Space.3}"
        Panel.ZIndex="1"
        IsVisible="{Binding Shell.IsProjectSettingsSection}">
    <Border Grid.Column="0"
            Classes="PanelCard ProjectWorkspaceSidebarCard">
      <Grid RowDefinitions="Auto,*"
            RowSpacing="{StaticResource Space.3}">
        <StackPanel Spacing="2">
          <TextBlock Classes="SectionTitle"
                     Text="{Binding Summary.ProjectSettingsSidebarTitle}" />
          <TextBlock Classes="CaptionText"
                     Text="{Binding Summary.ProjectSettingsSidebarDescription}" />
        </StackPanel>

        <ScrollViewer Grid.Row="1"
                      HorizontalScrollBarVisibility="Disabled">
          <Border Classes="ProjectSettingsSidebarCard">
            <StackPanel Spacing="{StaticResource Space.4}">
              <StackPanel Spacing="{StaticResource Space.2}">
                <TextBlock Classes="ProjectSettingsGroupTitle"
                           Text="{Binding Summary.ProjectSettingsOverviewGroupTitle}" />
                <Button Classes="ProjectSettingsSidebarItemButton"
                        Classes.ProjectSettingsSidebarItemSelected="{Binding Settings.IsOverviewSelected}"
                        Command="{Binding Settings.ShowOverviewCommand}">
                  <TextBlock Text="{Binding Summary.ProjectSettingsOverviewGroupTitle}" />
                </Button>
              </StackPanel>

              <StackPanel Spacing="{StaticResource Space.2}">
                <TextBlock Classes="ProjectSettingsGroupTitle"
                           Text="{Binding Summary.ProjectSettingsImportGroupTitle}" />
                <Button Classes="ProjectSettingsSidebarItemButton"
                        Classes.ProjectSettingsSidebarItemSelected="{Binding Settings.IsImportDataSelected}"
                        Command="{Binding Settings.ShowImportDataCommand}">
                  <TextBlock Text="{Binding Summary.ProjectSettingsImportDataTitle}" />
                </Button>
                <Button Classes="ProjectSettingsSidebarItemButton"
                        Classes.ProjectSettingsSidebarItemSelected="{Binding Settings.IsExportDataSelected}"
                        Command="{Binding Settings.ShowExportDataCommand}">
                  <TextBlock Text="{Binding Summary.ProjectSettingsExportDataTitle}" />
                </Button>
              </StackPanel>

              <Border Classes="ProjectSettingsSidebarMetaCard">
                <StackPanel Spacing="{StaticResource Space.2}">
                  <TextBlock Text="{Binding Project.DisplayName}"
                             FontWeight="SemiBold" />
                  <TextBlock Classes="CaptionText"
                             Text="{Binding Summary.CurrentEnvironmentSummaryText}" />
                  <TextBlock Classes="CaptionText"
                             Text="{Binding Summary.ImportedApiDocumentSummaryText}" />
                </StackPanel>
              </Border>
            </StackPanel>
          </Border>
        </ScrollViewer>
      </Grid>
    </Border>

    <Border Grid.Column="1"
            Classes="PanelCard ProjectWorkspaceCanvas">
      <Grid RowDefinitions="Auto,*"
            RowSpacing="{StaticResource Space.4}">
        <Grid>
          <StackPanel Spacing="2">
            <TextBlock Classes="SectionTitle"
                       Text="{Binding Settings.CurrentTitle}" />
            <TextBlock Classes="CaptionText"
                       Text="{Binding Settings.CurrentSubtitle}"
                       IsVisible="{Binding Settings.IsImportDataSelected}" />
            <TextBlock Classes="CaptionText"
                       Text="{Binding Settings.CurrentSubtitle}"
                       IsVisible="{Binding Settings.IsExportDataSelected}" />
          </StackPanel>
        </Grid>

        <Grid Grid.Row="1">
          <ScrollViewer HorizontalScrollBarVisibility="Disabled"
                        IsVisible="{Binding Settings.IsOverviewSelected}">
            <StackPanel Spacing="{StaticResource Space.4}">
              <Border Classes="ProjectSettingsInfoCard">
                <StackPanel Spacing="{StaticResource Space.3}">
                  <StackPanel Spacing="2">
                    <TextBlock Classes="SectionTitle"
                               Text="{Binding Summary.ProjectSettingsOverviewCardTitle}" />
                    <TextBlock Classes="CaptionText"
                               Text="{Binding Summary.ProjectSettingsOverviewCardDescription}" />
                  </StackPanel>

                  <Border Classes="ProjectSettingsBasicCard">
                    <StackPanel>
                      <Border Classes="ProjectSettingsBasicRow">
                        <Grid ColumnDefinitions="180,*,Auto"
                              ColumnSpacing="{StaticResource Space.4}">
                          <TextBlock Classes="ProjectSettingsRowLabel"
                                     Text="项目名称" />
                          <TextBlock Grid.Column="1"
                                     Text="{Binding Project.Name}"
                                     VerticalAlignment="Center" />
                          <Button Grid.Column="2"
                                  Classes="ProjectSettingsInlineActionButton"
                                  Click="OnOpenProjectDrawer"
                                  Content="编辑" />
                        </Grid>
                      </Border>

                      <Border Classes="ProjectSettingsBasicRow">
                        <Grid ColumnDefinitions="180,*"
                              ColumnSpacing="{StaticResource Space.4}">
                          <TextBlock Classes="ProjectSettingsRowLabel"
                                     Text="项目 ID" />
                          <TextBlock Grid.Column="1"
                                     Text="{Binding ProjectId}"
                                     VerticalAlignment="Center" />
                        </Grid>
                      </Border>

                      <Border Classes="ProjectSettingsBasicRow ProjectSettingsBasicRowLast">
                        <Grid ColumnDefinitions="180,*,Auto"
                              ColumnSpacing="{StaticResource Space.4}">
                          <TextBlock Classes="ProjectSettingsRowLabel"
                                     Text="简介" />
                          <TextBlock Grid.Column="1"
                                     Text="{Binding Settings.ProjectDescription}"
                                     TextWrapping="Wrap"
                                     VerticalAlignment="Center" />
                          <Button Grid.Column="2"
                                  Classes="ProjectSettingsInlineActionButton"
                                  Click="OnOpenProjectDrawer"
                                  Content="编辑" />
                        </Grid>
                      </Border>
                    </StackPanel>
                  </Border>
                </StackPanel>
              </Border>

              <Border Classes="SettingsPageSection SettingsDangerSection">
                <StackPanel Spacing="{StaticResource Space.3}">
                  <StackPanel Spacing="2">
                    <TextBlock Classes="SettingsGroupTitle"
                               Text="{Binding Summary.ProjectSettingsDangerCardTitle}" />
                    <TextBlock Classes="CaptionText"
                               Text="{Binding Summary.ProjectSettingsDangerCardDescription}"
                               TextWrapping="Wrap" />
                  </StackPanel>

                  <Border Classes="ProjectSettingsBasicCard">
                    <StackPanel>
                      <Border Classes="ProjectSettingsBasicRow">
                        <Grid ColumnDefinitions="*,Auto"
                              ColumnSpacing="{StaticResource Space.4}">
                          <StackPanel Spacing="4">
                            <TextBlock Classes="ProjectSettingsRowLabel"
                                       Text="{Binding Summary.ProjectSettingsClearProjectDataTitle}" />
                            <TextBlock Classes="CaptionText"
                                       Text="{Binding Summary.ProjectSettingsClearProjectDataDescription}"
                                       TextWrapping="Wrap" />
                          </StackPanel>
                          <Button Grid.Column="1"
                                  Classes="DialogDangerButton"
                                  Content="{Binding Settings.ClearProjectDataButtonText}"
                                  IsEnabled="{Binding Settings.CanRunProjectDangerOperation}"
                                  Command="{Binding Settings.RequestClearProjectDataCommand}" />
                        </Grid>
                      </Border>

                      <Border Classes="ProjectSettingsBasicRow ProjectSettingsBasicRowLast">
                        <Grid ColumnDefinitions="*,Auto"
                              ColumnSpacing="{StaticResource Space.4}">
                          <StackPanel Spacing="4">
                            <TextBlock Classes="ProjectSettingsRowLabel"
                                       Text="{Binding Summary.ProjectSettingsDeleteProjectTitle}" />
                            <TextBlock Classes="CaptionText"
                                       Text="{Binding Summary.ProjectSettingsDeleteProjectDescription}"
                                       TextWrapping="Wrap" />
                          </StackPanel>
                          <Button Grid.Column="1"
                                  Classes="DialogDangerButton"
                                  Content="{Binding Settings.DeleteProjectButtonText}"
                                  IsEnabled="{Binding Settings.CanRunProjectDangerOperation}"
                                  Command="{Binding Settings.RequestDeleteProjectCommand}" />
                        </Grid>
                      </Border>
                    </StackPanel>
                  </Border>

                  <TextBlock Classes="CaptionText"
                             Text="{Binding Settings.ProjectDangerOperationStatus}"
                             TextWrapping="Wrap" />
                </StackPanel>
              </Border>
            </StackPanel>
          </ScrollViewer>

          <ScrollViewer HorizontalScrollBarVisibility="Disabled"
                        IsVisible="{Binding Settings.IsImportDataSelected}">
            <StackPanel Spacing="{StaticResource Space.4}">
              <Border Classes="ProjectSettingsInfoCard">
                <StackPanel Spacing="{StaticResource Space.3}">
                  <Border Classes="ProjectSettingsSectionDivider" />
                  <StackPanel Spacing="2">
                    <TextBlock Classes="SectionTitle"
                               Text="{Binding Summary.ProjectSettingsImportCardTitle}" />
                    <TextBlock Classes="CaptionText"
                               Text="{Binding Summary.ProjectSettingsImportCardDescription}" />
                  </StackPanel>
                  <Button Classes="ProjectImportCatalogButton"
                          Command="{Binding Import.OpenDialogCommand}">
                    <Grid ColumnDefinitions="Auto,*"
                          ColumnSpacing="{StaticResource Space.3}">
                      <Border Width="42"
                              Height="42"
                              Classes="ProjectImportFormatIcon">
                        <TextBlock HorizontalAlignment="Center"
                                   VerticalAlignment="Center"
                                   FontSize="{StaticResource Font.Size.BodyLarge}"
                                   FontWeight="Bold"
                                   Text="S" />
                      </Border>
                      <StackPanel Grid.Column="1"
                                  Spacing="2"
                                  VerticalAlignment="Center">
                        <TextBlock Text="{Binding Summary.ProjectSettingsImportFormatName}"
                                   FontWeight="SemiBold" />
                        <TextBlock Classes="CaptionText"
                                   Text="{Binding Summary.ProjectSettingsImportFormatDescription}" />
                      </StackPanel>
                    </Grid>
                  </Button>

                  <Border Classes="ProjectSettingsSectionDivider" />
                  <StackPanel Spacing="2">
                    <TextBlock Classes="SectionTitle"
                               Text="{Binding Summary.ProjectSettingsImportPackageCardTitle}" />
                    <TextBlock Classes="CaptionText"
                               Text="{Binding Summary.ProjectSettingsImportPackageCardDescription}" />
                  </StackPanel>
                  <Button Classes="ProjectImportCatalogButton"
                          Command="{Binding Import.ImportProjectDataPackageFileCommand}">
                    <Grid ColumnDefinitions="Auto,*"
                          ColumnSpacing="{StaticResource Space.3}">
                      <Border Width="42"
                              Height="42"
                              Classes="ProjectImportFormatIcon">
                        <TextBlock HorizontalAlignment="Center"
                                   VerticalAlignment="Center"
                                   FontSize="{StaticResource Font.Size.BodyLarge}"
                                   FontWeight="Bold"
                                   Text="P" />
                      </Border>
                      <StackPanel Grid.Column="1"
                                  Spacing="2"
                                  VerticalAlignment="Center">
                        <TextBlock Text="{Binding Summary.ProjectSettingsImportPackageFormatName}"
                                   FontWeight="SemiBold" />
                        <TextBlock Classes="CaptionText"
                                   Text="{Binding Summary.ProjectSettingsImportPackageFormatDescription}" />
                      </StackPanel>
                    </Grid>
                  </Button>
                </StackPanel>
              </Border>
            </StackPanel>
          </ScrollViewer>

          <ScrollViewer HorizontalScrollBarVisibility="Disabled"
                        IsVisible="{Binding Settings.IsExportDataSelected}">
            <StackPanel Spacing="{StaticResource Space.4}">
              <Border Classes="ProjectSettingsInfoCard">
                <StackPanel Spacing="{StaticResource Space.3}">
                  <Border Classes="ProjectSettingsSectionDivider" />
                  <StackPanel Spacing="2">
                    <TextBlock Classes="SectionTitle"
                               Text="{Binding Summary.ProjectSettingsExportCardTitle}" />
                    <TextBlock Classes="CaptionText"
                               Text="{Binding Summary.ProjectSettingsExportCardDescription}" />
                  </StackPanel>
                  <Button Classes="ProjectImportCatalogButton"
                          Command="{Binding Import.ExportProjectDataCommand}">
                    <Grid ColumnDefinitions="Auto,*"
                          ColumnSpacing="{StaticResource Space.3}">
                      <Border Width="42"
                              Height="42"
                              Classes="ProjectImportFormatIcon">
                        <TextBlock HorizontalAlignment="Center"
                                   VerticalAlignment="Center"
                                   FontSize="{StaticResource Font.Size.BodyLarge}"
                                   FontWeight="Bold"
                                   Text="E" />
                      </Border>
                      <StackPanel Grid.Column="1"
                                  Spacing="2"
                                  VerticalAlignment="Center">
                        <TextBlock Text="{Binding Summary.ProjectSettingsExportFormatName}"
                                   FontWeight="SemiBold" />
                        <TextBlock Classes="CaptionText"
                                   Text="{Binding Summary.ProjectSettingsExportFormatDescription}" />
                      </StackPanel>
                    </Grid>
                  </Button>
                </StackPanel>
              </Border>
            </StackPanel>
          </ScrollViewer>
        </Grid>
      </Grid>
    </Border>

    <Border Grid.ColumnSpan="2"
            Classes="CreateProjectDialogBackdrop"
            IsVisible="{Binding Settings.IsClearProjectDataConfirmDialogOpen}">
      <Grid HorizontalAlignment="Center"
            VerticalAlignment="Center">
        <Border Classes="SettingsDangerConfirmCard">
          <StackPanel Spacing="{StaticResource Space.4}">
            <StackPanel Spacing="{StaticResource Space.2}">
              <TextBlock Classes="DialogTitle"
                         Text="确认清空项目数据？" />
              <TextBlock Classes="CaptionText"
                         Text="{Binding Project.Name, StringFormat='将清空项目 {0} 的接口、用例、导入文档、环境变量和请求历史，项目本身会保留。'}"
                         TextWrapping="Wrap" />
            </StackPanel>
            <Border Classes="CreateProjectDialogDivider" />
            <StackPanel Orientation="Horizontal"
                        HorizontalAlignment="Right"
                        Spacing="{StaticResource Space.2}">
              <Button Classes="DialogSecondaryButton"
                      Content="取消"
                      Command="{Binding Settings.CancelClearProjectDataCommand}" />
              <Button Classes="DialogDangerButton"
                      Content="{Binding Settings.ClearProjectDataButtonText}"
                      Command="{Binding Settings.ConfirmClearProjectDataCommand}" />
            </StackPanel>
          </StackPanel>
        </Border>
      </Grid>
    </Border>

    <Border Grid.ColumnSpan="2"
            Classes="CreateProjectDialogBackdrop"
            IsVisible="{Binding Settings.IsDeleteProjectConfirmDialogOpen}">
      <Grid HorizontalAlignment="Center"
            VerticalAlignment="Center">
        <Border Classes="SettingsDangerConfirmCard">
          <StackPanel Spacing="{StaticResource Space.4}">
            <StackPanel Spacing="{StaticResource Space.2}">
              <TextBlock Classes="DialogTitle"
                         Text="确认删除项目？" />
              <TextBlock Classes="CaptionText"
                         Text="{Binding Project.Name, StringFormat='项目 {0} 会被删除，相关接口、用例、导入文档、环境配置和请求历史都会一并删除，不能撤销。'}"
                         TextWrapping="Wrap" />
            </StackPanel>
            <Border Classes="CreateProjectDialogDivider" />
            <StackPanel Orientation="Horizontal"
                        HorizontalAlignment="Right"
                        Spacing="{StaticResource Space.2}">
              <Button Classes="DialogSecondaryButton"
                      Content="取消"
                      Command="{Binding Settings.CancelDeleteProjectCommand}" />
              <Button Classes="DialogDangerButton"
                      Content="{Binding Settings.DeleteProjectButtonText}"
                      Command="{Binding Settings.ConfirmDeleteProjectCommand}" />
            </StackPanel>
          </StackPanel>
        </Border>
      </Grid>
    </Border>
  </Grid>
</UserControl>
