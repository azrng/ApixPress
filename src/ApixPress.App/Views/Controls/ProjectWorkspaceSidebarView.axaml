<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:iri="https://irihi.tech/shared"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:u="https://irihi.tech/ursa"
             xmlns:vm="using:ApixPress.App.ViewModels"
             x:Class="ApixPress.App.Views.Controls.ProjectWorkspaceSidebarView"
             x:DataType="vm:ProjectTabViewModel"
             mc:Ignorable="d">
  <UserControl.Resources>
    <DataTemplate x:Key="ProjectSidebarExplorerItemTemplate"
                  x:DataType="vm:ExplorerItemViewModel">
      <StackPanel Spacing="0">
        <StackPanel Orientation="Horizontal"
                    Spacing="1">
          <ToggleButton x:Name="ExplorerExpandToggle"
                        Classes="ProjectSidebarTreeExpanderToggle"
                        IsChecked="{Binding IsExpanded, Mode=TwoWay}"
                        IsVisible="{Binding HasChildren}">
            <Grid>
              <TextBlock Classes="ProjectSidebarCatalogChevron"
                         FontFamily="Segoe Fluent Icons, Segoe MDL2 Assets"
                         IsVisible="{Binding !#ExplorerExpandToggle.IsChecked}"
                         Text="&#xE76C;" />
              <TextBlock Classes="ProjectSidebarCatalogChevron"
                         FontFamily="Segoe Fluent Icons, Segoe MDL2 Assets"
                         IsVisible="{Binding #ExplorerExpandToggle.IsChecked}"
                         Text="&#xE70D;" />
            </Grid>
          </ToggleButton>
          <Border Classes="ProjectSidebarTreeExpanderSpacer"
                  IsVisible="{Binding !HasChildren}" />

          <Button Classes="WorkspaceTreeNodeButton"
                  IsHitTestVisible="{Binding IsClickable}"
                  Command="{Binding $parent[Window].((vm:MainWindowViewModel)DataContext).LoadSavedRequestCommand}"
                  CommandParameter="{Binding}">
            <Button.ContextMenu>
              <ContextMenu DataContext="{Binding}">
                <MenuItem Header="删除"
                          IsEnabled="{Binding CanDelete}"
                          Command="{Binding DeleteCommand}"
                          CommandParameter="{Binding}" />
              </ContextMenu>
            </Button.ContextMenu>
            <StackPanel Spacing="1">
              <Grid ColumnDefinitions="Auto,Auto,*,Auto"
                    ColumnSpacing="2">
                <TextBlock Grid.Column="0"
                           Classes="WorkspaceTreeNodeGlyph"
                           FontFamily="Segoe Fluent Icons, Segoe MDL2 Assets"
                           Text="{Binding NodeGlyph}"
                           IsVisible="{Binding ShowLeadingGlyph}" />
                <TextBlock Grid.Column="0"
                           Classes="WorkspaceTreeNodeGlyph WorkspaceTreeCaseGlyph"
                           FontFamily="Segoe Fluent Icons, Segoe MDL2 Assets"
                           Text="{Binding NodeGlyph}"
                           IsVisible="{Binding IsHttpCaseNode}" />
                <u:Badge Grid.Column="1"
                         Margin="0,0,2,0"
                         Header="{Binding MethodBadgeText}"
                         IsVisible="{Binding ShowMethodBadge}"
                         iri:ClassHelper.Classes="{Binding MethodBadgeClass}" />
                <TextBlock Grid.Column="2"
                           Text="{Binding Title}"
                           VerticalAlignment="Center"
                           TextWrapping="Wrap" />
                <Border Grid.Column="3"
                        Classes="WorkspaceTreeStatusDot"
                        IsVisible="{Binding ShowTrailingDot}" />
              </Grid>
              <TextBlock Classes="CaptionText WorkspaceTreeSubtitleText"
                         Text="{Binding Subtitle}"
                         IsVisible="{Binding HasSubtitle}" />
            </StackPanel>
          </Button>
        </StackPanel>

        <ItemsControl Classes="ProjectSidebarInlineTreeChildren"
                      ItemsSource="{Binding Children}"
                      IsVisible="{Binding IsExpanded}">
          <ItemsControl.ItemTemplate>
            <StaticResource ResourceKey="ProjectSidebarExplorerItemTemplate" />
          </ItemsControl.ItemTemplate>
        </ItemsControl>
      </StackPanel>
    </DataTemplate>
  </UserControl.Resources>

  <Border Classes="PanelCard ProjectWorkspaceSidebarCard">
    <Grid>
      <Grid IsVisible="{Binding IsInterfaceManagementSection}"
            RowDefinitions="Auto,Auto,*"
            RowSpacing="{StaticResource Space.3}">
        <Grid ColumnDefinitions="*">
          <StackPanel Spacing="4">
            <TextBlock Classes="SectionTitle"
                       Text="接口管理" />
          </StackPanel>
        </Grid>

        <Grid Grid.Row="1"
              ColumnDefinitions="*,Auto"
              ColumnSpacing="{StaticResource Space.2}">
          <TextBox Grid.Column="0"
                   Classes="ProjectSidebarSearchBox"
                   Watermark="搜索" />
          <Button Grid.Column="1"
                  Classes="ProjectSidebarAddButton"
                  Command="{Binding OpenHttpInterfaceWorkspaceCommand}">
            <TextBlock FontFamily="Segoe Fluent Icons, Segoe MDL2 Assets"
                       Text="&#xE710;" />
          </Button>
        </Grid>

        <ScrollViewer Grid.Row="2">
          <StackPanel Spacing="{StaticResource Space.3}">
            <Border Classes="ProjectSidebarSectionCard ProjectSidebarModuleSectionCard">
              <StackPanel Classes="ProjectSidebarModuleGroup">
                <Grid Classes="ProjectSidebarModuleHeader"
                      ColumnDefinitions="Auto,Auto,*"
                      ColumnSpacing="{StaticResource Space.2}">
                  <TextBlock Grid.Column="0"
                             Classes="ProjectSidebarTreeChevron"
                             FontFamily="Segoe Fluent Icons, Segoe MDL2 Assets"
                             Text="&#xE70D;" />
                  <TextBlock Grid.Column="1"
                             Classes="WorkspaceTreeNodeGlyph"
                             FontFamily="Segoe Fluent Icons, Segoe MDL2 Assets"
                             Text="&#xE8B7;" />
                  <TextBlock Grid.Column="2"
                             Classes="ProjectSidebarSectionTitle"
                             Text="默认模块" />
                </Grid>
                <StackPanel Classes="ProjectSidebarModuleChildren">
                  <ToggleButton x:Name="InterfaceCatalogToggle"
                                Classes="ProjectSidebarCatalogToggleButton ProjectSidebarCatalogActiveButton ProjectSidebarCatalogFlatButton"
                                IsChecked="{Binding IsInterfaceCatalogExpanded, Mode=TwoWay}">
                    <Grid ColumnDefinitions="Auto,Auto,*,Auto"
                          ColumnSpacing="{StaticResource Space.2}">
                      <TextBlock Grid.Column="0"
                                 Classes="ProjectSidebarCatalogChevron"
                                 FontFamily="Segoe Fluent Icons, Segoe MDL2 Assets"
                                 IsVisible="{Binding !#InterfaceCatalogToggle.IsChecked}"
                                 Text="&#xE76C;" />
                      <TextBlock Grid.Column="0"
                                 Classes="ProjectSidebarCatalogChevron"
                                 FontFamily="Segoe Fluent Icons, Segoe MDL2 Assets"
                                 IsVisible="{Binding #InterfaceCatalogToggle.IsChecked}"
                                 Text="&#xE70D;" />
                      <TextBlock Grid.Column="1"
                                 Classes="WorkspaceTreeNodeGlyph"
                                 FontFamily="Segoe Fluent Icons, Segoe MDL2 Assets"
                                 Text="&#xE8C8;" />
                      <TextBlock Grid.Column="2"
                                 Classes="ProjectSidebarCatalogTitle"
                                 Text="接口" />
                    </Grid>
                  </ToggleButton>

                  <Border Classes="ProjectSidebarCatalogBody"
                          IsVisible="{Binding IsInterfaceCatalogExpanded}">
                    <StackPanel Classes="ProjectSidebarCatalogContent">
                      <TextBlock Classes="CaptionText ProjectSidebarEmptyHint"
                                 Text="当前还没有保存的 HTTP 接口"
                                 IsVisible="{Binding ShowInterfaceEntriesEmptyState}" />
                      <ItemsControl Classes="ProjectSidebarInlineTree"
                                    ItemsSource="{Binding InterfaceCatalogItems}">
                        <ItemsControl.ItemTemplate>
                          <StaticResource ResourceKey="ProjectSidebarExplorerItemTemplate" />
                        </ItemsControl.ItemTemplate>
                      </ItemsControl>
                    </StackPanel>
                  </Border>

                  <ToggleButton x:Name="DataModelCatalogToggle"
                                Classes="ProjectSidebarCatalogToggleButton"
                                IsChecked="{Binding IsDataModelCatalogExpanded, Mode=TwoWay}">
                    <Grid ColumnDefinitions="Auto,*,Auto"
                          ColumnSpacing="{StaticResource Space.2}">
                      <TextBlock Grid.Column="0"
                                 Classes="WorkspaceTreeNodeGlyph"
                                 FontFamily="Segoe Fluent Icons, Segoe MDL2 Assets"
                                 Text="&#xEC1A;" />
                      <TextBlock Grid.Column="1"
                                 Classes="ProjectSidebarSectionTitle"
                                 Text="数据模型" />
                      <TextBlock Grid.Column="2"
                                 Classes="ProjectSidebarCatalogChevron"
                                 FontFamily="Segoe Fluent Icons, Segoe MDL2 Assets"
                                 IsVisible="{Binding !#DataModelCatalogToggle.IsChecked}"
                                 Text="&#xE76C;" />
                      <TextBlock Grid.Column="2"
                                 Classes="ProjectSidebarCatalogChevron"
                                 FontFamily="Segoe Fluent Icons, Segoe MDL2 Assets"
                                 IsVisible="{Binding #DataModelCatalogToggle.IsChecked}"
                                 Text="&#xE70D;" />
                    </Grid>
                  </ToggleButton>

                  <ToggleButton x:Name="ComponentCatalogToggle"
                                Classes="ProjectSidebarCatalogToggleButton"
                                IsChecked="{Binding IsComponentLibraryCatalogExpanded, Mode=TwoWay}">
                    <Grid ColumnDefinitions="Auto,*,Auto"
                          ColumnSpacing="{StaticResource Space.2}">
                      <TextBlock Grid.Column="0"
                                 Classes="WorkspaceTreeNodeGlyph"
                                 FontFamily="Segoe Fluent Icons, Segoe MDL2 Assets"
                                 Text="&#xE8FD;" />
                      <TextBlock Grid.Column="1"
                                 Classes="ProjectSidebarSectionTitle"
                                 Text="组件库" />
                      <TextBlock Grid.Column="2"
                                 Classes="ProjectSidebarCatalogChevron"
                                 FontFamily="Segoe Fluent Icons, Segoe MDL2 Assets"
                                 IsVisible="{Binding !#ComponentCatalogToggle.IsChecked}"
                                 Text="&#xE76C;" />
                      <TextBlock Grid.Column="2"
                                 Classes="ProjectSidebarCatalogChevron"
                                 FontFamily="Segoe Fluent Icons, Segoe MDL2 Assets"
                                 IsVisible="{Binding #ComponentCatalogToggle.IsChecked}"
                                 Text="&#xE70D;" />
                    </Grid>
                  </ToggleButton>
                </StackPanel>
              </StackPanel>
            </Border>

            <Border Classes="ProjectSidebarSectionCard">
              <StackPanel Classes="ProjectSidebarTopLevelSection">
                <ToggleButton x:Name="QuickRequestCatalogToggle"
                              Classes="ProjectSidebarCatalogToggleButton ProjectSidebarCatalogFlatButton"
                              IsChecked="{Binding IsQuickRequestCatalogExpanded, Mode=TwoWay}">
                  <Grid ColumnDefinitions="Auto,Auto,*,Auto"
                        ColumnSpacing="{StaticResource Space.2}">
                    <TextBlock Grid.Column="0"
                               Classes="ProjectSidebarCatalogChevron"
                               FontFamily="Segoe Fluent Icons, Segoe MDL2 Assets"
                               IsVisible="{Binding !#QuickRequestCatalogToggle.IsChecked}"
                               Text="&#xE76C;" />
                    <TextBlock Grid.Column="0"
                               Classes="ProjectSidebarCatalogChevron"
                               FontFamily="Segoe Fluent Icons, Segoe MDL2 Assets"
                               IsVisible="{Binding #QuickRequestCatalogToggle.IsChecked}"
                               Text="&#xE70D;" />
                    <TextBlock Grid.Column="1"
                               Classes="WorkspaceTreeNodeGlyph"
                               FontFamily="Segoe Fluent Icons, Segoe MDL2 Assets"
                               Text="&#xE945;" />
                    <TextBlock Grid.Column="2"
                               Classes="ProjectSidebarSectionTitle"
                               Text="快捷请求" />
                  </Grid>
                </ToggleButton>
                <Border Classes="ProjectSidebarCatalogBody QuickRequestCatalogBody"
                        IsVisible="{Binding IsQuickRequestCatalogExpanded}">
                  <StackPanel Classes="ProjectSidebarCatalogContent QuickRequestCatalogContent">
                    <TreeView Classes="WorkspaceTreeView ProjectSidebarTree QuickRequestSidebarTree"
                              ItemsSource="{Binding QuickRequestTreeItems}">
                      <TreeView.ItemTemplate>
                        <TreeDataTemplate x:DataType="vm:ExplorerItemViewModel"
                                          ItemsSource="{Binding Children}">
                          <Button Classes="WorkspaceTreeNodeButton QuickRequestTreeNodeButton"
                                  IsHitTestVisible="{Binding CanLoad}"
                                  Command="{Binding $parent[Window].((vm:MainWindowViewModel)DataContext).LoadSavedRequestCommand}"
                                  CommandParameter="{Binding}">
                            <Button.ContextMenu>
                              <ContextMenu DataContext="{Binding}">
                                <MenuItem Header="删除"
                                          IsEnabled="{Binding CanDelete}"
                                          Command="{Binding DeleteCommand}"
                                          CommandParameter="{Binding}" />
                              </ContextMenu>
                            </Button.ContextMenu>
                            <StackPanel Classes="QuickRequestTreeNodeContent">
                              <Grid ColumnDefinitions="Auto,Auto,*,Auto"
                                    ColumnSpacing="{StaticResource Space.1}">
                                <TextBlock Grid.Column="0"
                                           Classes="WorkspaceTreeNodeGlyph"
                                           FontFamily="Segoe Fluent Icons, Segoe MDL2 Assets"
                                           Text="{Binding NodeGlyph}"
                                           IsVisible="{Binding ShowLeadingGlyph}" />
                                <TextBlock Grid.Column="0"
                                           Classes="WorkspaceTreeNodeGlyph WorkspaceTreeCaseGlyph"
                                           FontFamily="Segoe Fluent Icons, Segoe MDL2 Assets"
                                           Text="{Binding NodeGlyph}"
                                           IsVisible="{Binding IsHttpCaseNode}" />
                                <u:Badge Grid.Column="1"
                                         Margin="0,0,4,0"
                                         Header="{Binding MethodBadgeText}"
                                         IsVisible="{Binding ShowMethodBadge}"
                                         iri:ClassHelper.Classes="{Binding MethodBadgeClass}" />
                                <TextBlock Grid.Column="2"
                                           Text="{Binding Title}"
                                           VerticalAlignment="Center"
                                           TextWrapping="Wrap" />
                                <Border Grid.Column="3"
                                        Classes="WorkspaceTreeStatusDot"
                                        IsVisible="{Binding ShowTrailingDot}" />
                              </Grid>
                              <TextBlock Classes="CaptionText WorkspaceTreeSubtitleText"
                                         Text="{Binding Subtitle}"
                                         IsVisible="{Binding HasSubtitle}" />
                            </StackPanel>
                          </Button>
                        </TreeDataTemplate>
                      </TreeView.ItemTemplate>
                    </TreeView>
                    <Button Classes="ProjectSidebarGhostButton ProjectSidebarBottomCreateButton QuickRequestBottomCreateButton"
                            Content="+ 新建"
                            Command="{Binding OpenQuickRequestWorkspaceCommand}" />
                  </StackPanel>
                </Border>
              </StackPanel>
            </Border>
          </StackPanel>
        </ScrollViewer>
      </Grid>

      <Grid IsVisible="{Binding IsRequestHistorySection}"
            RowDefinitions="Auto,*"
            RowSpacing="{StaticResource Space.3}">
        <Grid ColumnDefinitions="*,Auto"
              ColumnSpacing="{StaticResource Space.2}">
          <StackPanel Spacing="2">
            <TextBlock Classes="SectionTitle"
                       Text="请求历史" />
            <TextBlock Classes="CaptionText"
                       Text="可直接载入历史请求，或转存为接口草稿。" />
          </StackPanel>
          <u:PopConfirm Grid.Column="1"
                        PopupHeader="确认清空当前项目的请求历史？"
                        PopupContent="清空后无法恢复。"
                        ConfirmCommand="{Binding $parent[Window].((vm:MainWindowViewModel)DataContext).ClearHistoryCommand}">
            <Button Classes="SecondaryButton"
                    Content="清空" />
          </u:PopConfirm>
        </Grid>

        <ScrollViewer Grid.Row="1">
          <StackPanel Spacing="{StaticResource Space.2}">
            <TextBlock Classes="CaptionText"
                       Text="还没有发送记录"
                       IsVisible="{Binding ShowHistoryEmptyState}" />
            <ItemsControl ItemsSource="{Binding RequestHistory}"
                          IsVisible="{Binding HasHistory}">
              <ItemsControl.ItemTemplate>
                <DataTemplate x:DataType="vm:RequestHistoryItemViewModel">
                  <Border Classes="SidebarListCard">
                    <StackPanel Spacing="{StaticResource Space.2}">
                      <Grid ColumnDefinitions="Auto,*"
                            ColumnSpacing="{StaticResource Space.2}">
                        <u:Badge Grid.Column="0"
                                 Header="{Binding Method}"
                                 iri:ClassHelper.Classes="{Binding MethodBadgeClass}" />
                        <TextBlock Grid.Column="1"
                                   Text="{Binding Url}"
                                   TextTrimming="CharacterEllipsis" />
                      </Grid>
                      <Grid ColumnDefinitions="Auto,*,Auto,Auto"
                            ColumnSpacing="{StaticResource Space.2}">
                        <TextBlock Classes="CaptionText"
                                   Text="{Binding StatusText}" />
                        <TextBlock Grid.Column="1"
                                   Classes="CaptionText"
                                   Text="{Binding TimestampText}" />
                        <Button Grid.Column="2"
                                Classes="TextButton"
                                Content="载入"
                                Command="{Binding $parent[Window].((vm:MainWindowViewModel)DataContext).LoadHistoryItemCommand}"
                                CommandParameter="{Binding}" />
                        <Button Grid.Column="3"
                                Classes="TextButton"
                                Content="转存"
                                Command="{Binding $parent[Window].((vm:MainWindowViewModel)DataContext).SaveHistoryAsCaseCommand}"
                                CommandParameter="{Binding}" />
                      </Grid>
                    </StackPanel>
                  </Border>
                </DataTemplate>
              </ItemsControl.ItemTemplate>
            </ItemsControl>
          </StackPanel>
        </ScrollViewer>
      </Grid>
    </Grid>
  </Border>
</UserControl>
