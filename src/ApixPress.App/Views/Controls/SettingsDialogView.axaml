<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:vm="using:ApixPress.App.ViewModels"
             x:Class="ApixPress.App.Views.Controls.SettingsDialogView"
             x:DataType="vm:MainWindowViewModel"
             mc:Ignorable="d">
  <Border Classes="SettingsDialogBackdrop"
          IsVisible="{Binding IsSettingsDialogOpen}">
    <Grid HorizontalAlignment="Center"
          VerticalAlignment="Center">
      <Border Classes="SettingsDialogCard">
        <Grid ColumnDefinitions="220,*"
              RowDefinitions="*">
          <Border Classes="SettingsSidebar">
            <StackPanel Spacing="{StaticResource Space.2}">
              <TextBlock Classes="SectionTitle"
                         Text="设置中心" />
               <TextBlock Classes="CaptionText"
                          Text="先保留通用和关于两个分组。" />
               <ToggleButton Classes="SettingsNavButton"
                             Command="{Binding SettingsCenter.ShowGeneralSettingsCommand}"
                             IsChecked="{Binding SettingsCenter.ShowGeneralSettingsSection, Mode=OneWay}">
                 <TextBlock Text="通用" />
               </ToggleButton>
               <ToggleButton Classes="SettingsNavButton"
                             Command="{Binding SettingsCenter.ShowAboutSettingsCommand}"
                             IsChecked="{Binding SettingsCenter.ShowAboutSettingsSection, Mode=OneWay}">
                 <TextBlock Text="关于" />
               </ToggleButton>
             </StackPanel>
           </Border>

          <Grid Grid.Column="1"
                RowDefinitions="Auto,*"
                RowSpacing="{StaticResource Space.4}"
                Margin="{StaticResource Pad.5}">
            <Grid ColumnDefinitions="*,Auto">
              <StackPanel Spacing="2">
                <TextBlock Classes="PageTitle"
                           Text="{Binding SettingsCenter.CurrentSettingsTitle}" />
                <TextBlock Classes="CaptionText"
                           Text="设置会自动保存到本地工作目录，并在后续请求中生效。" />
              </StackPanel>
              <Button Grid.Column="1"
                      Classes="DialogIconButton"
                      Command="{Binding CloseSettingsDialogCommand}"
                      Content="×" />
            </Grid>

            <ScrollViewer Grid.Row="1">
              <StackPanel>
                <Grid RowDefinitions="Auto,Auto"
                      IsVisible="{Binding SettingsCenter.ShowGeneralSettingsSection}"
                      RowSpacing="{StaticResource Space.4}">
                  <Border Classes="SettingsPageSection">
                    <Grid ColumnDefinitions="*,Auto"
                          ColumnSpacing="{StaticResource Space.4}">
                      <StackPanel Spacing="4">
                        <TextBlock Classes="SettingsGroupTitle"
                                   Text="请求超时时间" />
                        <TextBlock Classes="CaptionText"
                                   Text="输入 0 表示不限时，其余值会作为请求超时毫秒数。" />
                      </StackPanel>
                      <NumericUpDown Grid.Column="1"
                                     Classes="SettingsNumberInput"
                                     Minimum="0"
                                     Maximum="120000"
                                     Increment="1000"
                                     Value="{Binding SettingsCenter.RequestTimeoutMilliseconds}" />
                    </Grid>
                  </Border>

                  <StackPanel Grid.Row="1"
                              Spacing="{StaticResource Space.3}">
                    <Border Classes="SettingsPageSection">
                      <Grid ColumnDefinitions="*,Auto"
                            ColumnSpacing="{StaticResource Space.4}">
                        <StackPanel Spacing="4">
                          <TextBlock Classes="SettingsGroupTitle"
                                     Text="SSL 证书验证" />
                          <TextBlock Classes="CaptionText"
                                     Text="关闭后会忽略证书校验，适合本地或自签名环境调试。" />
                        </StackPanel>
                        <ToggleSwitch Grid.Column="1"
                                      IsChecked="{Binding SettingsCenter.ValidateSslCertificate}" />
                      </Grid>
                    </Border>
                    <Border Classes="SettingsPageSection">
                      <Grid ColumnDefinitions="*,Auto"
                            ColumnSpacing="{StaticResource Space.4}">
                        <StackPanel Spacing="4">
                          <TextBlock Classes="SettingsGroupTitle"
                                     Text="自动跟随重定向" />
                          <TextBlock Classes="CaptionText"
                                     Text="开启后，请求会自动处理 3xx 跳转响应。" />
                        </StackPanel>
                        <ToggleSwitch Grid.Column="1"
                                      IsChecked="{Binding SettingsCenter.AutoFollowRedirects}" />
                      </Grid>
                    </Border>
                    <Border Classes="SettingsPageSection">
                      <Grid ColumnDefinitions="*,Auto"
                            ColumnSpacing="{StaticResource Space.4}">
                        <StackPanel Spacing="4">
                          <TextBlock Classes="SettingsGroupTitle"
                                     Text="发送无缓存头" />
                          <TextBlock Classes="CaptionText"
                                     Text="开启后会自动补充 no-cache / no-store 请求头。" />
                        </StackPanel>
                        <ToggleSwitch Grid.Column="1"
                                      IsChecked="{Binding SettingsCenter.SendNoCacheHeader}" />
                      </Grid>
                    </Border>
                    <Border Classes="SettingsPageSection">
                      <Grid ColumnDefinitions="*,Auto"
                            ColumnSpacing="{StaticResource Space.4}">
                        <StackPanel Spacing="4">
                          <TextBlock Classes="SettingsGroupTitle"
                                     Text="详细日志 (Verbose Logging)" />
                          <TextBlock Classes="CaptionText"
                                     Text="当前先保存为本地偏好项，后续会继续扩展到更完整的调试输出。" />
                        </StackPanel>
                        <ToggleSwitch Grid.Column="1"
                                      IsChecked="{Binding SettingsCenter.EnableVerboseLogging}" />
                      </Grid>
                    </Border>
                    <Border Classes="SettingsPageSection">
                      <Grid ColumnDefinitions="*,Auto"
                            ColumnSpacing="{StaticResource Space.4}">
                        <StackPanel Spacing="4">
                          <TextBlock Classes="SettingsGroupTitle"
                                     Text="新版本提醒" />
                          <TextBlock Classes="CaptionText"
                                     Text="控制是否在设置中心展示 mock 更新提示。" />
                        </StackPanel>
                        <ToggleSwitch Grid.Column="1"
                                      IsChecked="{Binding SettingsCenter.EnableUpdateReminder}" />
                      </Grid>
                    </Border>
                    <TextBlock Classes="CaptionText"
                               Text="{Binding SettingsCenter.GeneralSettingsSaveStatus}" />
                  </StackPanel>
                </Grid>

                <Grid IsVisible="{Binding SettingsCenter.ShowAboutSettingsSection}">
                  <StackPanel Spacing="{StaticResource Space.4}">
                    <Border Classes="AboutHeroCard">
                      <Grid ColumnDefinitions="*,260"
                            ColumnSpacing="{StaticResource Space.4}">
                        <StackPanel Spacing="{StaticResource Space.2}"
                                    VerticalAlignment="Center">
                          <TextBlock Classes="HeroTitle"
                                     Text="{Binding AppDisplayName}" />
                          <TextBlock Classes="CaptionText"
                                     Text="轻量 API 协作与调试工作台" />
                          <StackPanel Orientation="Horizontal"
                                      Spacing="{StaticResource Space.2}">
                            <Button Classes="PrimaryButton"
                                    Content="{Binding SettingsCenter.CheckForUpdatesButtonText}"
                                    Command="{Binding SettingsCenter.CheckForUpdatesCommand}" />
                            <Border Classes="VersionTag">
                              <TextBlock Classes="CaptionText"
                                         Text="{Binding SettingsCenter.UpdateChannelName}" />
                            </Border>
                          </StackPanel>
                        </StackPanel>
                        <Border Grid.Column="1"
                                Classes="AboutVersionPanel">
                          <Grid RowDefinitions="Auto,Auto,Auto"
                                RowSpacing="{StaticResource Space.3}">
                            <Grid ColumnDefinitions="*,Auto">
                              <TextBlock Classes="AboutMetaLabel"
                                         Text="当前版本" />
                              <TextBlock Grid.Column="1"
                                         Classes="AboutMetaValue"
                                         Text="{Binding SettingsCenter.CurrentAppVersion}" />
                            </Grid>
                            <Grid Grid.Row="1"
                                  ColumnDefinitions="*,Auto">
                              <TextBlock Classes="AboutMetaLabel"
                                         Text="最新版本" />
                              <TextBlock Grid.Column="1"
                                         Classes="AboutMetaValue"
                                         Text="{Binding SettingsCenter.LatestAvailableVersion}" />
                            </Grid>
                            <Grid Grid.Row="2"
                                  ColumnDefinitions="*,Auto">
                              <TextBlock Classes="AboutMetaLabel"
                                         Text="更新渠道" />
                              <TextBlock Grid.Column="1"
                                         Classes="AboutMetaValue"
                                         Text="{Binding SettingsCenter.UpdateChannelName}" />
                            </Grid>
                          </Grid>
                        </Border>
                      </Grid>
                    </Border>
                    <Border Classes="SettingsPageSection">
                      <StackPanel Spacing="{StaticResource Space.2}">
                        <TextBlock Classes="SettingsGroupTitle"
                                   Text="更新状态" />
                        <TextBlock Classes="CaptionText"
                                   Text="{Binding SettingsCenter.AboutUpdateStatus}" />
                        <TextBlock Classes="CaptionText"
                                   Text="{Binding SettingsCenter.LastUpdateCheckText, StringFormat='最近检查：{0}'}" />
                      </StackPanel>
                    </Border>
                    <Border Classes="SettingsPageSection">
                      <StackPanel Spacing="{StaticResource Space.2}">
                        <TextBlock Classes="SettingsGroupTitle"
                                   Text="软件信息" />
                        <TextBlock Classes="CaptionText"
                                   Text="{Binding AppDisplayName, StringFormat='软件名称：{0}'}" />
                        <TextBlock Classes="CaptionText"
                                   Text="{Binding SettingsCenter.CurrentAppVersion, StringFormat='版本号：{0}'}" />
                        <TextBlock Classes="CaptionText"
                                   Text="{Binding RuntimeStackText, StringFormat='技术栈：{0}'}" />
                        <TextBlock Classes="CaptionText"
                                   Text="本地数据：SQLite / 项目级工作目录隔离" />
                      </StackPanel>
                    </Border>
                  </StackPanel>
                </Grid>
              </StackPanel>
            </ScrollViewer>
          </Grid>
        </Grid>
      </Border>
    </Grid>
  </Border>
</UserControl>
