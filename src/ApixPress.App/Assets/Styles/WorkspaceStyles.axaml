  <Style Selector="Border.HttpWorkbenchConfigCard">
    <Setter Property="MinHeight" Value="220" />
    <Setter Property="MaxHeight" Value="340" />
  </Style>

  <Style Selector="Border.ProjectWorkspaceSettingsHeader">
    <Setter Property="Background" Value="{DynamicResource Brush.Background.Subtle}" />
    <Setter Property="BorderBrush" Value="{DynamicResource Brush.Border.Default}" />
    <Setter Property="BorderThickness" Value="0,0,0,1" />
    <Setter Property="Padding" Value="{StaticResource Pad.3}" />
    <Setter Property="CornerRadius" Value="12,12,0,0" />
  </Style>

</Styles>
