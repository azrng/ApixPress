<Styles xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
  <Style Selector="Border.ProjectWorkspaceSidebarCard">
    <Setter Property="Padding" Value="14,16" />
    <Setter Property="CornerRadius" Value="{StaticResource Radius.Xl}" />
  </Style>

  <Style Selector="Border.ProjectSidebarSectionCard">
    <Setter Property="Background" Value="{DynamicResource Brush.Background.Subtle}" />
    <Setter Property="BorderBrush" Value="{DynamicResource Brush.Border.Subtle}" />
    <Setter Property="BorderThickness" Value="1" />
    <Setter Property="CornerRadius" Value="{StaticResource Radius.Lg}" />
    <Setter Property="Padding" Value="10,10" />
  </Style>

  <Style Selector="Border.ProjectSidebarModuleSectionCard">
    <Setter Property="Background" Value="{DynamicResource Brush.Status.Info.Background}" />
    <Setter Property="BorderBrush" Value="{DynamicResource Brush.Border.Default}" />
  </Style>

  <Style Selector="StackPanel.ProjectSidebarModuleGroup">
    <Setter Property="Spacing" Value="{StaticResource Space.2}" />
  </Style>

  <Style Selector="Grid.ProjectSidebarModuleHeader">
    <Setter Property="MinHeight" Value="22" />
    <Setter Property="Margin" Value="2,0,0,2" />
  </Style>

  <Style Selector="StackPanel.ProjectSidebarModuleChildren">
    <Setter Property="Spacing" Value="{StaticResource Space.2}" />
    <Setter Property="Margin" Value="10,4,0,0" />
  </Style>

  <Style Selector="StackPanel.ProjectSidebarNestedSection">
    <Setter Property="Spacing" Value="{StaticResource Space.2}" />
  </Style>

  <Style Selector="StackPanel.ProjectSidebarTopLevelSection">
    <Setter Property="Spacing" Value="{StaticResource Space.2}" />
  </Style>

  <Style Selector="Grid.ProjectSidebarTreeRow">
    <Setter Property="MinHeight" Value="24" />
  </Style>

  <Style Selector="TextBlock.ProjectSidebarTreeChevron">
    <Setter Property="FontSize" Value="10" />
    <Setter Property="Foreground" Value="{DynamicResource Brush.Text.Tertiary}" />
    <Setter Property="VerticalAlignment" Value="Center" />
  </Style>

  <Style Selector="ToggleButton.ProjectSidebarCatalogToggleButton">
    <Setter Property="Background" Value="{DynamicResource Brush.Background.Surface}" />
    <Setter Property="BorderBrush" Value="{DynamicResource Brush.Border.Subtle}" />
    <Setter Property="BorderThickness" Value="1" />
    <Setter Property="CornerRadius" Value="{StaticResource Radius.Md}" />
    <Setter Property="Padding" Value="12,8" />
    <Setter Property="HorizontalContentAlignment" Value="Stretch" />
    <Setter Property="HorizontalAlignment" Value="Stretch" />
    <Setter Property="MinHeight" Value="38" />
  </Style>

  <Style Selector="ToggleButton.ProjectSidebarCatalogToggleButton:pointerover">
    <Setter Property="Background" Value="{DynamicResource Brush.Background.Selected}" />
    <Setter Property="BorderBrush" Value="{DynamicResource Brush.Border.Focus}" />
  </Style>

  <Style Selector="ToggleButton.ProjectSidebarCatalogToggleButton:checked">
    <Setter Property="Background" Value="{DynamicResource Brush.Background.Surface}" />
    <Setter Property="BorderBrush" Value="{DynamicResource Brush.Border.Default}" />
  </Style>

  <Style Selector="ToggleButton.ProjectSidebarCatalogFlatButton">
    <Setter Property="Background" Value="Transparent" />
    <Setter Property="BorderBrush" Value="Transparent" />
    <Setter Property="BorderThickness" Value="0" />
    <Setter Property="Padding" Value="4,6" />
    <Setter Property="CornerRadius" Value="0" />
  </Style>

  <Style Selector="ToggleButton.ProjectSidebarCatalogFlatButton:pointerover">
    <Setter Property="Background" Value="Transparent" />
    <Setter Property="BorderBrush" Value="Transparent" />
  </Style>

  <Style Selector="ToggleButton.ProjectSidebarCatalogFlatButton:checked">
    <Setter Property="Background" Value="Transparent" />
    <Setter Property="BorderBrush" Value="Transparent" />
  </Style>

  <Style Selector="ToggleButton.ProjectSidebarCatalogActiveButton:checked">
    <Setter Property="Background" Value="{DynamicResource Brush.Background.Selected}" />
    <Setter Property="BorderBrush" Value="{DynamicResource Brush.Border.Focus}" />
  </Style>

  <Style Selector="ToggleButton.ProjectSidebarCatalogFlatButton.ProjectSidebarCatalogActiveButton:checked">
    <Setter Property="Background" Value="Transparent" />
    <Setter Property="BorderBrush" Value="Transparent" />
  </Style>

  <Style Selector="StackPanel.ProjectSidebarCatalogContent">
    <Setter Property="Spacing" Value="{StaticResource Space.2}" />
    <Setter Property="Margin" Value="0" />
  </Style>

  <Style Selector="StackPanel.QuickRequestCatalogContent">
    <Setter Property="Spacing" Value="{StaticResource Space.1}" />
  </Style>

  <Style Selector="Border.ProjectSidebarCatalogBody">
    <Setter Property="Background" Value="Transparent" />
    <Setter Property="BorderBrush" Value="Transparent" />
    <Setter Property="BorderThickness" Value="0" />
    <Setter Property="CornerRadius" Value="{StaticResource Radius.Md}" />
    <Setter Property="Padding" Value="10,2,0,0" />
    <Setter Property="Margin" Value="10,0,0,0" />
  </Style>

  <Style Selector="Border.QuickRequestCatalogBody">
    <Setter Property="Padding" Value="8,4,0,0" />
    <Setter Property="Margin" Value="6,2,0,0" />
  </Style>

  <Style Selector="TextBlock.ProjectSidebarCatalogChevron">
    <Setter Property="FontSize" Value="10" />
    <Setter Property="Foreground" Value="{DynamicResource Brush.Text.Tertiary}" />
    <Setter Property="VerticalAlignment" Value="Center" />
  </Style>

  <Style Selector="TextBlock.ProjectSidebarCatalogTitle">
    <Setter Property="FontSize" Value="{StaticResource Font.Size.Body}" />
    <Setter Property="FontWeight" Value="SemiBold" />
    <Setter Property="Foreground" Value="{DynamicResource Brush.Text.Primary}" />
    <Setter Property="VerticalAlignment" Value="Center" />
  </Style>

  <Style Selector="ToggleButton.ProjectSidebarTreeExpanderToggle">
    <Setter Property="Width" Value="16" />
    <Setter Property="Height" Value="20" />
    <Setter Property="Padding" Value="0" />
    <Setter Property="Background" Value="Transparent" />
    <Setter Property="BorderThickness" Value="0" />
    <Setter Property="HorizontalContentAlignment" Value="Center" />
    <Setter Property="VerticalContentAlignment" Value="Center" />
  </Style>

  <Style Selector="Border.ProjectSidebarTreeExpanderSpacer">
    <Setter Property="Width" Value="16" />
    <Setter Property="Height" Value="20" />
  </Style>

  <Style Selector="ItemsControl.ProjectSidebarInlineTree">
    <Setter Property="Margin" Value="0" />
  </Style>

  <Style Selector="ItemsControl.ProjectSidebarInlineTreeChildren">
    <Setter Property="Margin" Value="16,0,0,0" />
  </Style>

  <Style Selector="ToggleButton.ProjectSidebarTreeExpanderToggle TextBlock.ProjectSidebarCatalogChevron">
    <Setter Property="FontSize" Value="8" />
  </Style>

  <Style Selector="TextBlock.ProjectSidebarCatalogMeta">
    <Setter Property="FontSize" Value="{StaticResource Font.Size.Caption}" />
    <Setter Property="Foreground" Value="{DynamicResource Brush.Text.Tertiary}" />
    <Setter Property="VerticalAlignment" Value="Center" />
    <Setter Property="Margin" Value="0,0,6,0" />
  </Style>

  <Style Selector="Button.ProjectSidebarMiniActionButton">
    <Setter Property="Width" Value="20" />
    <Setter Property="Height" Value="20" />
    <Setter Property="Padding" Value="0" />
    <Setter Property="Background" Value="{DynamicResource Brush.Background.Surface}" />
    <Setter Property="BorderBrush" Value="{DynamicResource Brush.Border.Subtle}" />
    <Setter Property="BorderThickness" Value="1" />
    <Setter Property="CornerRadius" Value="{StaticResource Radius.Xl}" />
    <Setter Property="Foreground" Value="{DynamicResource Brush.Text.Secondary}" />
    <Setter Property="FontSize" Value="{StaticResource Font.Size.Caption}" />
  </Style>

  <Style Selector="Button.ProjectSidebarMiniActionButton:pointerover">
    <Setter Property="Background" Value="{DynamicResource Brush.Background.Selected}" />
    <Setter Property="Foreground" Value="{DynamicResource Brush.Text.Primary}" />
  </Style>

  <Style Selector="Border.ProjectWorkspaceTreeSection">
    <Setter Property="Background" Value="{DynamicResource Brush.Background.Subtle}" />
    <Setter Property="BorderBrush" Value="{DynamicResource Brush.Border.Default}" />
    <Setter Property="BorderThickness" Value="1" />
    <Setter Property="CornerRadius" Value="{StaticResource Radius.Lg}" />
    <Setter Property="Padding" Value="{StaticResource Pad.3}" />
  </Style>

  <Style Selector="Border.ProjectWorkspaceModuleCard">
    <Setter Property="Background" Value="{DynamicResource Brush.Background.Subtle}" />
    <Setter Property="BorderBrush" Value="{DynamicResource Brush.Border.Default}" />
    <Setter Property="BorderThickness" Value="1" />
    <Setter Property="CornerRadius" Value="{StaticResource Radius.Lg}" />
    <Setter Property="Padding" Value="{StaticResource Pad.3}" />
  </Style>

  <Style Selector="Button.ProjectTreeEntryButton">
    <Setter Property="Background" Value="{DynamicResource Brush.Background.Surface}" />
    <Setter Property="BorderBrush" Value="{DynamicResource Brush.Border.Default}" />
    <Setter Property="BorderThickness" Value="1" />
    <Setter Property="CornerRadius" Value="{StaticResource Radius.Md}" />
    <Setter Property="HorizontalContentAlignment" Value="Left" />
    <Setter Property="Padding" Value="{StaticResource Pad.3}" />
  </Style>

  <Style Selector="Button.ProjectTreeEntryButton:pointerover">
    <Setter Property="BorderBrush" Value="{DynamicResource Brush.Border.Focus}" />
    <Setter Property="Background" Value="{DynamicResource Brush.Background.Selected}" />
  </Style>

  <Style Selector="Border.ProjectWorkspaceCanvas">
    <Setter Property="Padding" Value="{StaticResource Pad.5}" />
    <Setter Property="CornerRadius" Value="{StaticResource Radius.Xl}" />
    <Setter Property="BoxShadow" Value="0 14 30 0 #0F172A0C" />
  </Style>

  <Style Selector="Border.ProjectWorkspaceLoadingOverlay">
    <Setter Property="Background" Value="{DynamicResource Brush.Background.Overlay}" />
    <Setter Property="HorizontalAlignment" Value="Stretch" />
    <Setter Property="VerticalAlignment" Value="Stretch" />
  </Style>

  <Style Selector="Border.ProjectWorkspaceLoadingCard">
    <Setter Property="Width" Value="360" />
    <Setter Property="Background" Value="{DynamicResource Brush.Background.Surface}" />
    <Setter Property="BorderBrush" Value="{DynamicResource Brush.Border.Default}" />
    <Setter Property="BorderThickness" Value="1" />
    <Setter Property="CornerRadius" Value="{StaticResource Radius.Xl}" />
    <Setter Property="Padding" Value="{StaticResource Pad.5}" />
    <Setter Property="BoxShadow" Value="0 24 48 0 #0F172A24" />
    <Setter Property="HorizontalAlignment" Value="Center" />
    <Setter Property="VerticalAlignment" Value="Center" />
  </Style>

  <Style Selector="ProgressBar.ProjectWorkspaceLoadingProgress">
    <Setter Property="Height" Value="4" />
  </Style>

  <Style Selector="Border.ProjectWorkspaceTopActionBar">
    <Setter Property="Background" Value="{DynamicResource Brush.Background.Surface}" />
    <Setter Property="BorderBrush" Value="{DynamicResource Brush.Border.Default}" />
    <Setter Property="BorderThickness" Value="0,0,1,0" />
    <Setter Property="CornerRadius" Value="0" />
    <Setter Property="Padding" Value="4,2,4,4" />
  </Style>

  <Style Selector="Border.ProjectWorkspaceTabViewport">
    <Setter Property="ClipToBounds" Value="True" />
    <Setter Property="HorizontalAlignment" Value="Stretch" />
    <Setter Property="MinWidth" Value="0" />
  </Style>

  <Style Selector="Border.ProjectWorkspaceMetaCard">
    <Setter Property="Background" Value="{DynamicResource Brush.Background.Subtle}" />
    <Setter Property="BorderBrush" Value="{DynamicResource Brush.Border.Default}" />
    <Setter Property="BorderThickness" Value="1" />
    <Setter Property="CornerRadius" Value="{StaticResource Radius.Lg}" />
    <Setter Property="Padding" Value="{StaticResource Pad.3}" />
  </Style>

  <Style Selector="TabStrip.ProjectWorkspaceEditorTabs">
    <Setter Property="Background" Value="Transparent" />
    <Setter Property="BorderThickness" Value="0" />
    <Setter Property="Padding" Value="0" />
    <Setter Property="HorizontalAlignment" Value="Left" />
  </Style>

  <Style Selector="TabStrip.ProjectWorkspaceEditorTabs TabStripItem">
    <Setter Property="Background" Value="Transparent" />
    <Setter Property="BorderThickness" Value="0" />
    <Setter Property="Padding" Value="0" />
    <Setter Property="Margin" Value="0,0,6,0" />
    <Setter Property="Foreground" Value="{DynamicResource Brush.Text.Secondary}" />
    <Setter Property="HorizontalContentAlignment" Value="Left" />
  </Style>

  <Style Selector="TabStrip.ProjectWorkspaceEditorTabs TabStripItem:selected">
    <Setter Property="Foreground" Value="{DynamicResource Brush.Text.Primary}" />
  </Style>

  <Style Selector="Border.ProjectWorkspaceInnerTabCapsule">
    <Setter Property="Background" Value="Transparent" />
    <Setter Property="BorderBrush" Value="Transparent" />
    <Setter Property="BorderThickness" Value="1" />
    <Setter Property="CornerRadius" Value="{StaticResource Radius.Lg}" />
    <Setter Property="Padding" Value="10,4,6,4" />
  </Style>

  <Style Selector="TabStrip.ProjectWorkspaceEditorTabs TabStripItem:pointerover Border.ProjectWorkspaceInnerTabCapsule">
    <Setter Property="Background" Value="{DynamicResource Brush.Background.Subtle}" />
    <Setter Property="BorderBrush" Value="{DynamicResource Brush.Border.Subtle}" />
  </Style>

  <Style Selector="TabStrip.ProjectWorkspaceEditorTabs TabStripItem:selected Border.ProjectWorkspaceInnerTabCapsule">
    <Setter Property="Background" Value="{DynamicResource Brush.Background.Selected}" />
    <Setter Property="BorderBrush" Value="{DynamicResource Brush.Border.Focus}" />
  </Style>

  <Style Selector="Border.ProjectWorkspaceInnerTabBadge">
    <Setter Property="Background" Value="{DynamicResource Brush.Background.Selected}" />
    <Setter Property="CornerRadius" Value="{StaticResource Radius.Lg}" />
    <Setter Property="Padding" Value="6,2" />
  </Style>

  <Style Selector="Button.ProjectWorkspaceInnerTabCloseButton">
    <Setter Property="Width" Value="18" />
    <Setter Property="Height" Value="18" />
    <Setter Property="Padding" Value="0" />
    <Setter Property="Background" Value="Transparent" />
    <Setter Property="BorderThickness" Value="0" />
    <Setter Property="CornerRadius" Value="{StaticResource Radius.Xl}" />
    <Setter Property="Foreground" Value="{DynamicResource Brush.Text.Secondary}" />
    <Setter Property="FontSize" Value="{StaticResource Font.Size.Caption}" />
    <Setter Property="HorizontalContentAlignment" Value="Center" />
    <Setter Property="VerticalContentAlignment" Value="Center" />
    <Setter Property="VerticalAlignment" Value="Center" />
  </Style>

  <Style Selector="Button.ProjectWorkspaceInnerTabCloseButton:pointerover">
    <Setter Property="Background" Value="{DynamicResource Brush.Background.Surface}" />
    <Setter Property="Foreground" Value="{DynamicResource Brush.Text.Primary}" />
  </Style>

  <Style Selector="TextBlock.ProjectWorkspacePinnedGlyph">
    <Setter Property="FontFamily" Value="Segoe Fluent Icons, Segoe MDL2 Assets" />
    <Setter Property="FontSize" Value="{StaticResource Font.Size.Caption}" />
    <Setter Property="Foreground" Value="{DynamicResource Brush.Text.Secondary}" />
    <Setter Property="VerticalAlignment" Value="Center" />
    <Setter Property="Margin" Value="0,0,2,0" />
  </Style>

  <Style Selector="Button.ProjectWorkspaceInnerTabAddButton">
    <Setter Property="Width" Value="26" />
    <Setter Property="Height" Value="26" />
    <Setter Property="Padding" Value="0" />
    <Setter Property="Background" Value="Transparent" />
    <Setter Property="BorderThickness" Value="0" />
    <Setter Property="CornerRadius" Value="{StaticResource Radius.Sm}" />
    <Setter Property="FontSize" Value="{StaticResource Font.Size.BodyLarge}" />
    <Setter Property="HorizontalContentAlignment" Value="Center" />
    <Setter Property="VerticalContentAlignment" Value="Center" />
  </Style>

  <Style Selector="Button.ProjectWorkspaceInnerTabAddButton:pointerover">
    <Setter Property="Background" Value="{DynamicResource Brush.Background.Selected}" />
  </Style>

  <Style Selector="Button.ProjectWorkspaceInnerTabMoreButton">
    <Setter Property="Width" Value="30" />
    <Setter Property="Height" Value="26" />
    <Setter Property="Padding" Value="0" />
    <Setter Property="Background" Value="Transparent" />
    <Setter Property="BorderThickness" Value="0" />
    <Setter Property="CornerRadius" Value="{StaticResource Radius.Sm}" />
    <Setter Property="FontSize" Value="{StaticResource Font.Size.BodyLarge}" />
    <Setter Property="Foreground" Value="{DynamicResource Brush.Text.Secondary}" />
  </Style>

  <Style Selector="Button.ProjectWorkspaceInnerTabMoreButton:pointerover">
    <Setter Property="Background" Value="{DynamicResource Brush.Background.Selected}" />
    <Setter Property="Foreground" Value="{DynamicResource Brush.Text.Primary}" />
  </Style>

  <Style Selector="ContextMenu.WorkspaceTabContextMenu">
    <Setter Property="MinWidth" Value="230" />
  </Style>

  <Style Selector="MenuItem.WorkspaceTabContextMenuItem">
    <Setter Property="Padding" Value="10,8" />
  </Style>

  <Style Selector="TextBlock.WorkspaceTabContextMenuIcon">
    <Setter Property="FontFamily" Value="Segoe Fluent Icons, Segoe MDL2 Assets" />
    <Setter Property="FontSize" Value="{StaticResource Font.Size.Body}" />
    <Setter Property="Foreground" Value="{DynamicResource Brush.Text.Secondary}" />
    <Setter Property="VerticalAlignment" Value="Center" />
  </Style>

  <Style Selector="ComboBox.ProjectWorkspaceToolbarComboBox">
    <Setter Property="MinWidth" Value="156" />
    <Setter Property="CornerRadius" Value="{StaticResource Radius.Lg}" />
    <Setter Property="Height" Value="34" />
    <Setter Property="VerticalContentAlignment" Value="Center" />
  </Style>

  <Style Selector="Button.ProjectWorkspaceToolbarIconButton">
    <Setter Property="Width" Value="40" />
    <Setter Property="Height" Value="34" />
    <Setter Property="Padding" Value="0" />
    <Setter Property="CornerRadius" Value="{StaticResource Radius.Lg}" />
    <Setter Property="FontSize" Value="{StaticResource Font.Size.BodyLarge}" />
    <Setter Property="FontWeight" Value="SemiBold" />
    <Setter Property="VerticalContentAlignment" Value="Center" />
  </Style>

  <Style Selector="ComboBox.ProjectSidebarEnvCombo">
    <Setter Property="MinWidth" Value="110" />
    <Setter Property="MinHeight" Value="34" />
    <Setter Property="Background" Value="Transparent" />
    <Setter Property="BorderBrush" Value="Transparent" />
    <Setter Property="BorderThickness" Value="0" />
    <Setter Property="Padding" Value="0" />
    <Setter Property="Foreground" Value="{DynamicResource Brush.Text.Secondary}" />
  </Style>

  <Style Selector="TextBox.ProjectSidebarSearchBox">
    <Setter Property="Background" Value="{DynamicResource Brush.Background.Surface}" />
    <Setter Property="BorderBrush" Value="{DynamicResource Brush.Border.Default}" />
    <Setter Property="BorderThickness" Value="1" />
    <Setter Property="Padding" Value="12,8" />
    <Setter Property="CornerRadius" Value="{StaticResource Radius.Lg}" />
    <Setter Property="MinHeight" Value="36" />
  </Style>

  <Style Selector="Button.ProjectSidebarToolButton">
    <Setter Property="Width" Value="36" />
    <Setter Property="Height" Value="36" />
    <Setter Property="Padding" Value="0" />
    <Setter Property="Background" Value="{DynamicResource Brush.Background.Surface}" />
    <Setter Property="BorderBrush" Value="{DynamicResource Brush.Border.Default}" />
    <Setter Property="BorderThickness" Value="1" />
    <Setter Property="CornerRadius" Value="{StaticResource Radius.Lg}" />
    <Setter Property="Foreground" Value="{DynamicResource Brush.Text.Secondary}" />
  </Style>

  <Style Selector="Button.ProjectSidebarToolButton:pointerover">
    <Setter Property="Background" Value="{DynamicResource Brush.Background.Selected}" />
    <Setter Property="BorderBrush" Value="{DynamicResource Brush.Border.Focus}" />
    <Setter Property="Foreground" Value="{DynamicResource Brush.Text.Primary}" />
  </Style>

  <Style Selector="Button.ProjectSidebarAddButton">
    <Setter Property="Width" Value="36" />
    <Setter Property="Height" Value="36" />
    <Setter Property="Padding" Value="0" />
    <Setter Property="Background" Value="#8B6AE6" />
    <Setter Property="BorderThickness" Value="0" />
    <Setter Property="CornerRadius" Value="{StaticResource Radius.Lg}" />
    <Setter Property="Foreground" Value="{DynamicResource Brush.Text.Inverse}" />
  </Style>

  <Style Selector="Button.ProjectSidebarAddButton:pointerover">
    <Setter Property="Opacity" Value="0.92" />
  </Style>

  <Style Selector="Button.ProjectSidebarGhostButton">
    <Setter Property="Background" Value="Transparent" />
    <Setter Property="BorderBrush" Value="{DynamicResource Brush.Border.Subtle}" />
    <Setter Property="BorderThickness" Value="1" />
    <Setter Property="CornerRadius" Value="{StaticResource Radius.Lg}" />
    <Setter Property="Padding" Value="0,8" />
    <Setter Property="Foreground" Value="{DynamicResource Brush.Text.Tertiary}" />
    <Setter Property="MinHeight" Value="34" />
  </Style>

  <Style Selector="Button.ProjectSidebarInlineCreateButton">
    <Setter Property="HorizontalAlignment" Value="Left" />
    <Setter Property="MinWidth" Value="44" />
    <Setter Property="Padding" Value="8,6" />
    <Setter Property="CornerRadius" Value="{StaticResource Radius.Xl}" />
  </Style>

  <Style Selector="Button.ProjectSidebarBottomCreateButton">
    <Setter Property="HorizontalAlignment" Value="Stretch" />
    <Setter Property="BorderBrush" Value="{DynamicResource Brush.Border.Subtle}" />
    <Setter Property="BorderThickness" Value="1" />
    <Setter Property="Padding" Value="0,9" />
    <Setter Property="CornerRadius" Value="{StaticResource Radius.Lg}" />
  </Style>

  <Style Selector="Button.QuickRequestBottomCreateButton">
    <Setter Property="Padding" Value="0,7" />
    <Setter Property="Margin" Value="0,2,0,0" />
  </Style>

  <Style Selector="Button.ProjectSidebarGhostButton:pointerover">
    <Setter Property="Background" Value="{DynamicResource Brush.Background.Subtle}" />
    <Setter Property="Foreground" Value="{DynamicResource Brush.Text.Secondary}" />
  </Style>

  <Style Selector="TextBlock.ProjectSidebarEmptyHint">
    <Setter Property="Margin" Value="0,2,0,2" />
  </Style>

  <Style Selector="TextBlock.ProjectSidebarSectionTitle">
    <Setter Property="FontSize" Value="{StaticResource Font.Size.BodySmall}" />
    <Setter Property="FontWeight" Value="Medium" />
    <Setter Property="Foreground" Value="{DynamicResource Brush.Text.Secondary}" />
  </Style>

  <Style Selector="Border.ProjectSidebarSectionCard TextBlock.ProjectSidebarSectionTitle">
    <Setter Property="Foreground" Value="{DynamicResource Brush.Text.Primary}" />
  </Style>
</Styles>
