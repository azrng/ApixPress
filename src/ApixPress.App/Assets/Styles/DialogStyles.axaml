<Styles xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:u="https://irihi.tech/ursa">  <Style Selector="Border.QuickRequestSaveDialogCard">
    <Setter Property="Background" Value="{DynamicResource Brush.Background.Surface}" />
    <Setter Property="BorderBrush" Value="{DynamicResource Brush.Border.Default}" />
    <Setter Property="BorderThickness" Value="1" />
    <Setter Property="CornerRadius" Value="{StaticResource Radius.Xl}" />
    <Setter Property="Padding" Value="{StaticResource Pad.5}" />
    <Setter Property="Width" Value="480" />
    <Setter Property="BoxShadow" Value="0 24 60 0 #0F172A20" />
  </Style>

  <Style Selector="Border.RequestCodeDialogCard">
    <Setter Property="Background" Value="{DynamicResource Brush.Background.Surface}" />
    <Setter Property="BorderBrush" Value="{DynamicResource Brush.Border.Default}" />
    <Setter Property="BorderThickness" Value="1" />
    <Setter Property="CornerRadius" Value="{StaticResource Radius.Xl}" />
    <Setter Property="Padding" Value="{StaticResource Pad.5}" />
    <Setter Property="Width" Value="720" />
    <Setter Property="MaxHeight" Value="560" />
    <Setter Property="BoxShadow" Value="0 24 60 0 #0F172A20" />
  </Style>

  <Style Selector="TextBox.RequestCodeDialogTextBox">
    <Setter Property="MinHeight" Value="260" />
    <Setter Property="Background" Value="{DynamicResource Brush.Background.Subtle}" />
    <Setter Property="BorderBrush" Value="{DynamicResource Brush.Border.Default}" />
    <Setter Property="BorderThickness" Value="1" />
    <Setter Property="CornerRadius" Value="{StaticResource Radius.Lg}" />
    <Setter Property="Padding" Value="{StaticResource Pad.3}" />
    <Setter Property="Foreground" Value="{DynamicResource Brush.Text.Primary}" />
  </Style>

  <Style Selector="Border.RequestCodeDialogPreviewCard">
    <Setter Property="Background" Value="{DynamicResource Brush.Background.Subtle}" />
    <Setter Property="BorderBrush" Value="{DynamicResource Brush.Border.Default}" />
    <Setter Property="BorderThickness" Value="1" />
    <Setter Property="CornerRadius" Value="{StaticResource Radius.Lg}" />
    <Setter Property="Padding" Value="{StaticResource Pad.3}" />
  </Style>

  <Style Selector="TextBlock.RequestCodeDialogPreviewText">
    <Setter Property="Foreground" Value="{DynamicResource Brush.Text.Primary}" />
  </Style>

  <Style Selector="Border.ProjectSettingsInfoCard">
    <Setter Property="Background" Value="{DynamicResource Brush.Background.Subtle}" />
    <Setter Property="BorderBrush" Value="{DynamicResource Brush.Border.Default}" />
    <Setter Property="BorderThickness" Value="1" />
    <Setter Property="CornerRadius" Value="{StaticResource Radius.Lg}" />
    <Setter Property="Padding" Value="{StaticResource Pad.4}" />
  </Style>

  <Style Selector="Border.ProjectSettingsSidebarCard">
    <Setter Property="Background" Value="{DynamicResource Brush.Background.Subtle}" />
    <Setter Property="BorderBrush" Value="{DynamicResource Brush.Border.Default}" />
    <Setter Property="BorderThickness" Value="1" />
    <Setter Property="CornerRadius" Value="{StaticResource Radius.Lg}" />
    <Setter Property="Padding" Value="{StaticResource Pad.3}" />
  </Style>

  <Style Selector="TextBlock.ProjectSettingsGroupTitle">
    <Setter Property="FontSize" Value="{StaticResource Font.Size.Caption}" />
    <Setter Property="FontWeight" Value="SemiBold" />
    <Setter Property="Foreground" Value="{DynamicResource Brush.Text.Secondary}" />
    <Setter Property="Margin" Value="2,0,0,0" />
  </Style>

  <Style Selector="Button.ProjectSettingsSidebarItemButton">
    <Setter Property="Background" Value="Transparent" />
    <Setter Property="BorderThickness" Value="0" />
    <Setter Property="CornerRadius" Value="{StaticResource Radius.Md}" />
    <Setter Property="Padding" Value="12,10" />
    <Setter Property="HorizontalAlignment" Value="Stretch" />
    <Setter Property="HorizontalContentAlignment" Value="Left" />
    <Setter Property="Foreground" Value="{DynamicResource Brush.Text.Primary}" />
  </Style>

  <Style Selector="Button.ProjectSettingsSidebarItemButton:pointerover">
    <Setter Property="Background" Value="{DynamicResource Brush.Background.Surface}" />
  </Style>

  <Style Selector="Button.ProjectSettingsSidebarItemButton.ProjectSettingsSidebarItemSelected">
    <Setter Property="Background" Value="{DynamicResource Brush.Background.Surface}" />
    <Setter Property="BorderBrush" Value="{DynamicResource Brush.Border.Focus}" />
    <Setter Property="BorderThickness" Value="1" />
  </Style>

  <Style Selector="Border.ProjectSettingsSidebarMetaCard">
    <Setter Property="Background" Value="{DynamicResource Brush.Background.Surface}" />
    <Setter Property="BorderBrush" Value="{DynamicResource Brush.Border.Default}" />
    <Setter Property="BorderThickness" Value="1" />
    <Setter Property="CornerRadius" Value="{StaticResource Radius.Md}" />
    <Setter Property="Padding" Value="{StaticResource Pad.3}" />
  </Style>

  <Style Selector="Border.ProjectSettingsSectionDivider">
    <Setter Property="BorderBrush" Value="{DynamicResource Brush.Border.Default}" />
    <Setter Property="BorderThickness" Value="0,0,0,1" />
    <Setter Property="Height" Value="1" />
  </Style>

  <Style Selector="Border.ProjectSettingsBasicCard">
    <Setter Property="Background" Value="{DynamicResource Brush.Background.Surface}" />
    <Setter Property="BorderBrush" Value="{DynamicResource Brush.Border.Default}" />
    <Setter Property="BorderThickness" Value="1" />
    <Setter Property="CornerRadius" Value="{StaticResource Radius.Lg}" />
  </Style>

  <Style Selector="Border.ProjectSettingsBasicRow">
    <Setter Property="BorderBrush" Value="{DynamicResource Brush.Border.Default}" />
    <Setter Property="BorderThickness" Value="0,0,0,1" />
    <Setter Property="Padding" Value="{StaticResource Pad.4}" />
  </Style>

  <Style Selector="Border.ProjectSettingsBasicRow.ProjectSettingsBasicRowLast">
    <Setter Property="BorderThickness" Value="0" />
  </Style>

  <Style Selector="TextBlock.ProjectSettingsRowLabel">
    <Setter Property="Foreground" Value="{DynamicResource Brush.Text.Primary}" />
    <Setter Property="FontWeight" Value="Medium" />
    <Setter Property="VerticalAlignment" Value="Center" />
  </Style>

  <Style Selector="Button.ProjectSettingsInlineActionButton">
    <Setter Property="Background" Value="{DynamicResource Brush.Background.Surface}" />
    <Setter Property="BorderBrush" Value="{DynamicResource Brush.Border.Default}" />
    <Setter Property="BorderThickness" Value="1" />
    <Setter Property="CornerRadius" Value="{StaticResource Radius.Lg}" />
    <Setter Property="Padding" Value="12,8" />
    <Setter Property="MinWidth" Value="60" />
  </Style>

  <Style Selector="Button.ProjectSettingsInlineActionButton:pointerover">
    <Setter Property="Background" Value="{DynamicResource Brush.Background.Selected}" />
    <Setter Property="BorderBrush" Value="{DynamicResource Brush.Border.Focus}" />
  </Style>

  <Style Selector="ToggleButton.ProjectImportModeButton">
    <Setter Property="HorizontalContentAlignment" Value="Center" />
  </Style>

  <Style Selector="Border.ProjectImportTabStrip">
    <Setter Property="Background" Value="{DynamicResource Brush.Background.Surface}" />
    <Setter Property="BorderBrush" Value="{DynamicResource Brush.Border.Default}" />
    <Setter Property="BorderThickness" Value="1" />
    <Setter Property="CornerRadius" Value="{StaticResource Radius.Lg}" />
    <Setter Property="ClipToBounds" Value="True" />
  </Style>

  <Style Selector="ToggleButton.ProjectImportModeTab">
    <Setter Property="Background" Value="Transparent" />
    <Setter Property="BorderBrush" Value="Transparent" />
    <Setter Property="BorderThickness" Value="0,0,0,2" />
    <Setter Property="CornerRadius" Value="0" />
    <Setter Property="HorizontalContentAlignment" Value="Center" />
    <Setter Property="VerticalContentAlignment" Value="Center" />
    <Setter Property="MinHeight" Value="52" />
    <Setter Property="Padding" Value="0,0,0,2" />
    <Setter Property="FontSize" Value="{StaticResource Font.Size.BodyLarge}" />
    <Setter Property="FontWeight" Value="SemiBold" />
  </Style>

  <Style Selector="ToggleButton.ProjectImportModeTab:pointerover">
    <Setter Property="Background" Value="{DynamicResource Brush.Background.Subtle}" />
  </Style>

  <Style Selector="ToggleButton.ProjectImportModeTab:checked">
    <Setter Property="Background" Value="{DynamicResource Brush.Background.App}" />
    <Setter Property="BorderBrush" Value="{DynamicResource Brush.Border.Focus}" />
    <Setter Property="Foreground" Value="{DynamicResource Brush.Text.Link}" />
  </Style>

  <Style Selector="ToggleButton.ProjectImportModeTab /template/ ContentPresenter">
    <Setter Property="HorizontalAlignment" Value="Center" />
    <Setter Property="VerticalAlignment" Value="Center" />
  </Style>

  <Style Selector="Border.ProjectImportFormatCard">
    <Setter Property="Background" Value="{DynamicResource Brush.Background.Surface}" />
    <Setter Property="BorderBrush" Value="{DynamicResource Brush.Border.Default}" />
    <Setter Property="BorderThickness" Value="1" />
    <Setter Property="CornerRadius" Value="{StaticResource Radius.Lg}" />
    <Setter Property="Padding" Value="{StaticResource Pad.3}" />
  </Style>

  <Style Selector="Button.ProjectImportCatalogButton">
    <Setter Property="Background" Value="{DynamicResource Brush.Background.Surface}" />
    <Setter Property="BorderBrush" Value="{DynamicResource Brush.Border.Default}" />
    <Setter Property="BorderThickness" Value="1" />
    <Setter Property="CornerRadius" Value="{StaticResource Radius.Lg}" />
    <Setter Property="Padding" Value="{StaticResource Pad.3}" />
    <Setter Property="HorizontalContentAlignment" Value="Stretch" />
    <Setter Property="HorizontalAlignment" Value="Left" />
    <Setter Property="MinWidth" Value="280" />
  </Style>

  <Style Selector="Button.ProjectImportCatalogButton:pointerover">
    <Setter Property="Background" Value="{DynamicResource Brush.Background.Selected}" />
    <Setter Property="BorderBrush" Value="{DynamicResource Brush.Border.Focus}" />
  </Style>

  <Style Selector="Border.ProjectImportFormatIcon">
    <Setter Property="Background" Value="{DynamicResource Brush.Status.Info.Background}" />
    <Setter Property="CornerRadius" Value="{StaticResource Radius.Lg}" />
  </Style>

  <Style Selector="Border.ProjectImportInputCard">
    <Setter Property="Background" Value="{DynamicResource Brush.Background.Surface}" />
    <Setter Property="BorderBrush" Value="{DynamicResource Brush.Border.Default}" />
    <Setter Property="BorderThickness" Value="1" />
    <Setter Property="CornerRadius" Value="{StaticResource Radius.Lg}" />
    <Setter Property="Padding" Value="{StaticResource Pad.3}" />
  </Style>

  <Style Selector="Border.ProjectImportDocumentCard">
    <Setter Property="Background" Value="{DynamicResource Brush.Background.Surface}" />
    <Setter Property="BorderBrush" Value="{DynamicResource Brush.Border.Default}" />
    <Setter Property="BorderThickness" Value="1" />
    <Setter Property="CornerRadius" Value="{StaticResource Radius.Lg}" />
    <Setter Property="Padding" Value="{StaticResource Pad.4}" />
    <Setter Property="Margin" Value="0,0,0,12" />
  </Style>

  <Style Selector="Border.ProjectImportCountBadge">
    <Setter Property="Background" Value="{DynamicResource Brush.Background.App}" />
    <Setter Property="BorderBrush" Value="{DynamicResource Brush.Border.Default}" />
    <Setter Property="BorderThickness" Value="1" />
    <Setter Property="CornerRadius" Value="{StaticResource Radius.Lg}" />
    <Setter Property="Padding" Value="12,10" />
    <Setter Property="MinWidth" Value="92" />
  </Style>

  <Style Selector="Border.ProjectImportDialogCard">
    <Setter Property="Width" Value="760" />
    <Setter Property="Background" Value="{DynamicResource Brush.Background.Surface}" />
    <Setter Property="BorderBrush" Value="{DynamicResource Brush.Border.Default}" />
    <Setter Property="BorderThickness" Value="1" />
    <Setter Property="CornerRadius" Value="{StaticResource Radius.Xl}" />
    <Setter Property="Padding" Value="{StaticResource Pad.5}" />
    <Setter Property="BoxShadow" Value="0 24 60 0 #0F172A20" />
  </Style>

  <Style Selector="Border.ProjectImportDialogHeaderCard">
    <Setter Property="Background" Value="{DynamicResource Brush.Background.Surface}" />
    <Setter Property="BorderBrush" Value="{DynamicResource Brush.Border.Default}" />
    <Setter Property="BorderThickness" Value="1" />
    <Setter Property="CornerRadius" Value="{StaticResource Radius.Lg}" />
    <Setter Property="Padding" Value="{StaticResource Pad.3}" />
  </Style>

  <Style Selector="Border.ProjectImportDialogNoticeCard">
    <Setter Property="Background" Value="{DynamicResource Brush.Background.Subtle}" />
    <Setter Property="BorderBrush" Value="{DynamicResource Brush.Border.Default}" />
    <Setter Property="BorderThickness" Value="1" />
    <Setter Property="CornerRadius" Value="{StaticResource Radius.Lg}" />
    <Setter Property="Padding" Value="{StaticResource Pad.3}" />
  </Style>

  <Style Selector="Border.ProjectImportDropZoneCard">
    <Setter Property="Background" Value="{DynamicResource Brush.Background.App}" />
    <Setter Property="BorderBrush" Value="{DynamicResource Brush.Border.Default}" />
    <Setter Property="BorderThickness" Value="1" />
    <Setter Property="CornerRadius" Value="{StaticResource Radius.Xl}" />
    <Setter Property="Padding" Value="{StaticResource Pad.5}" />
    <Setter Property="MinHeight" Value="300" />
  </Style>

  <Style Selector="Border.ProjectImportUrlCard">
    <Setter Property="Background" Value="{DynamicResource Brush.Background.App}" />
    <Setter Property="BorderBrush" Value="{DynamicResource Brush.Border.Default}" />
    <Setter Property="BorderThickness" Value="1" />
    <Setter Property="CornerRadius" Value="{StaticResource Radius.Xl}" />
    <Setter Property="Padding" Value="{StaticResource Pad.4}" />
  </Style>

  <Style Selector="Border.ProjectImportBusyOverlay">
    <Setter Property="Background" Value="{DynamicResource Brush.Background.Overlay}" />
    <Setter Property="CornerRadius" Value="{StaticResource Radius.Xl}" />
  </Style>

  <Style Selector="Border.ProjectImportBusyCard">
    <Setter Property="Width" Value="320" />
    <Setter Property="Background" Value="{DynamicResource Brush.Background.Surface}" />
    <Setter Property="BorderBrush" Value="{DynamicResource Brush.Border.Default}" />
    <Setter Property="BorderThickness" Value="1" />
    <Setter Property="CornerRadius" Value="{StaticResource Radius.Xl}" />
    <Setter Property="Padding" Value="{StaticResource Pad.4}" />
    <Setter Property="BoxShadow" Value="0 16 40 0 #140F172A" />
  </Style>

  <Style Selector="ProgressBar.ProjectImportBusyProgress">
    <Setter Property="Height" Value="6" />
    <Setter Property="MinWidth" Value="220" />
    <Setter Property="Foreground" Value="{DynamicResource Brush.Text.Link}" />
  </Style>

  <Style Selector="Border.EnvironmentManagerDialogCard">
    <Setter Property="Width" Value="1080" />
    <Setter Property="Height" Value="720" />
    <Setter Property="Background" Value="{DynamicResource Brush.Background.Surface}" />
    <Setter Property="BorderBrush" Value="{DynamicResource Brush.Border.Default}" />
    <Setter Property="BorderThickness" Value="1" />
    <Setter Property="CornerRadius" Value="{StaticResource Radius.Xl}" />
    <Setter Property="BoxShadow" Value="0 28 60 0 #0F172A22" />
  </Style>

  <Style Selector="Border.EnvironmentManagerSidebar">
    <Setter Property="Background" Value="{DynamicResource Brush.Background.Subtle}" />
    <Setter Property="BorderBrush" Value="{DynamicResource Brush.Border.Default}" />
    <Setter Property="BorderThickness" Value="0,0,1,0" />
    <Setter Property="Padding" Value="{StaticResource Pad.5}" />
    <Setter Property="CornerRadius" Value="16,0,0,16" />
  </Style>

  <Style Selector="Border.EnvironmentDetailCard">
    <Setter Property="Background" Value="{DynamicResource Brush.Background.Surface}" />
    <Setter Property="BorderBrush" Value="{DynamicResource Brush.Border.Default}" />
    <Setter Property="BorderThickness" Value="1" />
    <Setter Property="CornerRadius" Value="{StaticResource Radius.Lg}" />
    <Setter Property="Padding" Value="{StaticResource Pad.4}" />
  </Style>

  <Style Selector="Border.EnvironmentDetailHeroCard">
    <Setter Property="Background" Value="{DynamicResource Brush.Background.Subtle}" />
    <Setter Property="Padding" Value="{StaticResource Pad.3}" />
  </Style>

  <Style Selector="TextBox.EnvironmentHeroNameInput">
    <Setter Property="MinWidth" Value="260" />
    <Setter Property="MinHeight" Value="38" />
    <Setter Property="FontSize" Value="{StaticResource Font.Size.BodyLarge}" />
    <Setter Property="FontWeight" Value="SemiBold" />
  </Style>

  <Style Selector="Border.EnvironmentListItem">
    <Setter Property="Background" Value="{DynamicResource Brush.Background.App}" />
    <Setter Property="BorderBrush" Value="Transparent" />
    <Setter Property="BorderThickness" Value="1" />
    <Setter Property="CornerRadius" Value="{StaticResource Radius.Lg}" />
    <Setter Property="Padding" Value="{StaticResource Pad.3}" />
    <Setter Property="MinHeight" Value="64" />
  </Style>

  <Style Selector="TextBlock.EnvironmentListItemTitle">
    <Setter Property="Foreground" Value="{DynamicResource Brush.Text.Primary}" />
  </Style>

  <Style Selector="TextBlock.EnvironmentListItemSubtitle">
    <Setter Property="FontSize" Value="{StaticResource Font.Size.Caption}" />
    <Setter Property="Foreground" Value="{DynamicResource Brush.Text.Secondary}" />
  </Style>

  <Style Selector="Border.EnvironmentVariableHeader">
    <Setter Property="Background" Value="{DynamicResource Brush.Background.Subtle}" />
    <Setter Property="CornerRadius" Value="{StaticResource Radius.Md}" />
    <Setter Property="Padding" Value="{StaticResource Pad.3}" />
  </Style>

  <Style Selector="Border.EnvironmentVariableRow">
    <Setter Property="Background" Value="{DynamicResource Brush.Background.Subtle}" />
    <Setter Property="CornerRadius" Value="{StaticResource Radius.Md}" />
    <Setter Property="Padding" Value="{StaticResource Pad.3}" />
    <Setter Property="Margin" Value="0,0,0,8" />
  </Style>

  <Style Selector="ListBox.EnvironmentListBox ListBoxItem">
    <Setter Property="Padding" Value="0" />
    <Setter Property="Margin" Value="0,0,0,8" />
    <Setter Property="CornerRadius" Value="{StaticResource Radius.Lg}" />
  </Style>

  <Style Selector="ListBox.EnvironmentListBox ListBoxItem:pointerover Border.EnvironmentListItem">
    <Setter Property="Background" Value="{DynamicResource Brush.Background.Surface}" />
    <Setter Property="BorderBrush" Value="{DynamicResource Brush.Border.Default}" />
  </Style>

  <Style Selector="ListBox.EnvironmentListBox ListBoxItem:selected">
    <Setter Property="Background" Value="Transparent" />
    <Setter Property="Foreground" Value="{DynamicResource Brush.Text.Primary}" />
  </Style>

  <Style Selector="ListBox.EnvironmentListBox ListBoxItem:selected Border.EnvironmentListItem">
    <Setter Property="Background" Value="{DynamicResource Brush.Background.Surface}" />
    <Setter Property="BorderBrush" Value="{DynamicResource Brush.Border.Focus}" />
    <Setter Property="BorderThickness" Value="1" />
  </Style>

  <Style Selector="ListBox.EnvironmentListBox ListBoxItem:selected TextBlock.EnvironmentListItemTitle">
    <Setter Property="Foreground" Value="{DynamicResource Brush.Text.Primary}" />
  </Style>

  <Style Selector="ListBox.EnvironmentListBox ListBoxItem:selected TextBlock.EnvironmentListItemSubtitle">
    <Setter Property="Foreground" Value="{DynamicResource Brush.Text.Secondary}" />
  </Style>

  <Style Selector="Border.EnvironmentSectionHeader">
    <Setter Property="Background" Value="{DynamicResource Brush.Background.Subtle}" />
    <Setter Property="CornerRadius" Value="{StaticResource Radius.Md}" />
    <Setter Property="Padding" Value="{StaticResource Pad.3}" />
  </Style>

  <Style Selector="Border.EnvironmentSectionRow">
    <Setter Property="Background" Value="{DynamicResource Brush.Background.App}" />
    <Setter Property="BorderBrush" Value="{DynamicResource Brush.Border.Default}" />
    <Setter Property="BorderThickness" Value="1" />
    <Setter Property="CornerRadius" Value="{StaticResource Radius.Md}" />
    <Setter Property="Padding" Value="{StaticResource Pad.3}" />
  </Style>

  <Style Selector="TextBlock.EnvironmentTableHeaderText">
    <Setter Property="FontWeight" Value="SemiBold" />
  </Style>

  <Style Selector="TextBlock.EnvironmentTableCellLabel">
    <Setter Property="Foreground" Value="{DynamicResource Brush.Text.Primary}" />
    <Setter Property="FontWeight" Value="Medium" />
    <Setter Property="VerticalAlignment" Value="Center" />
  </Style>

  <Style Selector="TextBox.EnvironmentTableInput">
    <Setter Property="MinHeight" Value="36" />
  </Style>
</Styles>
