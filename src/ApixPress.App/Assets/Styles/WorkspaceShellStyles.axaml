<Styles xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
  <Style Selector="Border.TopTabStripShell">
    <Setter Property="Background" Value="{DynamicResource Brush.Background.Subtle}" />
    <Setter Property="BorderBrush" Value="{DynamicResource Brush.Border.Default}" />
    <Setter Property="BorderThickness" Value="1" />
    <Setter Property="CornerRadius" Value="{StaticResource Radius.Xl}" />
    <Setter Property="Padding" Value="3" />
  </Style>

  <Style Selector="Border.WorkspaceTabItemShell">
    <Setter Property="Background" Value="Transparent" />
    <Setter Property="CornerRadius" Value="{StaticResource Radius.Lg}" />
  </Style>

  <Style Selector="Border.WorkspaceTabCapsule">
    <Setter Property="Background" Value="Transparent" />
    <Setter Property="BorderBrush" Value="Transparent" />
    <Setter Property="BorderThickness" Value="1" />
    <Setter Property="CornerRadius" Value="{StaticResource Radius.Lg}" />
    <Setter Property="Padding" Value="4,3,6,3" />
  </Style>

  <Style Selector="Border.WorkspaceTabCapsule:pointerover">
    <Setter Property="Background" Value="{DynamicResource Brush.Background.Surface}" />
    <Setter Property="BorderBrush" Value="{DynamicResource Brush.Border.Subtle}" />
  </Style>

  <Style Selector="Border.WorkspaceTabCapsule[Tag=True]">
    <Setter Property="Background" Value="{DynamicResource Brush.Background.Surface}" />
    <Setter Property="BorderBrush" Value="{DynamicResource Brush.Border.Focus}" />
  </Style>

  <Style Selector="ToggleButton.WorkspaceTabButton">
    <Setter Property="Background" Value="Transparent" />
    <Setter Property="BorderBrush" Value="Transparent" />
    <Setter Property="BorderThickness" Value="0" />
    <Setter Property="CornerRadius" Value="{StaticResource Radius.Lg}" />
    <Setter Property="Padding" Value="10,6" />
    <Setter Property="Foreground" Value="{DynamicResource Brush.Text.Secondary}" />
    <Setter Property="HorizontalContentAlignment" Value="Left" />
  </Style>

  <Style Selector="ToggleButton.WorkspaceTabButton /template/ ContentPresenter#PART_ContentPresenter">
    <Setter Property="Background" Value="Transparent" />
    <Setter Property="BorderBrush" Value="Transparent" />
    <Setter Property="BorderThickness" Value="0" />
  </Style>

  <Style Selector="ToggleButton.WorkspaceTabButton:pointerover">
    <Setter Property="Background" Value="Transparent" />
    <Setter Property="BorderBrush" Value="Transparent" />
    <Setter Property="Foreground" Value="{DynamicResource Brush.Text.Primary}" />
  </Style>

  <Style Selector="ToggleButton.WorkspaceTabButton:pointerover /template/ ContentPresenter#PART_ContentPresenter">
    <Setter Property="Background" Value="Transparent" />
    <Setter Property="BorderBrush" Value="Transparent" />
    <Setter Property="BorderThickness" Value="0" />
  </Style>

  <Style Selector="ToggleButton.WorkspaceTabButton:checked">
    <Setter Property="Background" Value="Transparent" />
    <Setter Property="BorderBrush" Value="Transparent" />
    <Setter Property="Foreground" Value="{DynamicResource Brush.Text.Primary}" />
  </Style>

  <Style Selector="ToggleButton.WorkspaceTabButton:checked /template/ ContentPresenter#PART_ContentPresenter">
    <Setter Property="Background" Value="Transparent" />
    <Setter Property="BorderBrush" Value="Transparent" />
    <Setter Property="BorderThickness" Value="0" />
  </Style>

  <Style Selector="ToggleButton.WorkspaceTabButton:checked:pointerover">
    <Setter Property="Background" Value="Transparent" />
    <Setter Property="BorderBrush" Value="Transparent" />
    <Setter Property="Foreground" Value="{DynamicResource Brush.Text.Primary}" />
  </Style>

  <Style Selector="ToggleButton.WorkspaceTabButton:checked:pointerover /template/ ContentPresenter#PART_ContentPresenter">
    <Setter Property="Background" Value="Transparent" />
    <Setter Property="BorderBrush" Value="Transparent" />
    <Setter Property="BorderThickness" Value="0" />
  </Style>

  <Style Selector="ToggleButton.WorkspaceTabButton:pressed">
    <Setter Property="Background" Value="Transparent" />
    <Setter Property="BorderBrush" Value="Transparent" />
    <Setter Property="Foreground" Value="{DynamicResource Brush.Text.Primary}" />
  </Style>

  <Style Selector="ToggleButton.WorkspaceTabButton:pressed /template/ ContentPresenter#PART_ContentPresenter">
    <Setter Property="Background" Value="Transparent" />
    <Setter Property="BorderBrush" Value="Transparent" />
    <Setter Property="BorderThickness" Value="0" />
  </Style>

  <Style Selector="Button.WorkspaceTabButton">
    <Setter Property="Background" Value="Transparent" />
    <Setter Property="BorderBrush" Value="Transparent" />
    <Setter Property="BorderThickness" Value="0" />
    <Setter Property="CornerRadius" Value="{StaticResource Radius.Lg}" />
    <Setter Property="Padding" Value="10,6" />
    <Setter Property="Foreground" Value="{DynamicResource Brush.Text.Secondary}" />
    <Setter Property="HorizontalContentAlignment" Value="Left" />
  </Style>

  <Style Selector="Button.WorkspaceTabButton /template/ ContentPresenter#PART_ContentPresenter">
    <Setter Property="Background" Value="Transparent" />
    <Setter Property="BorderBrush" Value="Transparent" />
    <Setter Property="BorderThickness" Value="0" />
  </Style>

  <Style Selector="Button.WorkspaceTabButton:pointerover">
    <Setter Property="Background" Value="Transparent" />
    <Setter Property="BorderBrush" Value="Transparent" />
    <Setter Property="Foreground" Value="{DynamicResource Brush.Text.Primary}" />
  </Style>

  <Style Selector="Button.WorkspaceTabButton:pointerover /template/ ContentPresenter#PART_ContentPresenter">
    <Setter Property="Background" Value="Transparent" />
    <Setter Property="BorderBrush" Value="Transparent" />
    <Setter Property="BorderThickness" Value="0" />
  </Style>

  <Style Selector="Button.WorkspaceTabButton:pressed">
    <Setter Property="Background" Value="Transparent" />
    <Setter Property="BorderBrush" Value="Transparent" />
    <Setter Property="Foreground" Value="{DynamicResource Brush.Text.Primary}" />
  </Style>

  <Style Selector="Button.WorkspaceTabButton:pressed /template/ ContentPresenter#PART_ContentPresenter">
    <Setter Property="Background" Value="Transparent" />
    <Setter Property="BorderBrush" Value="Transparent" />
    <Setter Property="BorderThickness" Value="0" />
  </Style>

  <Style Selector="Border.WorkspaceTabBadge">
    <Setter Property="Background" Value="{DynamicResource Brush.Background.Selected}" />
    <Setter Property="CornerRadius" Value="{StaticResource Radius.Lg}" />
    <Setter Property="Padding" Value="6,2" />
  </Style>

  <Style Selector="Button.WorkspaceTabCloseButton">
    <Setter Property="Width" Value="18" />
    <Setter Property="Height" Value="18" />
    <Setter Property="Padding" Value="0" />
    <Setter Property="Background" Value="Transparent" />
    <Setter Property="BorderThickness" Value="0" />
    <Setter Property="CornerRadius" Value="{StaticResource Radius.Xl}" />
    <Setter Property="Foreground" Value="{DynamicResource Brush.Text.Secondary}" />
    <Setter Property="FontSize" Value="{StaticResource Font.Size.Caption}" />
    <Setter Property="HorizontalContentAlignment" Value="Center" />
    <Setter Property="VerticalContentAlignment" Value="Center" />
    <Setter Property="VerticalAlignment" Value="Center" />
  </Style>

  <Style Selector="Button.WorkspaceTabCloseButton:pointerover">
    <Setter Property="Background" Value="{DynamicResource Brush.Background.Subtle}" />
    <Setter Property="Foreground" Value="{DynamicResource Brush.Text.Primary}" />
  </Style>

  <Style Selector="Border.HomeHeroCard">
    <Setter Property="Background" Value="{DynamicResource Brush.Background.Surface}" />
    <Setter Property="BorderBrush" Value="{DynamicResource Brush.Border.Default}" />
    <Setter Property="BorderThickness" Value="1" />
    <Setter Property="CornerRadius" Value="{StaticResource Radius.Xl}" />
    <Setter Property="Padding" Value="{StaticResource Pad.6}" />
    <Setter Property="BoxShadow" Value="0 18 40 0 #0F172A12" />
  </Style>

  <Style Selector="Border.DashboardStatCard">
    <Setter Property="Background" Value="{DynamicResource Brush.Background.Subtle}" />
    <Setter Property="CornerRadius" Value="{StaticResource Radius.Lg}" />
    <Setter Property="Padding" Value="{StaticResource Pad.4}" />
    <Setter Property="MinWidth" Value="132" />
  </Style>

  <Style Selector="Border.HomeHeroEyebrow">
    <Setter Property="Background" Value="{DynamicResource Brush.Status.Info.Background}" />
    <Setter Property="CornerRadius" Value="{StaticResource Radius.Xl}" />
    <Setter Property="Padding" Value="10,6" />
    <Setter Property="HorizontalAlignment" Value="Left" />
  </Style>

  <Style Selector="TextBlock.HomeHeroDescription">
    <Setter Property="MaxWidth" Value="760" />
  </Style>

  <Style Selector="Border.HomeHeroNarrativeCard">
    <Setter Property="Background" Value="{DynamicResource Brush.Background.Subtle}" />
    <Setter Property="BorderBrush" Value="{DynamicResource Brush.Border.Default}" />
    <Setter Property="BorderThickness" Value="1" />
    <Setter Property="CornerRadius" Value="{StaticResource Radius.Xl}" />
    <Setter Property="Padding" Value="{StaticResource Pad.4}" />
    <Setter Property="MaxWidth" Value="760" />
  </Style>

  <Style Selector="Border.HomeHeroNarrativeBadge">
    <Setter Property="Width" Value="56" />
    <Setter Property="Height" Value="56" />
    <Setter Property="Background" Value="{DynamicResource Brush.Background.Surface}" />
    <Setter Property="BorderBrush" Value="{DynamicResource Brush.Border.Default}" />
    <Setter Property="BorderThickness" Value="1" />
    <Setter Property="CornerRadius" Value="{StaticResource Radius.Xl}" />
  </Style>

  <Style Selector="Border.HomeHeroNarrativeBadge TextBlock">
    <Setter Property="HorizontalAlignment" Value="Center" />
    <Setter Property="VerticalAlignment" Value="Center" />
    <Setter Property="TextAlignment" Value="Center" />
  </Style>

  <Style Selector="Border.HomeMetricCard">
    <Setter Property="Background" Value="{DynamicResource Brush.Background.Subtle}" />
    <Setter Property="BorderBrush" Value="{DynamicResource Brush.Border.Default}" />
    <Setter Property="BorderThickness" Value="1" />
    <Setter Property="CornerRadius" Value="{StaticResource Radius.Xl}" />
    <Setter Property="Padding" Value="{StaticResource Pad.4}" />
    <Setter Property="MinHeight" Value="126" />
  </Style>

  <Style Selector="Border.HomeMetricCardAccent">
    <Setter Property="Background" Value="{DynamicResource Brush.Status.Info.Background}" />
    <Setter Property="BorderBrush" Value="{DynamicResource Brush.Border.Focus}" />
  </Style>

  <Style Selector="TextBlock.HomeMetricValue">
    <Setter Property="FontSize" Value="{StaticResource Font.Size.Title}" />
    <Setter Property="FontWeight" Value="SemiBold" />
    <Setter Property="Foreground" Value="{DynamicResource Brush.Text.Primary}" />
  </Style>

  <Style Selector="TextBlock.HomeMetricHint">
    <Setter Property="FontSize" Value="{StaticResource Font.Size.Caption}" />
    <Setter Property="Foreground" Value="{DynamicResource Brush.Text.Secondary}" />
  </Style>

  <Style Selector="Border.HomeOverviewToolbarSection">
    <Setter Property="BorderBrush" Value="{DynamicResource Brush.Border.Subtle}" />
    <Setter Property="BorderThickness" Value="0,1,0,0" />
    <Setter Property="Padding" Value="0,20,0,0" />
  </Style>

  <Style Selector="Border.HomeHeroActionStrip">
    <Setter Property="Padding" Value="0,20,0,0" />
  </Style>

  <Style Selector="Button.HomeCreateProjectButton">
    <Setter Property="MinHeight" Value="40" />
    <Setter Property="Padding" Value="16,12" />
    <Setter Property="FontWeight" Value="SemiBold" />
  </Style>

  <Style Selector="Border.HomeEmptyStateCard">
    <Setter Property="Padding" Value="{StaticResource Pad.6}" />
  </Style>

  <Style Selector="Border.HomeEmptyStateBadge">
    <Setter Property="Background" Value="{DynamicResource Brush.Background.Subtle}" />
    <Setter Property="BorderBrush" Value="{DynamicResource Brush.Border.Default}" />
    <Setter Property="BorderThickness" Value="1" />
    <Setter Property="CornerRadius" Value="{StaticResource Radius.Xl}" />
    <Setter Property="Padding" Value="10,6" />
    <Setter Property="HorizontalAlignment" Value="Center" />
  </Style>

  <Style Selector="Border.HomeSectionCountPill">
    <Setter Property="Background" Value="{DynamicResource Brush.Status.Info.Background}" />
    <Setter Property="CornerRadius" Value="{StaticResource Radius.Xl}" />
    <Setter Property="Padding" Value="10,4" />
    <Setter Property="VerticalAlignment" Value="Center" />
  </Style>

  <Style Selector="Border.HomeSectionCountPill TextBlock">
    <Setter Property="Foreground" Value="{DynamicResource Brush.Text.Primary}" />
    <Setter Property="FontWeight" Value="SemiBold" />
  </Style>

  <Style Selector="Border.HomeSectionStatCard">
    <Setter Property="Background" Value="{DynamicResource Brush.Background.Subtle}" />
    <Setter Property="BorderBrush" Value="{DynamicResource Brush.Border.Default}" />
    <Setter Property="BorderThickness" Value="1" />
    <Setter Property="CornerRadius" Value="{StaticResource Radius.Lg}" />
    <Setter Property="Padding" Value="{StaticResource Pad.4}" />
    <Setter Property="MinWidth" Value="148" />
  </Style>

  <Style Selector="Border.ProjectWorkspaceHero">
    <Setter Property="BoxShadow" Value="0 16 36 0 #0F172A10" />
  </Style>

  <Style Selector="Border.HomeSidebarShell">
    <Setter Property="Background" Value="{DynamicResource Brush.Background.Surface}" />
    <Setter Property="BorderBrush" Value="{DynamicResource Brush.Border.Default}" />
    <Setter Property="BorderThickness" Value="1" />
    <Setter Property="CornerRadius" Value="{StaticResource Radius.Xl}" />
    <Setter Property="Padding" Value="{StaticResource Pad.4}" />
  </Style>

  <Style Selector="Border.HomeSidebarEyebrow">
    <Setter Property="Background" Value="{DynamicResource Brush.Background.App}" />
    <Setter Property="BorderBrush" Value="{DynamicResource Brush.Border.Default}" />
    <Setter Property="BorderThickness" Value="1" />
    <Setter Property="CornerRadius" Value="{StaticResource Radius.Xl}" />
    <Setter Property="Padding" Value="10,6" />
    <Setter Property="HorizontalAlignment" Value="Left" />
  </Style>

  <Style Selector="Border.HomeSidebarMetaCard">
    <Setter Property="Background" Value="{DynamicResource Brush.Background.App}" />
    <Setter Property="BorderBrush" Value="{DynamicResource Brush.Border.Default}" />
    <Setter Property="BorderThickness" Value="1" />
    <Setter Property="CornerRadius" Value="{StaticResource Radius.Lg}" />
    <Setter Property="Padding" Value="{StaticResource Pad.3}" />
  </Style>

  <Style Selector="Border.HomeSidebarMetaBadge">
    <Setter Property="Background" Value="{DynamicResource Brush.Background.Surface}" />
    <Setter Property="BorderBrush" Value="{DynamicResource Brush.Border.Default}" />
    <Setter Property="BorderThickness" Value="1" />
    <Setter Property="CornerRadius" Value="{StaticResource Radius.Xl}" />
    <Setter Property="Padding" Value="8,4" />
    <Setter Property="VerticalAlignment" Value="Top" />
  </Style>

  <Style Selector="TextBlock.HomeSidebarSectionTitle">
    <Setter Property="FontSize" Value="{StaticResource Font.Size.BodyLarge}" />
    <Setter Property="FontWeight" Value="SemiBold" />
    <Setter Property="Foreground" Value="{DynamicResource Brush.Text.Primary}" />
  </Style>

  <Style Selector="Border.HomeSidebarSectionCount">
    <Setter Property="Background" Value="{DynamicResource Brush.Background.App}" />
    <Setter Property="BorderBrush" Value="{DynamicResource Brush.Border.Default}" />
    <Setter Property="BorderThickness" Value="1" />
    <Setter Property="CornerRadius" Value="{StaticResource Radius.Xl}" />
    <Setter Property="Padding" Value="8,4" />
  </Style>

  <Style Selector="Border.HomeSidebarPlaceholderCard">
    <Setter Property="Background" Value="{DynamicResource Brush.Background.App}" />
    <Setter Property="BorderBrush" Value="{DynamicResource Brush.Border.Default}" />
    <Setter Property="BorderThickness" Value="1" />
    <Setter Property="CornerRadius" Value="{StaticResource Radius.Lg}" />
    <Setter Property="Padding" Value="{StaticResource Pad.3}" />
  </Style>

  <Style Selector="Button.HomeSidebarCreateButton">
    <Setter Property="MinHeight" Value="40" />
    <Setter Property="Padding" Value="14,10" />
  </Style>

  <Style Selector="Border.HomeContentHeaderCard">
    <Setter Property="Background" Value="{DynamicResource Brush.Background.Surface}" />
    <Setter Property="BorderBrush" Value="{DynamicResource Brush.Border.Default}" />
    <Setter Property="BorderThickness" Value="1" />
    <Setter Property="CornerRadius" Value="{StaticResource Radius.Xl}" />
    <Setter Property="Padding" Value="{StaticResource Pad.4}" />
  </Style>

  <Style Selector="Border.HomeContentOwnerBadge">
    <Setter Property="Background" Value="{DynamicResource Brush.Status.Warning.Background}" />
    <Setter Property="CornerRadius" Value="{StaticResource Radius.Xl}" />
    <Setter Property="Padding" Value="10,6" />
    <Setter Property="VerticalAlignment" Value="Center" />
  </Style>

  <Style Selector="TextBlock.HomeContentTabText">
    <Setter Property="Foreground" Value="{DynamicResource Brush.Text.Secondary}" />
    <Setter Property="FontWeight" Value="Medium" />
  </Style>

  <Style Selector="TextBlock.HomeContentTabTextActive">
    <Setter Property="Foreground" Value="{DynamicResource Brush.Border.Focus}" />
  </Style>

  <Style Selector="Border.HomeTopMetricPill">
    <Setter Property="Background" Value="{DynamicResource Brush.Background.App}" />
    <Setter Property="BorderBrush" Value="{DynamicResource Brush.Border.Default}" />
    <Setter Property="BorderThickness" Value="1" />
    <Setter Property="CornerRadius" Value="{StaticResource Radius.Lg}" />
    <Setter Property="Padding" Value="{StaticResource Pad.3}" />
    <Setter Property="MinWidth" Value="116" />
  </Style>

  <Style Selector="Border.HomeContentToolbarCard">
    <Setter Property="Background" Value="{DynamicResource Brush.Background.Surface}" />
    <Setter Property="BorderBrush" Value="{DynamicResource Brush.Border.Default}" />
    <Setter Property="BorderThickness" Value="1" />
    <Setter Property="CornerRadius" Value="{StaticResource Radius.Lg}" />
    <Setter Property="Padding" Value="{StaticResource Pad.3}" />
  </Style>

  <Style Selector="Border.HomeToolbarChip">
    <Setter Property="Background" Value="{DynamicResource Brush.Background.App}" />
    <Setter Property="BorderBrush" Value="{DynamicResource Brush.Border.Default}" />
    <Setter Property="BorderThickness" Value="1" />
    <Setter Property="CornerRadius" Value="{StaticResource Radius.Xl}" />
    <Setter Property="Padding" Value="10,6" />
    <Setter Property="VerticalAlignment" Value="Center" />
  </Style>

  <Style Selector="Border.HomeContentBodyCard">
    <Setter Property="Background" Value="{DynamicResource Brush.Background.Surface}" />
    <Setter Property="BorderBrush" Value="{DynamicResource Brush.Border.Default}" />
    <Setter Property="BorderThickness" Value="1" />
    <Setter Property="CornerRadius" Value="{StaticResource Radius.Xl}" />
    <Setter Property="Padding" Value="{StaticResource Pad.4}" />
    <Setter Property="MinHeight" Value="560" />
  </Style>

  <Style Selector="Border.HomeBodyEmptyCard">
    <Setter Property="Background" Value="Transparent" />
    <Setter Property="Padding" Value="{StaticResource Pad.7}" />
    <Setter Property="VerticalAlignment" Value="Top" />
  </Style>

  <Style Selector="Border.HomeBodyEmptyBadge">
    <Setter Property="Background" Value="{DynamicResource Brush.Background.App}" />
    <Setter Property="BorderBrush" Value="{DynamicResource Brush.Border.Default}" />
    <Setter Property="BorderThickness" Value="1" />
    <Setter Property="CornerRadius" Value="{StaticResource Radius.Xl}" />
    <Setter Property="Padding" Value="10,6" />
    <Setter Property="HorizontalAlignment" Value="Center" />
  </Style>

  <Style Selector="Border.HomeBodyEmptyBadgeMuted">
    <Setter Property="Background" Value="{DynamicResource Brush.Background.Surface}" />
  </Style>

  <Style Selector="Border.HomeBodyEmptySurface">
    <Setter Property="Background" Value="{DynamicResource Brush.Background.Subtle}" />
    <Setter Property="BorderBrush" Value="{DynamicResource Brush.Border.Default}" />
    <Setter Property="BorderThickness" Value="1" />
    <Setter Property="CornerRadius" Value="{StaticResource Radius.Xl}" />
    <Setter Property="Padding" Value="{StaticResource Pad.6}" />
    <Setter Property="MaxWidth" Value="760" />
    <Setter Property="HorizontalAlignment" Value="Center" />
    <Setter Property="BoxShadow" Value="0 14 32 0 #0F172A0D" />
  </Style>

  <Style Selector="TextBlock.HomeBodyEmptyDescription">
    <Setter Property="MaxWidth" Value="500" />
    <Setter Property="LineHeight" Value="20" />
  </Style>
</Styles>
