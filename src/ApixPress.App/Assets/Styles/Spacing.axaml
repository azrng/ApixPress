<ResourceDictionary xmlns="https://github.com/avaloniaui"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
  <x:Double x:Key="Space.1">4</x:Double>
  <x:Double x:Key="Space.2">8</x:Double>
  <x:Double x:Key="Space.3">12</x:Double>
  <x:Double x:Key="Space.4">16</x:Double>
  <x:Double x:Key="Space.5">20</x:Double>
  <x:Double x:Key="Space.6">24</x:Double>
  <x:Double x:Key="Space.7">32</x:Double>
  <Thickness x:Key="Pad.1">4</Thickness>
  <Thickness x:Key="Pad.2">8</Thickness>
  <Thickness x:Key="Pad.3">12</Thickness>
  <Thickness x:Key="Pad.4">16</Thickness>
  <Thickness x:Key="Pad.5">20</Thickness>
  <Thickness x:Key="Pad.6">24</Thickness>
  <Thickness x:Key="Pad.7">32</Thickness>
  <CornerRadius x:Key="Radius.Sm">4</CornerRadius>
  <CornerRadius x:Key="Radius.Md">8</CornerRadius>
  <CornerRadius x:Key="Radius.Lg">12</CornerRadius>
  <CornerRadius x:Key="Radius.Xl">16</CornerRadius>
</ResourceDictionary>
