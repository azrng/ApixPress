<Styles xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
  <Style Selector="Border.HttpDocumentHeroCard">
    <Setter Property="Padding" Value="{StaticResource Pad.5}" />
  </Style>

  <Style Selector="Border.HttpDocumentMethodBadge">
    <Setter Property="Background" Value="{DynamicResource Brush.Background.Selected}" />
    <Setter Property="CornerRadius" Value="{StaticResource Radius.Lg}" />
    <Setter Property="Padding" Value="10,6" />
  </Style>

  <Style Selector="Border.HttpDocumentStatusBadge">
    <Setter Property="Background" Value="{DynamicResource Brush.Background.Subtle}" />
    <Setter Property="BorderBrush" Value="{DynamicResource Brush.Border.Default}" />
    <Setter Property="BorderThickness" Value="1" />
    <Setter Property="CornerRadius" Value="{StaticResource Radius.Lg}" />
    <Setter Property="Padding" Value="10,6" />
  </Style>

  <Style Selector="Border.HttpDocumentUrlCard">
    <Setter Property="Background" Value="{DynamicResource Brush.Background.Subtle}" />
    <Setter Property="BorderBrush" Value="{DynamicResource Brush.Border.Default}" />
    <Setter Property="BorderThickness" Value="1" />
    <Setter Property="CornerRadius" Value="{StaticResource Radius.Lg}" />
    <Setter Property="Padding" Value="{StaticResource Pad.3}" />
  </Style>

  <Style Selector="Border.HttpDocumentCaseActionCard">
    <Setter Property="Background" Value="{DynamicResource Brush.Background.Subtle}" />
    <Setter Property="BorderBrush" Value="{DynamicResource Brush.Border.Default}" />
    <Setter Property="BorderThickness" Value="1" />
    <Setter Property="CornerRadius" Value="{StaticResource Radius.Lg}" />
    <Setter Property="Padding" Value="{StaticResource Pad.3}" />
    <Setter Property="MinWidth" Value="220" />
    <Setter Property="VerticalAlignment" Value="Top" />
  </Style>

  <Style Selector="Border.HttpDocumentPreviewCard">
    <Setter Property="Padding" Value="{StaticResource Pad.4}" />
  </Style>

  <Style Selector="Border.HttpDocumentKeyValueRow">
    <Setter Property="Background" Value="{DynamicResource Brush.Background.Subtle}" />
    <Setter Property="CornerRadius" Value="{StaticResource Radius.Md}" />
    <Setter Property="Padding" Value="10,8" />
    <Setter Property="Margin" Value="0,0,0,8" />
  </Style>

  <Style Selector="TextBox.HttpDocumentReadonlyCode">
    <Setter Property="Background" Value="{DynamicResource Brush.Background.Subtle}" />
    <Setter Property="BorderBrush" Value="{DynamicResource Brush.Border.Default}" />
    <Setter Property="BorderThickness" Value="1" />
    <Setter Property="CornerRadius" Value="{StaticResource Radius.Lg}" />
    <Setter Property="Padding" Value="{StaticResource Pad.3}" />
    <Setter Property="MinHeight" Value="180" />
    <Setter Property="FontFamily" Value="{StaticResource Font.Monospace}" />
  </Style>

  <Style Selector="TextBlock.HttpResponsePlaceholderIcon">
    <Setter Property="FontSize" Value="44" />
    <Setter Property="Foreground" Value="{DynamicResource Brush.Text.Tertiary}" />
    <Setter Property="HorizontalAlignment" Value="Center" />
  </Style>

  <Style Selector="Border.HttpResponsePlaceholderHost">
    <Setter Property="HorizontalAlignment" Value="Stretch" />
    <Setter Property="VerticalAlignment" Value="Stretch" />
  </Style>

  <Style Selector="StackPanel.HttpResponsePlaceholderContent">
    <Setter Property="HorizontalAlignment" Value="Center" />
    <Setter Property="VerticalAlignment" Value="Center" />
  </Style>

  <Style Selector="TextBlock.HttpResponsePlaceholderText">
    <Setter Property="HorizontalAlignment" Value="Center" />
    <Setter Property="TextAlignment" Value="Center" />
  </Style>

  <Style Selector="Border.HttpResponseLoadingOverlay">
    <Setter Property="Background" Value="{DynamicResource Brush.Background.Overlay}" />
    <Setter Property="HorizontalAlignment" Value="Stretch" />
    <Setter Property="VerticalAlignment" Value="Stretch" />
  </Style>

  <Style Selector="StackPanel.HttpResponseLoadingContent">
    <Setter Property="Width" Value="280" />
    <Setter Property="HorizontalAlignment" Value="Center" />
    <Setter Property="VerticalAlignment" Value="Center" />
  </Style>

  <Style Selector="ProgressBar.HttpResponseLoadingProgress">
    <Setter Property="Height" Value="4" />
  </Style>

  <Style Selector="TextBlock.HttpResponseLoadingText">
    <Setter Property="HorizontalAlignment" Value="Center" />
    <Setter Property="TextAlignment" Value="Center" />
  </Style>

  <Style Selector="Border.EnvironmentSummaryPill">
    <Setter Property="Background" Value="{DynamicResource Brush.Background.Subtle}" />
    <Setter Property="BorderBrush" Value="{DynamicResource Brush.Border.Default}" />
    <Setter Property="BorderThickness" Value="1" />
    <Setter Property="CornerRadius" Value="{StaticResource Radius.Lg}" />
    <Setter Property="Padding" Value="{StaticResource Pad.3}" />
  </Style>

  <Style Selector="Border.ProjectSummaryCard">
    <Setter Property="Background" Value="{DynamicResource Brush.Background.Subtle}" />
    <Setter Property="CornerRadius" Value="{StaticResource Radius.Lg}" />
    <Setter Property="Padding" Value="{StaticResource Pad.3}" />
  </Style>

  <Style Selector="Border.SidebarListCard">
    <Setter Property="Background" Value="{DynamicResource Brush.Background.Subtle}" />
    <Setter Property="CornerRadius" Value="{StaticResource Radius.Lg}" />
    <Setter Property="Padding" Value="{StaticResource Pad.3}" />
    <Setter Property="Margin" Value="0,0,0,8" />
  </Style>

  <Style Selector="Border.QuickRequestHintCard">
    <Setter Property="Background" Value="{DynamicResource Brush.Background.Subtle}" />
    <Setter Property="CornerRadius" Value="{StaticResource Radius.Lg}" />
    <Setter Property="Padding" Value="{StaticResource Pad.3}" />
  </Style>

  <Style Selector="Border.ResponsePanelCard">
    <Setter Property="MinHeight" Value="520" />
  </Style>

  <Style Selector="Border.ProjectWorkspaceSettingsCard">
    <Setter Property="MinHeight" Value="320" />
  </Style>

  <Style Selector="Border.HttpWorkbenchConfigCard">
    <Setter Property="MinHeight" Value="180" />
    <Setter Property="MaxHeight" Value="340" />
    <Setter Property="ClipToBounds" Value="True" />
  </Style>

  <Style Selector="Border.ProjectWorkspaceSettingsHeader">
    <Setter Property="Background" Value="{DynamicResource Brush.Background.Subtle}" />
    <Setter Property="BorderBrush" Value="{DynamicResource Brush.Border.Default}" />
    <Setter Property="BorderThickness" Value="0,0,0,1" />
    <Setter Property="Padding" Value="{StaticResource Pad.3}" />
    <Setter Property="CornerRadius" Value="12,12,0,0" />
  </Style>
</Styles>
