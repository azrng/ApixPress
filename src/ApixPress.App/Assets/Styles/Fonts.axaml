<ResourceDictionary xmlns="https://github.com/avaloniaui"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
  <FontFamily x:Key="Font.Default">Segoe UI, Microsoft YaHei UI, sans-serif</FontFamily>
  <x:Double x:Key="Font.Size.Caption">12</x:Double>
  <x:Double x:Key="Font.Size.Body">14</x:Double>
  <x:Double x:Key="Font.Size.BodyLarge">16</x:Double>
  <x:Double x:Key="Font.Size.Title">20</x:Double>
  <x:Double x:Key="Font.Size.Hero">30</x:Double>
</ResourceDictionary>
