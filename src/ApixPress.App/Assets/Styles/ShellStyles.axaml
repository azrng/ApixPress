    <Setter Property="CornerRadius" Value="{StaticResource Radius.Lg}" />
    <Setter Property="Padding" Value="{StaticResource Pad.6}" />
  </Style>

  <Style Selector="Border.AppIconBadge">
    <Setter Property="Background" Value="Transparent" />
    <Setter Property="BorderBrush" Value="Transparent" />
    <Setter Property="BorderThickness" Value="0" />
    <Setter Property="CornerRadius" Value="{StaticResource Radius.Md}" />
    <Setter Property="Padding" Value="0" />
    <Setter Property="ClipToBounds" Value="True" />
  </Style>

  <Style Selector="Image.AppLogoImage">
    <Setter Property="HorizontalAlignment" Value="Stretch" />
    <Setter Property="VerticalAlignment" Value="Stretch" />
    <Setter Property="Margin" Value="-1" />
  </Style>

  <Style Selector="Border.StatusStrip">
