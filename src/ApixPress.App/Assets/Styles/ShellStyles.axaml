<Styles xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:u="https://irihi.tech/ursa">  <Style Selector="Window">
    <Setter Property="Background" Value="{DynamicResource Brush.Background.App}" />
    <Setter Property="Foreground" Value="{DynamicResource Brush.Text.Primary}" />
    <Setter Property="FontFamily" Value="{StaticResource Font.Default}" />
  </Style>

  <Style Selector="TextBox">
    <Setter Property="TextAlignment" Value="Left" />
    <Setter Property="HorizontalContentAlignment" Value="Left" />
    <Setter Property="VerticalContentAlignment" Value="Top" />
  </Style>

  <Style Selector="TextBox[AcceptsReturn=true]">
    <Setter Property="HorizontalAlignment" Value="Stretch" />
    <Setter Property="VerticalAlignment" Value="Stretch" />
    <Setter Property="TextWrapping" Value="Wrap" />
  </Style>

  <Style Selector="Border.RawEditorCard > TextBox">
    <Setter Property="HorizontalAlignment" Value="Stretch" />
    <Setter Property="VerticalAlignment" Value="Stretch" />
  </Style>

  <Style Selector="Border.PanelCard">
    <Setter Property="Background" Value="{DynamicResource Brush.Background.Surface}" />
    <Setter Property="BorderBrush" Value="{DynamicResource Brush.Border.Default}" />
    <Setter Property="BorderThickness" Value="1" />
    <Setter Property="CornerRadius" Value="{StaticResource Radius.Lg}" />
    <Setter Property="Padding" Value="{StaticResource Pad.4}" />
  </Style>

  <Style Selector="Border.TopBarCard">
    <Setter Property="Background" Value="{DynamicResource Brush.Background.Surface}" />
    <Setter Property="BorderBrush" Value="{DynamicResource Brush.Border.Default}" />
    <Setter Property="BorderThickness" Value="0,0,0,1" />
    <Setter Property="Padding" Value="12,3" />
  </Style>

  <Style Selector="Path.ShellIconPath">
    <Setter Property="Width" Value="16" />
    <Setter Property="Height" Value="16" />
    <Setter Property="Stretch" Value="Uniform" />
    <Setter Property="Stroke" Value="{DynamicResource Brush.Text.Primary}" />
    <Setter Property="StrokeThickness" Value="1.6" />
  </Style>

  <Style Selector="Border.EmptyStateCard">
    <Setter Property="Background" Value="{DynamicResource Brush.Background.Surface}" />
    <Setter Property="BorderBrush" Value="{DynamicResource Brush.Border.Strong}" />
    <Setter Property="BorderThickness" Value="1" />
    <Setter Property="CornerRadius" Value="{StaticResource Radius.Lg}" />
    <Setter Property="Padding" Value="{StaticResource Pad.6}" />
  </Style>

  <Style Selector="TextBlock.PageTitle">
    <Setter Property="FontSize" Value="{StaticResource Font.Size.Title}" />
    <Setter Property="FontWeight" Value="SemiBold" />
  </Style>

  <Style Selector="TextBlock.HeroTitle">
    <Setter Property="FontSize" Value="{StaticResource Font.Size.Hero}" />
    <Setter Property="FontWeight" Value="SemiBold" />
  </Style>

  <Style Selector="TextBlock.SectionTitle">
    <Setter Property="FontSize" Value="{StaticResource Font.Size.BodyLarge}" />
    <Setter Property="FontWeight" Value="SemiBold" />
  </Style>

  <Style Selector="TextBlock.CaptionText">
    <Setter Property="FontSize" Value="{StaticResource Font.Size.Caption}" />
    <Setter Property="Foreground" Value="{DynamicResource Brush.Text.Secondary}" />
  </Style>

  <Style Selector="TextBlock.SubtleText">
    <Setter Property="Foreground" Value="{DynamicResource Brush.Text.Secondary}" />
  </Style>

  <Style Selector="Button.PrimaryButton">
    <Setter Property="Background" Value="{DynamicResource Brush.Border.Focus}" />
    <Setter Property="Foreground" Value="{DynamicResource Brush.Text.Inverse}" />
    <Setter Property="Padding" Value="{StaticResource Pad.3}" />
    <Setter Property="CornerRadius" Value="{StaticResource Radius.Md}" />
  </Style>

  <Style Selector="Button.SecondaryButton">
    <Setter Property="Background" Value="{DynamicResource Brush.Background.Subtle}" />
    <Setter Property="Foreground" Value="{DynamicResource Brush.Text.Primary}" />
    <Setter Property="Padding" Value="{StaticResource Pad.3}" />
    <Setter Property="CornerRadius" Value="{StaticResource Radius.Md}" />
  </Style>

  <Style Selector="Button.TopActionButton">
    <Setter Property="Background" Value="{DynamicResource Brush.Background.Subtle}" />
    <Setter Property="Foreground" Value="{DynamicResource Brush.Text.Primary}" />
    <Setter Property="Padding" Value="{StaticResource Pad.3}" />
    <Setter Property="CornerRadius" Value="{StaticResource Radius.Md}" />
    <Setter Property="BorderBrush" Value="{DynamicResource Brush.Border.Default}" />
    <Setter Property="BorderThickness" Value="1" />
  </Style>

  <Style Selector="Button.TopActionButton:pointerover">
    <Setter Property="Background" Value="{DynamicResource Brush.Background.Selected}" />
    <Setter Property="BorderBrush" Value="{DynamicResource Brush.Border.Focus}" />
  </Style>

  <Style Selector="Button.ShellIconButton">
    <Setter Property="Width" Value="28" />
    <Setter Property="Height" Value="28" />
    <Setter Property="Padding" Value="0" />
    <Setter Property="Background" Value="{DynamicResource Brush.Background.Subtle}" />
    <Setter Property="BorderBrush" Value="{DynamicResource Brush.Border.Default}" />
    <Setter Property="BorderThickness" Value="1" />
    <Setter Property="CornerRadius" Value="{StaticResource Radius.Md}" />
  </Style>

  <Style Selector="Button.ShellIconButton:pointerover">
    <Setter Property="Background" Value="{DynamicResource Brush.Background.Selected}" />
    <Setter Property="BorderBrush" Value="{DynamicResource Brush.Border.Focus}" />
  </Style>

  <Style Selector="Border.NotificationDot">
    <Setter Property="Background" Value="{DynamicResource Brush.Status.Warning.Text}" />
    <Setter Property="CornerRadius" Value="{StaticResource Radius.Xl}" />
    <Setter Property="BorderBrush" Value="{DynamicResource Brush.Background.Surface}" />
    <Setter Property="BorderThickness" Value="1" />
  </Style>

  <Style Selector="Button.WindowControlButton">
    <Setter Property="Width" Value="40" />
    <Setter Property="Height" Value="26" />
    <Setter Property="Background" Value="Transparent" />
    <Setter Property="BorderThickness" Value="0" />
    <Setter Property="CornerRadius" Value="{StaticResource Radius.Md}" />
    <Setter Property="Padding" Value="0" />
  </Style>

  <Style Selector="Button.WindowControlButton:pointerover">
    <Setter Property="Background" Value="{DynamicResource Brush.Background.Subtle}" />
  </Style>

  <Style Selector="Button.WindowCloseButton:pointerover">
    <Setter Property="Background" Value="{DynamicResource Brush.Status.Warning.Background}" />
  </Style>

  <Style Selector="TextBlock.WindowControlGlyph">
    <Setter Property="HorizontalAlignment" Value="Center" />
    <Setter Property="VerticalAlignment" Value="Center" />
    <Setter Property="FontSize" Value="{StaticResource Font.Size.BodyLarge}" />
    <Setter Property="Foreground" Value="{DynamicResource Brush.Text.Primary}" />
  </Style>

  <Style Selector="Button.IconButton">
    <Setter Property="Padding" Value="{StaticResource Pad.2}" />
    <Setter Property="CornerRadius" Value="{StaticResource Radius.Sm}" />
  </Style>

  <Style Selector="TextBox.SectionInput">
    <Setter Property="Background" Value="{DynamicResource Brush.Background.Subtle}" />
    <Setter Property="BorderBrush" Value="{DynamicResource Brush.Border.Default}" />
    <Setter Property="BorderThickness" Value="1" />
    <Setter Property="Padding" Value="{StaticResource Pad.2}" />
    <Setter Property="CornerRadius" Value="{StaticResource Radius.Md}" />
  </Style>

  <Style Selector="ComboBox.SectionInput">
    <Setter Property="Background" Value="{DynamicResource Brush.Background.Subtle}" />
    <Setter Property="BorderBrush" Value="{DynamicResource Brush.Border.Default}" />
    <Setter Property="BorderThickness" Value="1" />
    <Setter Property="Padding" Value="{StaticResource Pad.2}" />
  </Style>

  <Style Selector="Expander.SectionExpander">
    <Setter Property="Background" Value="{DynamicResource Brush.Background.Subtle}" />
    <Setter Property="BorderBrush" Value="{DynamicResource Brush.Border.Default}" />
    <Setter Property="BorderThickness" Value="1" />
    <Setter Property="CornerRadius" Value="{StaticResource Radius.Md}" />
    <Setter Property="Padding" Value="{StaticResource Pad.2}" />
