<Styles xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
  <Style Selector="Window">
    <Setter Property="Background" Value="{DynamicResource Brush.Background.App}" />
    <Setter Property="Foreground" Value="{DynamicResource Brush.Text.Primary}" />
    <Setter Property="FontFamily" Value="{StaticResource Font.Default}" />
  </Style>

  <Style Selector="Border.PanelCard">
    <Setter Property="Background" Value="{DynamicResource Brush.Background.Surface}" />
    <Setter Property="BorderBrush" Value="{DynamicResource Brush.Border.Default}" />
    <Setter Property="BorderThickness" Value="1" />
    <Setter Property="CornerRadius" Value="{StaticResource Radius.Lg}" />
    <Setter Property="Padding" Value="{StaticResource Pad.4}" />
  </Style>

  <Style Selector="Border.TopBarCard">
    <Setter Property="Background" Value="{DynamicResource Brush.Background.Surface}" />
    <Setter Property="BorderBrush" Value="{DynamicResource Brush.Border.Default}" />
    <Setter Property="BorderThickness" Value="0,0,0,1" />
    <Setter Property="Padding" Value="{StaticResource Pad.4}" />
  </Style>

  <Style Selector="Path.ShellIconPath">
    <Setter Property="Width" Value="16" />
    <Setter Property="Height" Value="16" />
    <Setter Property="Stretch" Value="Uniform" />
    <Setter Property="Stroke" Value="{DynamicResource Brush.Text.Primary}" />
    <Setter Property="StrokeThickness" Value="1.6" />
  </Style>

  <Style Selector="Border.EmptyStateCard">
    <Setter Property="Background" Value="{DynamicResource Brush.Background.Surface}" />
    <Setter Property="BorderBrush" Value="{DynamicResource Brush.Border.Strong}" />
    <Setter Property="BorderThickness" Value="1" />
    <Setter Property="CornerRadius" Value="{StaticResource Radius.Lg}" />
    <Setter Property="Padding" Value="{StaticResource Pad.6}" />
  </Style>

  <Style Selector="TextBlock.PageTitle">
    <Setter Property="FontSize" Value="{StaticResource Font.Size.Title}" />
    <Setter Property="FontWeight" Value="SemiBold" />
  </Style>

  <Style Selector="TextBlock.HeroTitle">
    <Setter Property="FontSize" Value="{StaticResource Font.Size.Hero}" />
    <Setter Property="FontWeight" Value="SemiBold" />
  </Style>

  <Style Selector="TextBlock.SectionTitle">
    <Setter Property="FontSize" Value="{StaticResource Font.Size.BodyLarge}" />
    <Setter Property="FontWeight" Value="SemiBold" />
  </Style>

  <Style Selector="TextBlock.CaptionText">
    <Setter Property="FontSize" Value="{StaticResource Font.Size.Caption}" />
    <Setter Property="Foreground" Value="{DynamicResource Brush.Text.Secondary}" />
  </Style>

  <Style Selector="TextBlock.SubtleText">
    <Setter Property="Foreground" Value="{DynamicResource Brush.Text.Secondary}" />
  </Style>

  <Style Selector="Button.PrimaryButton">
    <Setter Property="Background" Value="{DynamicResource Brush.Border.Focus}" />
    <Setter Property="Foreground" Value="{DynamicResource Brush.Text.Inverse}" />
    <Setter Property="Padding" Value="{StaticResource Pad.3}" />
    <Setter Property="CornerRadius" Value="{StaticResource Radius.Md}" />
  </Style>

  <Style Selector="Button.SecondaryButton">
    <Setter Property="Background" Value="{DynamicResource Brush.Background.Subtle}" />
    <Setter Property="Foreground" Value="{DynamicResource Brush.Text.Primary}" />
    <Setter Property="Padding" Value="{StaticResource Pad.3}" />
    <Setter Property="CornerRadius" Value="{StaticResource Radius.Md}" />
  </Style>

  <Style Selector="Button.TopActionButton">
    <Setter Property="Background" Value="{DynamicResource Brush.Background.Subtle}" />
    <Setter Property="Foreground" Value="{DynamicResource Brush.Text.Primary}" />
    <Setter Property="Padding" Value="{StaticResource Pad.3}" />
    <Setter Property="CornerRadius" Value="{StaticResource Radius.Md}" />
    <Setter Property="BorderBrush" Value="{DynamicResource Brush.Border.Default}" />
    <Setter Property="BorderThickness" Value="1" />
  </Style>

  <Style Selector="Button.TopActionButton:pointerover">
    <Setter Property="Background" Value="{DynamicResource Brush.Background.Selected}" />
    <Setter Property="BorderBrush" Value="{DynamicResource Brush.Border.Focus}" />
  </Style>

  <Style Selector="Button.ShellIconButton">
    <Setter Property="Width" Value="36" />
    <Setter Property="Height" Value="36" />
    <Setter Property="Padding" Value="0" />
    <Setter Property="Background" Value="{DynamicResource Brush.Background.Subtle}" />
    <Setter Property="BorderBrush" Value="{DynamicResource Brush.Border.Default}" />
    <Setter Property="BorderThickness" Value="1" />
    <Setter Property="CornerRadius" Value="{StaticResource Radius.Md}" />
  </Style>

  <Style Selector="Button.ShellIconButton:pointerover">
    <Setter Property="Background" Value="{DynamicResource Brush.Background.Selected}" />
    <Setter Property="BorderBrush" Value="{DynamicResource Brush.Border.Focus}" />
  </Style>

  <Style Selector="Border.NotificationDot">
    <Setter Property="Background" Value="{DynamicResource Brush.Status.Warning.Text}" />
    <Setter Property="CornerRadius" Value="{StaticResource Radius.Xl}" />
    <Setter Property="BorderBrush" Value="{DynamicResource Brush.Background.Surface}" />
    <Setter Property="BorderThickness" Value="1" />
  </Style>

  <Style Selector="Button.WindowControlButton">
    <Setter Property="Width" Value="44" />
    <Setter Property="Height" Value="32" />
    <Setter Property="Background" Value="Transparent" />
    <Setter Property="BorderThickness" Value="0" />
    <Setter Property="CornerRadius" Value="{StaticResource Radius.Md}" />
    <Setter Property="Padding" Value="0" />
  </Style>

  <Style Selector="Button.WindowControlButton:pointerover">
    <Setter Property="Background" Value="{DynamicResource Brush.Background.Subtle}" />
  </Style>

  <Style Selector="Button.WindowCloseButton:pointerover">
    <Setter Property="Background" Value="{DynamicResource Brush.Status.Warning.Background}" />
  </Style>

  <Style Selector="TextBlock.WindowControlGlyph">
    <Setter Property="HorizontalAlignment" Value="Center" />
    <Setter Property="VerticalAlignment" Value="Center" />
    <Setter Property="FontSize" Value="{StaticResource Font.Size.BodyLarge}" />
    <Setter Property="Foreground" Value="{DynamicResource Brush.Text.Primary}" />
  </Style>

  <Style Selector="Button.IconButton">
    <Setter Property="Padding" Value="{StaticResource Pad.2}" />
    <Setter Property="CornerRadius" Value="{StaticResource Radius.Sm}" />
  </Style>

  <Style Selector="TextBox.SectionInput">
    <Setter Property="Background" Value="{DynamicResource Brush.Background.Subtle}" />
    <Setter Property="BorderBrush" Value="{DynamicResource Brush.Border.Default}" />
    <Setter Property="BorderThickness" Value="1" />
    <Setter Property="Padding" Value="{StaticResource Pad.2}" />
    <Setter Property="CornerRadius" Value="{StaticResource Radius.Md}" />
  </Style>

  <Style Selector="ComboBox.SectionInput">
    <Setter Property="Background" Value="{DynamicResource Brush.Background.Subtle}" />
    <Setter Property="BorderBrush" Value="{DynamicResource Brush.Border.Default}" />
    <Setter Property="BorderThickness" Value="1" />
    <Setter Property="Padding" Value="{StaticResource Pad.2}" />
  </Style>

  <Style Selector="Expander.SectionExpander">
    <Setter Property="Background" Value="{DynamicResource Brush.Background.Subtle}" />
    <Setter Property="BorderBrush" Value="{DynamicResource Brush.Border.Default}" />
    <Setter Property="BorderThickness" Value="1" />
    <Setter Property="CornerRadius" Value="{StaticResource Radius.Md}" />
    <Setter Property="Padding" Value="{StaticResource Pad.2}" />
  </Style>

  <Style Selector="ListBox.FlatListBox">
    <Setter Property="Background" Value="{DynamicResource Brush.Background.Subtle}" />
    <Setter Property="BorderBrush" Value="{DynamicResource Brush.Border.Default}" />
    <Setter Property="BorderThickness" Value="1" />
  </Style>

  <Style Selector="TabControl.ResponseTabs">
    <Setter Property="Background" Value="{DynamicResource Brush.Background.Subtle}" />
  </Style>

  <Style Selector="Border.StatusInfo">
    <Setter Property="Background" Value="{DynamicResource Brush.Status.Info.Background}" />
    <Setter Property="CornerRadius" Value="{StaticResource Radius.Md}" />
    <Setter Property="Padding" Value="{StaticResource Pad.3}" />
  </Style>

  <Style Selector="Border.StatusSuccess">
    <Setter Property="Background" Value="{DynamicResource Brush.Status.Success.Background}" />
    <Setter Property="CornerRadius" Value="{StaticResource Radius.Md}" />
    <Setter Property="Padding" Value="{StaticResource Pad.3}" />
  </Style>

  <Style Selector="Button.SendButton">
    <Setter Property="Background" Value="{DynamicResource Brush.Border.Focus}" />
    <Setter Property="Foreground" Value="{DynamicResource Brush.Text.Inverse}" />
    <Setter Property="FontWeight" Value="SemiBold" />
    <Setter Property="Padding" Value="{StaticResource Pad.4}" />
    <Setter Property="CornerRadius" Value="{StaticResource Radius.Md}" />
  </Style>

  <Style Selector="Border.PlaceholderTab">
    <Setter Property="Background" Value="{DynamicResource Brush.Background.Subtle}" />
    <Setter Property="CornerRadius" Value="{StaticResource Radius.Lg}" />
    <Setter Property="Padding" Value="{StaticResource Pad.6}" />
  </Style>

  <Style Selector="Border.AppIconBadge">
    <Setter Property="Background" Value="{DynamicResource Brush.Status.Info.Background}" />
    <Setter Property="CornerRadius" Value="{StaticResource Radius.Lg}" />
  </Style>

  <Style Selector="Border.StatusStrip">
    <Setter Property="Background" Value="{DynamicResource Brush.Background.Subtle}" />
    <Setter Property="CornerRadius" Value="{StaticResource Radius.Lg}" />
    <Setter Property="Padding" Value="{StaticResource Pad.3}" />
  </Style>

  <Style Selector="Border.BrowserHeroCard">
    <Setter Property="Background" Value="{DynamicResource Brush.Background.Surface}" />
    <Setter Property="BorderBrush" Value="{DynamicResource Brush.Border.Default}" />
    <Setter Property="BorderThickness" Value="1" />
    <Setter Property="CornerRadius" Value="{StaticResource Radius.Xl}" />
    <Setter Property="Padding" Value="{StaticResource Pad.6}" />
  </Style>

  <Style Selector="Border.BrowserToolbarCard">
    <Setter Property="Background" Value="{DynamicResource Brush.Background.Surface}" />
    <Setter Property="BorderBrush" Value="{DynamicResource Brush.Border.Default}" />
    <Setter Property="BorderThickness" Value="1" />
    <Setter Property="CornerRadius" Value="{StaticResource Radius.Xl}" />
    <Setter Property="Padding" Value="{StaticResource Pad.4}" />
    <Setter Property="BoxShadow" Value="0 10 26 0 #0F172A0D" />
  </Style>

  <Style Selector="Border.InfoPill">
    <Setter Property="Background" Value="{DynamicResource Brush.Background.Subtle}" />
    <Setter Property="CornerRadius" Value="{StaticResource Radius.Lg}" />
    <Setter Property="Padding" Value="{StaticResource Pad.3}" />
  </Style>

  <Style Selector="TextBox.ToolbarSearchBox">
    <Setter Property="Background" Value="{DynamicResource Brush.Background.Subtle}" />
    <Setter Property="BorderBrush" Value="{DynamicResource Brush.Border.Default}" />
    <Setter Property="BorderThickness" Value="1" />
    <Setter Property="Padding" Value="{StaticResource Pad.3}" />
    <Setter Property="CornerRadius" Value="{StaticResource Radius.Lg}" />
    <Setter Property="MinHeight" Value="40" />
  </Style>

  <Style Selector="Border.SectionHeaderPill">
    <Setter Property="Background" Value="{DynamicResource Brush.Background.Surface}" />
    <Setter Property="BorderBrush" Value="{DynamicResource Brush.Border.Default}" />
    <Setter Property="BorderThickness" Value="1" />
    <Setter Property="CornerRadius" Value="{StaticResource Radius.Lg}" />
    <Setter Property="Padding" Value="{StaticResource Pad.3}" />
  </Style>

  <Style Selector="Border.CreateProjectDialogBackdrop">
    <Setter Property="Background" Value="{DynamicResource Brush.Background.Overlay}" />
  </Style>

  <Style Selector="Border.NotificationFlyoutCard">
    <Setter Property="Width" Value="360" />
    <Setter Property="Background" Value="{DynamicResource Brush.Background.Surface}" />
    <Setter Property="BorderBrush" Value="{DynamicResource Brush.Border.Default}" />
    <Setter Property="BorderThickness" Value="1" />
    <Setter Property="CornerRadius" Value="{StaticResource Radius.Xl}" />
    <Setter Property="Padding" Value="{StaticResource Pad.4}" />
    <Setter Property="BoxShadow" Value="0 18 36 0 #0F172A18" />
  </Style>

  <Style Selector="Border.NotificationItemCard">
    <Setter Property="Background" Value="{DynamicResource Brush.Background.Subtle}" />
    <Setter Property="CornerRadius" Value="{StaticResource Radius.Lg}" />
    <Setter Property="Padding" Value="{StaticResource Pad.3}" />
    <Setter Property="Margin" Value="0,0,0,8" />
  </Style>

  <Style Selector="Border.NotificationItemDot">
    <Setter Property="Background" Value="{DynamicResource Brush.Border.Focus}" />
    <Setter Property="CornerRadius" Value="{StaticResource Radius.Xl}" />
    <Setter Property="VerticalAlignment" Value="Top" />
    <Setter Property="Margin" Value="0,6,0,0" />
  </Style>

  <Style Selector="Border.SettingsDialogBackdrop">
    <Setter Property="Background" Value="{DynamicResource Brush.Background.Overlay}" />
  </Style>

  <Style Selector="Border.SettingsDialogCard">
    <Setter Property="Width" Value="980" />
    <Setter Property="Height" Value="640" />
    <Setter Property="Background" Value="{DynamicResource Brush.Background.Surface}" />
    <Setter Property="BorderBrush" Value="{DynamicResource Brush.Border.Default}" />
    <Setter Property="BorderThickness" Value="1" />
    <Setter Property="CornerRadius" Value="{StaticResource Radius.Xl}" />
    <Setter Property="BoxShadow" Value="0 28 60 0 #0F172A20" />
  </Style>

  <Style Selector="Border.SettingsSidebar">
    <Setter Property="Background" Value="{DynamicResource Brush.Background.Subtle}" />
    <Setter Property="BorderBrush" Value="{DynamicResource Brush.Border.Default}" />
    <Setter Property="BorderThickness" Value="0,0,1,0" />
    <Setter Property="Padding" Value="{StaticResource Pad.5}" />
    <Setter Property="CornerRadius" Value="16,0,0,16" />
  </Style>

  <Style Selector="ToggleButton.SettingsNavButton">
    <Setter Property="Background" Value="Transparent" />
    <Setter Property="BorderThickness" Value="0" />
    <Setter Property="CornerRadius" Value="{StaticResource Radius.Lg}" />
    <Setter Property="Padding" Value="16,12" />
    <Setter Property="HorizontalContentAlignment" Value="Left" />
    <Setter Property="Foreground" Value="{DynamicResource Brush.Text.Primary}" />
  </Style>

  <Style Selector="ToggleButton.SettingsNavButton:pointerover">
    <Setter Property="Background" Value="{DynamicResource Brush.Background.Surface}" />
  </Style>

  <Style Selector="ToggleButton.SettingsNavButton:checked">
    <Setter Property="Background" Value="{DynamicResource Brush.Background.Surface}" />
    <Setter Property="BorderBrush" Value="{DynamicResource Brush.Border.Focus}" />
    <Setter Property="BorderThickness" Value="1" />
  </Style>

  <Style Selector="Border.SettingsPageSection">
    <Setter Property="Background" Value="{DynamicResource Brush.Background.Surface}" />
    <Setter Property="BorderBrush" Value="{DynamicResource Brush.Border.Default}" />
    <Setter Property="BorderThickness" Value="1" />
    <Setter Property="CornerRadius" Value="{StaticResource Radius.Lg}" />
    <Setter Property="Padding" Value="{StaticResource Pad.4}" />
  </Style>

  <Style Selector="TextBlock.SettingsGroupTitle">
    <Setter Property="FontSize" Value="{StaticResource Font.Size.BodyLarge}" />
    <Setter Property="FontWeight" Value="SemiBold" />
  </Style>

  <Style Selector="NumericUpDown.SettingsNumberInput">
    <Setter Property="MinWidth" Value="150" />
  </Style>

  <Style Selector="Button.DialogIconButton">
    <Setter Property="Background" Value="{DynamicResource Brush.Background.Subtle}" />
    <Setter Property="Foreground" Value="{DynamicResource Brush.Text.Primary}" />
    <Setter Property="BorderBrush" Value="{DynamicResource Brush.Border.Default}" />
    <Setter Property="BorderThickness" Value="1" />
    <Setter Property="CornerRadius" Value="{StaticResource Radius.Md}" />
    <Setter Property="Padding" Value="10,6" />
  </Style>

  <Style Selector="Border.AboutHeroCard">
    <Setter Property="Background" Value="{DynamicResource Brush.Background.Subtle}" />
    <Setter Property="CornerRadius" Value="{StaticResource Radius.Xl}" />
    <Setter Property="Padding" Value="{StaticResource Pad.4}" />
  </Style>

  <Style Selector="Border.AboutIconBadge">
    <Setter Property="Background" Value="{DynamicResource Brush.Border.Focus}" />
    <Setter Property="CornerRadius" Value="{StaticResource Radius.Xl}" />
    <Setter Property="BoxShadow" Value="0 14 28 0 #4C84F02A" />
  </Style>

  <Style Selector="Border.VersionTag">
    <Setter Property="Background" Value="{DynamicResource Brush.Status.Info.Background}" />
    <Setter Property="CornerRadius" Value="{StaticResource Radius.Lg}" />
    <Setter Property="Padding" Value="10,6" />
  </Style>

  <Style Selector="Border.CreateProjectDialogCard">
    <Setter Property="Background" Value="{DynamicResource Brush.Background.Surface}" />
    <Setter Property="BorderBrush" Value="{DynamicResource Brush.Border.Default}" />
    <Setter Property="BorderThickness" Value="1" />
    <Setter Property="CornerRadius" Value="{StaticResource Radius.Xl}" />
    <Setter Property="Padding" Value="{StaticResource Pad.5}" />
    <Setter Property="Width" Value="460" />
    <Setter Property="BoxShadow" Value="0 24 60 0 #0F172A20" />
  </Style>

  <Style Selector="TextBlock.DialogTitle">
    <Setter Property="FontSize" Value="{StaticResource Font.Size.Title}" />
    <Setter Property="FontWeight" Value="SemiBold" />
  </Style>

  <Style Selector="Border.CreateProjectFormShell">
    <Setter Property="Background" Value="{DynamicResource Brush.Background.Subtle}" />
    <Setter Property="CornerRadius" Value="{StaticResource Radius.Lg}" />
    <Setter Property="Padding" Value="{StaticResource Pad.4}" />
  </Style>

  <Style Selector="TextBox.DialogInput">
    <Setter Property="MinWidth" Value="320" />
  </Style>

  <Style Selector="Button.DialogSecondaryButton">
    <Setter Property="Background" Value="{DynamicResource Brush.Background.Subtle}" />
    <Setter Property="Foreground" Value="{DynamicResource Brush.Text.Primary}" />
    <Setter Property="Padding" Value="16,12" />
    <Setter Property="CornerRadius" Value="{StaticResource Radius.Lg}" />
    <Setter Property="MinWidth" Value="92" />
  </Style>

  <Style Selector="Button.DialogPrimaryButton">
    <Setter Property="Background" Value="{DynamicResource Brush.Border.Focus}" />
    <Setter Property="Foreground" Value="{DynamicResource Brush.Text.Inverse}" />
    <Setter Property="Padding" Value="16,12" />
    <Setter Property="CornerRadius" Value="{StaticResource Radius.Lg}" />
    <Setter Property="FontWeight" Value="SemiBold" />
    <Setter Property="MinWidth" Value="112" />
  </Style>

  <Style Selector="Button.ProjectCardButton">
    <Setter Property="Background" Value="Transparent" />
    <Setter Property="BorderThickness" Value="0" />
    <Setter Property="Padding" Value="0" />
    <Setter Property="Margin" Value="0,0,16,16" />
    <Setter Property="HorizontalAlignment" Value="Stretch" />
    <Setter Property="VerticalAlignment" Value="Stretch" />
  </Style>

  <Style Selector="Border.ProjectCard">
    <Setter Property="Background" Value="{DynamicResource Brush.Background.Surface}" />
    <Setter Property="BorderBrush" Value="{DynamicResource Brush.Border.Default}" />
    <Setter Property="BorderThickness" Value="1" />
    <Setter Property="CornerRadius" Value="{StaticResource Radius.Xl}" />
    <Setter Property="Padding" Value="{StaticResource Pad.5}" />
    <Setter Property="MinHeight" Value="224" />
    <Setter Property="BoxShadow" Value="0 12 32 0 #0F172A0D" />
  </Style>

  <Style Selector="Border.ProjectCardGlow">
    <Setter Property="Height" Value="4" />
    <Setter Property="HorizontalAlignment" Value="Stretch" />
    <Setter Property="VerticalAlignment" Value="Top" />
    <Setter Property="Background" Value="{DynamicResource Brush.Border.Focus}" />
    <Setter Property="CornerRadius" Value="{StaticResource Radius.Lg}" />
    <Setter Property="Margin" Value="-20,-20,-20,0" />
  </Style>

  <Style Selector="Button.ProjectCardButton:pointerover Border.ProjectCard">
    <Setter Property="BorderBrush" Value="{DynamicResource Brush.Border.Focus}" />
    <Setter Property="Background" Value="{DynamicResource Brush.Background.Selected}" />
    <Setter Property="BoxShadow" Value="0 18 36 0 #4C84F022" />
  </Style>

  <Style Selector="Border.ProjectCardIcon">
    <Setter Property="Background" Value="{DynamicResource Brush.Status.Info.Background}" />
    <Setter Property="CornerRadius" Value="{StaticResource Radius.Lg}" />
    <Setter Property="BorderBrush" Value="{DynamicResource Brush.Background.Surface}" />
    <Setter Property="BorderThickness" Value="1" />
    <Setter Property="BoxShadow" Value="0 8 18 0 #4C84F020" />
  </Style>

  <Style Selector="TextBlock.ProjectAvatarText">
    <Setter Property="HorizontalAlignment" Value="Center" />
    <Setter Property="VerticalAlignment" Value="Center" />
    <Setter Property="FontSize" Value="{StaticResource Font.Size.Title}" />
    <Setter Property="FontWeight" Value="SemiBold" />
    <Setter Property="Foreground" Value="{DynamicResource Brush.Border.Focus}" />
  </Style>

  <Style Selector="Border.ProjectGridHost">
    <Setter Property="Background" Value="{DynamicResource Brush.Background.Subtle}" />
    <Setter Property="BorderBrush" Value="{DynamicResource Brush.Border.Default}" />
    <Setter Property="BorderThickness" Value="1" />
    <Setter Property="CornerRadius" Value="{StaticResource Radius.Xl}" />
    <Setter Property="Padding" Value="{StaticResource Pad.5}" />
  </Style>

  <Style Selector="TextBlock.ProjectCardTitle">
    <Setter Property="FontSize" Value="{StaticResource Font.Size.Title}" />
    <Setter Property="FontWeight" Value="SemiBold" />
  </Style>

  <Style Selector="TextBlock.ProjectCardSummary">
    <Setter Property="Foreground" Value="{DynamicResource Brush.Text.Secondary}" />
    <Setter Property="FontSize" Value="{StaticResource Font.Size.Body}" />
    <Setter Property="MaxHeight" Value="72" />
  </Style>

  <Style Selector="Border.ProjectMetaPill">
    <Setter Property="Background" Value="{DynamicResource Brush.Status.Info.Background}" />
    <Setter Property="CornerRadius" Value="{StaticResource Radius.Lg}" />
    <Setter Property="Padding" Value="8,4" />
  </Style>

  <Style Selector="Border.ProjectMetaPillMuted">
    <Setter Property="Background" Value="{DynamicResource Brush.Background.Subtle}" />
    <Setter Property="BorderBrush" Value="{DynamicResource Brush.Border.Default}" />
    <Setter Property="BorderThickness" Value="1" />
  </Style>

  <Style Selector="TextBlock.ProjectEntryHint">
    <Setter Property="Foreground" Value="{DynamicResource Brush.Text.Secondary}" />
    <Setter Property="VerticalAlignment" Value="Center" />
    <Setter Property="FontSize" Value="{StaticResource Font.Size.Caption}" />
  </Style>

  <Style Selector="Border.ProjectEntryBadge">
    <Setter Property="Background" Value="{DynamicResource Brush.Background.Selected}" />
    <Setter Property="CornerRadius" Value="{StaticResource Radius.Lg}" />
    <Setter Property="Padding" Value="10,6" />
  </Style>

  <Style Selector="TextBlock.ProjectEntryBadgeText">
    <Setter Property="Foreground" Value="{DynamicResource Brush.Border.Focus}" />
    <Setter Property="FontSize" Value="{StaticResource Font.Size.Caption}" />
    <Setter Property="FontWeight" Value="SemiBold" />
    <Setter Property="VerticalAlignment" Value="Center" />
  </Style>

  <Style Selector="Border.ProjectCardMeta">
    <Setter Property="Background" Value="{DynamicResource Brush.Background.Subtle}" />
    <Setter Property="CornerRadius" Value="{StaticResource Radius.Lg}" />
    <Setter Property="Padding" Value="{StaticResource Pad.3}" />
  </Style>

  <Style Selector="Border.SideRail">
    <Setter Property="Background" Value="{DynamicResource Brush.Background.Surface}" />
    <Setter Property="BorderBrush" Value="{DynamicResource Brush.Border.Default}" />
    <Setter Property="BorderThickness" Value="1" />
    <Setter Property="CornerRadius" Value="{StaticResource Radius.Xl}" />
    <Setter Property="Padding" Value="{StaticResource Pad.3}" />
  </Style>

  <Style Selector="Button.RailButton">
    <Setter Property="Background" Value="Transparent" />
    <Setter Property="Foreground" Value="{DynamicResource Brush.Text.Primary}" />
    <Setter Property="BorderThickness" Value="0" />
    <Setter Property="Padding" Value="{StaticResource Pad.3}" />
    <Setter Property="CornerRadius" Value="{StaticResource Radius.Lg}" />
    <Setter Property="HorizontalAlignment" Value="Stretch" />
  </Style>

  <Style Selector="Button.RailButton:pointerover">
    <Setter Property="Background" Value="{DynamicResource Brush.Background.Selected}" />
  </Style>

  <Style Selector="Border.WorkspaceHeaderCard">
    <Setter Property="Background" Value="{DynamicResource Brush.Background.Surface}" />
    <Setter Property="BorderBrush" Value="{DynamicResource Brush.Border.Default}" />
    <Setter Property="BorderThickness" Value="1" />
    <Setter Property="CornerRadius" Value="{StaticResource Radius.Xl}" />
    <Setter Property="Padding" Value="{StaticResource Pad.5}" />
  </Style>

  <Style Selector="Border.MiniInfoCard">
    <Setter Property="Background" Value="{DynamicResource Brush.Background.Subtle}" />
    <Setter Property="CornerRadius" Value="{StaticResource Radius.Lg}" />
    <Setter Property="Padding" Value="{StaticResource Pad.3}" />
    <Setter Property="Margin" Value="0,0,0,8" />
  </Style>

  <Style Selector="Border.RawEditorCard">
    <Setter Property="Background" Value="{DynamicResource Brush.Background.Subtle}" />
    <Setter Property="BorderBrush" Value="{DynamicResource Brush.Border.Default}" />
    <Setter Property="BorderThickness" Value="1" />
    <Setter Property="CornerRadius" Value="{StaticResource Radius.Md}" />
    <Setter Property="Padding" Value="{StaticResource Pad.2}" />
  </Style>

  <Style Selector="ListBox.FlatListBox ListBoxItem">
    <Setter Property="Padding" Value="{StaticResource Pad.2}" />
    <Setter Property="CornerRadius" Value="{StaticResource Radius.Sm}" />
  </Style>

  <Style Selector="ListBox.FlatListBox ListBoxItem:selected">
    <Setter Property="Background" Value="{DynamicResource Brush.Border.Focus}" />
    <Setter Property="Foreground" Value="{DynamicResource Brush.Text.Inverse}" />
  </Style>

  <!-- Request History Styles -->
  <Style Selector="Border.HistoryItemCard">
    <Setter Property="Background" Value="{DynamicResource Brush.Background.Subtle}" />
    <Setter Property="BorderBrush" Value="{DynamicResource Brush.Border.Subtle}" />
    <Setter Property="BorderThickness" Value="1" />
    <Setter Property="CornerRadius" Value="{StaticResource Radius.Md}" />
    <Setter Property="Padding" Value="{StaticResource Pad.2}" />
  </Style>

  <Style Selector="Border.HistoryItemCard:pointerover">
    <Setter Property="Background" Value="{DynamicResource Brush.Border.Default}" />
  </Style>

  <!-- Method badges -->
  <Style Selector="Border.MethodBadge_GET">
    <Setter Property="Background" Value="#6C757D" />
    <Setter Property="CornerRadius" Value="{StaticResource Radius.Sm}" />
    <Setter Property="Padding" Value="4,2" />
  </Style>

  <Style Selector="Border.MethodBadge_POST">
    <Setter Property="Background" Value="#0D6EFD" />
    <Setter Property="CornerRadius" Value="{StaticResource Radius.Sm}" />
    <Setter Property="Padding" Value="4,2" />
  </Style>

  <Style Selector="Border.MethodBadge_PUT">
    <Setter Property="Background" Value="#FD7E14" />
    <Setter Property="CornerRadius" Value="{StaticResource Radius.Sm}" />
    <Setter Property="Padding" Value="4,2" />
  </Style>

  <Style Selector="Border.MethodBadge_DELETE">
    <Setter Property="Background" Value="#DC3545" />
    <Setter Property="CornerRadius" Value="{StaticResource Radius.Sm}" />
    <Setter Property="Padding" Value="4,2" />
  </Style>

  <Style Selector="Border.MethodBadge_PATCH">
    <Setter Property="Background" Value="#20C997" />
    <Setter Property="CornerRadius" Value="{StaticResource Radius.Sm}" />
    <Setter Property="Padding" Value="4,2" />
  </Style>

  <!-- Status badges -->
  <Style Selector="Border.StatusBadge_2xx">
    <Setter Property="Background" Value="{DynamicResource Brush.Status.Success.Background}" />
    <Setter Property="CornerRadius" Value="{StaticResource Radius.Sm}" />
    <Setter Property="Padding" Value="4,2" />
  </Style>

  <Style Selector="Border.StatusBadge_3xx">
    <Setter Property="Background" Value="#6C757D" />
    <Setter Property="CornerRadius" Value="{StaticResource Radius.Sm}" />
    <Setter Property="Padding" Value="4,2" />
  </Style>

  <Style Selector="Border.StatusBadge_4xx">
    <Setter Property="Background" Value="#FD7E14" />
    <Setter Property="CornerRadius" Value="{StaticResource Radius.Sm}" />
    <Setter Property="Padding" Value="4,2" />
  </Style>

  <Style Selector="Border.StatusBadge_5xx">
    <Setter Property="Background" Value="#DC3545" />
    <Setter Property="CornerRadius" Value="{StaticResource Radius.Sm}" />
    <Setter Property="Padding" Value="4,2" />
  </Style>

  <Style Selector="Border.StatusBadge_Error">
    <Setter Property="Background" Value="#6C757D" />
    <Setter Property="CornerRadius" Value="{StaticResource Radius.Sm}" />
    <Setter Property="Padding" Value="4,2" />
  </Style>

  <!-- Text button style -->
  <Style Selector="Button.TextButton">
    <Setter Property="Background" Value="Transparent" />
    <Setter Property="Foreground" Value="{DynamicResource Brush.Border.Focus}" />
    <Setter Property="Padding" Value="{StaticResource Pad.1}" />
    <Setter Property="FontSize" Value="{StaticResource Font.Size.Caption}" />
  </Style>

  <Style Selector="Button.TextButton:pointerover">
    <Setter Property="Background" Value="{DynamicResource Brush.Background.Subtle}" />
  </Style>

  <!-- Parameter Row Styles -->
  <Style Selector="Border.ParameterRow">
    <Setter Property="Background" Value="Transparent" />
    <Setter Property="BorderBrush" Value="{DynamicResource Brush.Border.Subtle}" />
    <Setter Property="BorderThickness" Value="0,0,0,1" />
    <Setter Property="Padding" Value="{StaticResource Pad.2}" />
    <Setter Property="Margin" Value="0,2" />
  </Style>

  <Style Selector="Border.ParameterRow:pointerover">
    <Setter Property="Background" Value="{DynamicResource Brush.Background.Subtle}" />
  </Style>

  <Style Selector="Border.ParameterHeader">
    <Setter Property="Background" Value="{DynamicResource Brush.Background.Subtle}" />
    <Setter Property="BorderBrush" Value="{DynamicResource Brush.Border.Default}" />
    <Setter Property="BorderThickness" Value="0,0,0,1" />
    <Setter Property="Padding" Value="{StaticResource Pad.2}" />
    <Setter Property="Margin" Value="0,0,0,8" />
  </Style>

  <!-- Delete Button with Icon -->
  <Style Selector="Button.DeleteButton">
    <Setter Property="Background" Value="Transparent" />
    <Setter Property="Foreground" Value="{DynamicResource Brush.Text.Secondary}" />
    <Setter Property="BorderThickness" Value="0" />
    <Setter Property="Padding" Value="8" />
    <Setter Property="Width" Value="32" />
    <Setter Property="Height" Value="32" />
    <Setter Property="CornerRadius" Value="{StaticResource Radius.Sm}" />
  </Style>

  <Style Selector="Button.DeleteButton:pointerover">
    <Setter Property="Background" Value="#DC3545" />
    <Setter Property="Foreground" Value="White" />
  </Style>

  <!-- Method Selector (ComboBox) -->
  <Style Selector="ComboBox.MethodSelector">
    <Setter Property="Background" Value="#0D6EFD" />
    <Setter Property="Foreground" Value="White" />
    <Setter Property="BorderThickness" Value="0" />
    <Setter Property="Padding" Value="{StaticResource Pad.3}" />
    <Setter Property="CornerRadius" Value="{StaticResource Radius.Md}" />
    <Setter Property="FontWeight" Value="SemiBold" />
  </Style>

  <Style Selector="ComboBox.MethodSelector /template/ Border#Border">
    <Setter Property="CornerRadius" Value="{StaticResource Radius.Md}" />
  </Style>

  <!-- URL Input -->
  <Style Selector="TextBox.UrlInput">
    <Setter Property="Background" Value="{DynamicResource Brush.Background.Subtle}" />
    <Setter Property="BorderBrush" Value="{DynamicResource Brush.Border.Default}" />
    <Setter Property="BorderThickness" Value="1" />
    <Setter Property="Padding" Value="{StaticResource Pad.3}" />
    <Setter Property="CornerRadius" Value="{StaticResource Radius.Md}" />
    <Setter Property="FontSize" Value="{StaticResource Font.Size.Body}" />
  </Style>

  <Style Selector="TextBox.UrlInput:focus">
    <Setter Property="BorderBrush" Value="{DynamicResource Brush.Border.Focus}" />
    <Setter Property="BorderThickness" Value="2" />
  </Style>

  <!-- Parameter Input -->
  <Style Selector="TextBox.ParameterInput">
    <Setter Property="Background" Value="Transparent" />
    <Setter Property="BorderBrush" Value="Transparent" />
    <Setter Property="BorderThickness" Value="0" />
    <Setter Property="Padding" Value="{StaticResource Pad.2}" />
    <Setter Property="Margin" Value="0" />
    <Setter Property="FontSize" Value="{StaticResource Font.Size.Body}" />
  </Style>

  <Style Selector="TextBox.ParameterInput:focus">
    <Setter Property="Background" Value="{DynamicResource Brush.Background.App}" />
    <Setter Property="BorderBrush" Value="{DynamicResource Brush.Border.Focus}" />
    <Setter Property="BorderThickness" Value="0,0,0,2" />
  </Style>

  <!-- Add Button -->
  <Style Selector="Button.AddButton">
    <Setter Property="Background" Value="Transparent" />
    <Setter Property="Foreground" Value="{DynamicResource Brush.Border.Focus}" />
    <Setter Property="BorderBrush" Value="{DynamicResource Brush.Border.Focus}" />
    <Setter Property="BorderThickness" Value="1" />
    <Setter Property="Padding" Value="{StaticResource Pad.2},{StaticResource Pad.1}" />
    <Setter Property="CornerRadius" Value="{StaticResource Radius.Sm}" />
    <Setter Property="FontSize" Value="{StaticResource Font.Size.Caption}" />
  </Style>

  <Style Selector="Button.AddButton:pointerover">
    <Setter Property="Background" Value="{DynamicResource Brush.Border.Focus}" />
    <Setter Property="Foreground" Value="White" />
  </Style>

  <!-- Improved TabControl -->
  <Style Selector="TabControl.ConfigTabControl">
    <Setter Property="Background" Value="Transparent" />
    <Setter Property="BorderThickness" Value="0" />
  </Style>

  <Style Selector="TabControl.ConfigTabControl TabItem">
    <Setter Property="Padding" Value="{StaticResource Pad.3},{StaticResource Pad.2}" />
    <Setter Property="Margin" Value="0,0,4,0" />
    <Setter Property="FontSize" Value="{StaticResource Font.Size.Body}" />
  </Style>

  <Style Selector="TabControl.ConfigTabControl TabItem:selected">
    <Setter Property="Background" Value="{DynamicResource Brush.Background.Surface}" />
    <Setter Property="BorderBrush" Value="{DynamicResource Brush.Border.Focus}" />
    <Setter Property="BorderThickness" Value="0,0,0,2" />
  </Style>

  <!-- Body Type Selector -->
  <Style Selector="ListBox.BodyTypeSelector">
    <Setter Property="Background" Value="{DynamicResource Brush.Background.Subtle}" />
    <Setter Property="BorderBrush" Value="{DynamicResource Brush.Border.Default}" />
    <Setter Property="BorderThickness" Value="1" />
    <Setter Property="CornerRadius" Value="{StaticResource Radius.Md}" />
    <Setter Property="Padding" Value="2" />
  </Style>

  <Style Selector="ListBox.BodyTypeSelector ListBoxItem">
    <Setter Property="Padding" Value="{StaticResource Pad.2},{StaticResource Pad.1}" />
    <Setter Property="Margin" Value="0" />
    <Setter Property="BorderBrush" Value="Transparent" />
    <Setter Property="BorderThickness" Value="0" />
    <Setter Property="CornerRadius" Value="{StaticResource Radius.Sm}" />
  </Style>

  <Style Selector="ListBox.BodyTypeSelector ListBoxItem:selected">
    <Setter Property="Background" Value="{DynamicResource Brush.Border.Focus}" />
    <Setter Property="Foreground" Value="White" />
  </Style>

  <Style Selector="ListBox.BodyTypeSelector ListBoxItem:pointerover:selected">
    <Setter Property="Background" Value="{DynamicResource Brush.Border.Focus}" />
  </Style>

  <Style Selector="ListBox.BodyTypeSelector ListBoxItem:pointerover">
    <Setter Property="Background" Value="{DynamicResource Brush.Background.Subtle}" />
  </Style>
</Styles>
