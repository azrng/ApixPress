<Styles xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:u="https://irihi.tech/ursa">
  <Style Selector="Border.ProjectWorkspaceNavigationRail">
    <Setter Property="Background" Value="{DynamicResource Brush.Background.Surface}" />
    <Setter Property="BorderBrush" Value="{DynamicResource Brush.Border.Default}" />
    <Setter Property="BorderThickness" Value="1" />
    <Setter Property="CornerRadius" Value="{StaticResource Radius.Xl}" />
    <Setter Property="Padding" Value="6,10" />
  </Style>

  <Style Selector="u|NavMenu.ProjectWorkspaceNavMenu">
    <Setter Property="ExpandWidth" Value="68" />
    <Setter Property="Width" Value="68" />
    <Setter Property="HorizontalAlignment" Value="Center" />
  </Style>

  <Style Selector="Button.ProjectWorkspaceNavButton">
    <Setter Property="Width" Value="68" />
    <Setter Property="MinHeight" Value="60" />
    <Setter Property="Background" Value="Transparent" />
    <Setter Property="BorderThickness" Value="0" />
    <Setter Property="Padding" Value="8,8,8,10" />
    <Setter Property="CornerRadius" Value="{StaticResource Radius.Lg}" />
    <Setter Property="HorizontalContentAlignment" Value="Center" />
  </Style>

  <Style Selector="Button.ProjectWorkspaceNavButton:pointerover">
    <Setter Property="Background" Value="{DynamicResource Brush.Background.Subtle}" />
  </Style>

  <Style Selector="Button.ProjectWorkspaceNavButton.ProjectWorkspaceNavButtonSelected">
    <Setter Property="Background" Value="{DynamicResource Brush.Background.Selected}" />
  </Style>

  <Style Selector="u|NavMenu.ProjectWorkspaceNavMenu u|NavMenuItem">
    <Setter Property="CornerRadius" Value="{StaticResource Radius.Lg}" />
    <Setter Property="Margin" Value="0,0,0,8" />
  </Style>

  <Style Selector="u|NavMenu.ProjectWorkspaceNavMenu u|NavMenuItem /template/ Border#PART_Border">
    <Setter Property="MinHeight" Value="60" />
    <Setter Property="CornerRadius" Value="{StaticResource Radius.Lg}" />
    <Setter Property="Background" Value="Transparent" />
  </Style>

  <Style Selector="u|NavMenu.ProjectWorkspaceNavMenu u|NavMenuItem:pointerover /template/ Border#PART_Border">
    <Setter Property="Background" Value="{DynamicResource Brush.Background.Subtle}" />
  </Style>

  <Style Selector="u|NavMenu.ProjectWorkspaceNavMenu u|NavMenuItem:selected /template/ Border#PART_Border">
    <Setter Property="Background" Value="{DynamicResource Brush.Background.Selected}" />
  </Style>

  <Style Selector="u|NavMenu.ProjectWorkspaceNavMenu u|NavMenuItem /template/ ContentPresenter#PART_HeaderPresenter">
    <Setter Property="Padding" Value="8,8,8,10" />
  </Style>

  <Style Selector="TextBlock.ProjectWorkspaceNavText">
    <Setter Property="FontSize" Value="{StaticResource Font.Size.Caption}" />
    <Setter Property="Foreground" Value="{DynamicResource Brush.Text.Secondary}" />
    <Setter Property="FontWeight" Value="Medium" />
  </Style>

  <Style Selector="Button.ProjectWorkspaceNavButton.ProjectWorkspaceNavButtonSelected TextBlock.ProjectWorkspaceNavText">
    <Setter Property="Foreground" Value="{DynamicResource Brush.Text.Primary}" />
  </Style>

  <Style Selector="u|NavMenu.ProjectWorkspaceNavMenu u|NavMenuItem:selected TextBlock.ProjectWorkspaceNavText">
    <Setter Property="Foreground" Value="{DynamicResource Brush.Text.Primary}" />
  </Style>

  <Style Selector="Border.ProjectWorkspaceNavIcon">
    <Setter Property="Width" Value="34" />
    <Setter Property="Height" Value="34" />
    <Setter Property="Background" Value="{DynamicResource Brush.Background.Subtle}" />
    <Setter Property="CornerRadius" Value="{StaticResource Radius.Lg}" />
    <Setter Property="HorizontalAlignment" Value="Center" />
    <Setter Property="VerticalAlignment" Value="Center" />
  </Style>

  <Style Selector="u|NavMenu.ProjectWorkspaceNavMenu u|NavMenuItem:selected Border.ProjectWorkspaceNavIcon">
    <Setter Property="Background" Value="{DynamicResource Brush.Background.Surface}" />
  </Style>

  <Style Selector="Button.ProjectWorkspaceNavButton.ProjectWorkspaceNavButtonSelected Border.ProjectWorkspaceNavIcon">
    <Setter Property="Background" Value="{DynamicResource Brush.Background.Surface}" />
  </Style>
</Styles>
