<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:iri="https://irihi.tech/shared"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:u="https://irihi.tech/ursa"
        xmlns:vm="using:ApixPress.App.ViewModels"
        mc:Ignorable="d"
        d:DesignWidth="1440"
        d:DesignHeight="920"
        x:Class="ApixPress.App.MainWindow"
        x:Name="RootWindow"
        x:DataType="vm:MainWindowViewModel"
        Width="1440"
        Height="920"
        MinWidth="1280"
        MinHeight="800"
        SystemDecorations="None"
        ExtendClientAreaToDecorationsHint="True"
        ExtendClientAreaChromeHints="NoChrome"
        Title="ApixPress">
  <Grid RowDefinitions="Auto,*">
    <Border Grid.Row="0"
            Classes="TopBarCard">
      <Grid ColumnDefinitions="Auto,*,Auto,Auto"
            ColumnSpacing="{StaticResource Space.4}">
        <Grid Grid.Column="0"
              ColumnDefinitions="Auto,Auto"
              ColumnSpacing="{StaticResource Space.3}">
          <StackPanel Grid.Column="0"
                      Orientation="Horizontal"
                      Spacing="{StaticResource Space.3}"
                      VerticalAlignment="Center"
                      PointerPressed="OnTitleBarPointerPressed">
            <Border Width="40"
                    Height="40"
                    Classes="AppIconBadge">
              <Path Width="20"
                    Height="20"
                    HorizontalAlignment="Center"
                    VerticalAlignment="Center"
                    Fill="{DynamicResource Brush.Border.Focus}"
                    Stretch="Uniform"
                    Data="M6,4 L18,4 C19.1,4 20,4.9 20,6 L20,18 C20,19.1 19.1,20 18,20 L6,20 C4.9,20 4,19.1 4,18 L4,6 C4,4.9 4.9,4 6,4 Z M8,8 L16,8 L16,10 L8,10 Z M8,12 L13,12 L13,14 L8,14 Z M8,16 L15,16 L15,18 L8,18 Z" />
            </Border>

            <StackPanel Spacing="2"
                        VerticalAlignment="Center">
              <TextBlock Classes="PageTitle"
                         Text="ApixPress" />
              <TextBlock Classes="CaptionText"
                         Text="项目总览"
                         IsVisible="{Binding IsProjectBrowserMode}" />
              <TextBlock Classes="CaptionText"
                         Text="{Binding CurrentProjectName}"
                         IsVisible="{Binding IsWorkspaceMode}" />
            </StackPanel>
          </StackPanel>

          <Button Grid.Column="1"
                  Classes="TopActionButton"
                  Content="返回项目列表"
                  Command="{Binding BackToProjectListCommand}"
                  IsVisible="{Binding IsWorkspaceMode}" />
        </Grid>

        <Border Grid.Column="1"
                Classes="StatusStrip"
                PointerPressed="OnTitleBarPointerPressed">
          <TextBlock Classes="CaptionText"
                     Text="{Binding StatusMessage}"
                     TextTrimming="CharacterEllipsis"
                     VerticalAlignment="Center" />
        </Border>

        <StackPanel Grid.Column="2"
                    Orientation="Horizontal"
                    Spacing="{StaticResource Space.2}"
                    VerticalAlignment="Center">
          <Button Classes="ShellIconButton"
                  Command="{Binding RefreshWorkspaceCommand}"
                  ToolTip.Tip="刷新">
            <Path Classes="ShellIconPath"
                  Data="M12,5 A7,7 0 1 0 19,12 M19,5 L19,9 L15,9" />
          </Button>
          <Button Classes="ShellIconButton"
                  Command="{Binding OpenSettingsDialogCommand}"
                  ToolTip.Tip="设置">
            <Path Classes="ShellIconPath"
                  Data="M12,8.5 A3.5,3.5 0 1 0 12,15.5 A3.5,3.5 0 1 0 12,8.5 M12,3 L13.2,3.3 L13.8,5 L15.5,5.5 L17,4.7 L18.3,6 L17.5,7.5 L18,9.2 L19.7,9.8 L20,11 L18.3,12.2 L18,13.8 L19.5,15 L18.3,16.3 L16.8,15.5 L15.2,16 L14.5,17.7 L13.3,18 L12,16.7 L10.7,18 L9.5,17.7 L8.8,16 L7.2,15.5 L5.7,16.3 L4.5,15 L6,13.8 L5.7,12.2 L4,11 L4.3,9.8 L6,9.2 L6.5,7.5 L5.7,6 L7,4.7 L8.5,5.5 L10.2,5 L10.8,3.3 Z" />
          </Button>
          <Button Classes="ShellIconButton"
                  Command="{Binding ToggleNotificationCenterCommand}"
                  ToolTip.Tip="通知">
            <Grid>
              <Path Classes="ShellIconPath"
                    Data="M12,4 C9.8,4 8,5.8 8,8 L8,10.7 C8,11.5 7.7,12.3 7.2,12.9 L6,14.3 L6,15 L18,15 L18,14.3 L16.8,12.9 C16.3,12.3 16,11.5 16,10.7 L16,8 C16,5.8 14.2,4 12,4 M10,17 A2,2 0 0 0 14,17" />
              <Border Width="8"
                      Height="8"
                      Classes="NotificationDot"
                      HorizontalAlignment="Right"
                      VerticalAlignment="Top"
                      IsVisible="{Binding HasUnreadNotifications}" />
            </Grid>
          </Button>
        </StackPanel>

        <StackPanel Grid.Column="3"
                    Orientation="Horizontal"
                    Spacing="0"
                    VerticalAlignment="Center">
          <Button Classes="WindowControlButton"
                  Click="OnMinimizeWindow">
            <TextBlock Classes="WindowControlGlyph"
                       Text="&#x2014;" />
          </Button>
          <Button Classes="WindowControlButton"
                  Click="OnToggleMaximizeWindow">
            <TextBlock Classes="WindowControlGlyph"
                       Text="{Binding WindowMaximizeGlyph}" />
          </Button>
          <Button Classes="WindowControlButton WindowCloseButton"
                  Click="OnCloseWindow">
            <TextBlock Classes="WindowControlGlyph"
                       Text="&#x00D7;" />
          </Button>
        </StackPanel>
      </Grid>
    </Border>

    <Grid Grid.Row="1">
      <ScrollViewer IsVisible="{Binding IsProjectBrowserMode}">
        <Grid Margin="{StaticResource Pad.6}"
              RowDefinitions="Auto,Auto,*"
              RowSpacing="{StaticResource Space.4}">
          <Border Classes="BrowserToolbarCard">
            <Grid ColumnDefinitions="*,Auto"
                  ColumnSpacing="{StaticResource Space.4}">
              <StackPanel Grid.Column="0"
                          Spacing="{StaticResource Space.1}"
                          VerticalAlignment="Center">
                <TextBlock Classes="SectionTitle"
                           Text="项目列表" />
                <TextBlock Classes="CaptionText"
                           Text="{Binding ProjectPanel.FilteredProjects.Count, StringFormat='共 {0} 个项目，可点击进入详情页'}" />
              </StackPanel>

              <Grid Grid.Column="1"
                    ColumnDefinitions="260,Auto"
                    ColumnSpacing="{StaticResource Space.2}"
                    HorizontalAlignment="Right">
                <TextBox Grid.Column="0"
                         Classes="ToolbarSearchBox"
                         Watermark="搜索项目"
                         Text="{Binding ProjectPanel.SearchText}" />
                <Button Grid.Column="1"
                        Classes="PrimaryButton"
                        Content="新建项目"
                        Command="{Binding OpenCreateProjectDialogCommand}" />
              </Grid>
            </Grid>
          </Border>

          <Grid Grid.Row="1"
                ColumnDefinitions="*,Auto"
                ColumnSpacing="{StaticResource Space.4}">
            <StackPanel Spacing="{StaticResource Space.2}">
              <TextBlock Classes="PageTitle"
                         Text="全部项目" />
              <TextBlock Classes="CaptionText"
                         Text="默认打开这里展示项目列表，点击项目卡片进入详情页和调试工作台。" />
            </StackPanel>

            <Border Grid.Column="1"
                    Classes="SectionHeaderPill"
                    VerticalAlignment="Center">
              <StackPanel Spacing="2">
                <TextBlock Classes="CaptionText"
                           Text="当前状态" />
                <TextBlock Text="{Binding BrowserStatusText}"
                           FontSize="{StaticResource Font.Size.Body}"
                           FontWeight="SemiBold" />
              </StackPanel>
            </Border>
          </Grid>

          <Border Grid.Row="2"
                  Classes="EmptyStateCard"
                  Margin="0,24,0,0"
                  IsVisible="{Binding ShowProjectListEmptyState}">
            <StackPanel Spacing="{StaticResource Space.3}"
                        HorizontalAlignment="Center">
              <TextBlock Classes="SectionTitle"
                         Text="还没有项目" />
              <TextBlock Classes="CaptionText"
                         Text="点击右上角“新建项目”，在弹框中填写项目名称和备注后创建。" />
              <Button Classes="PrimaryButton"
                      HorizontalAlignment="Center"
                      Content="新建项目"
                      Command="{Binding OpenCreateProjectDialogCommand}" />
            </StackPanel>
          </Border>

          <Border Grid.Row="2"
                  Margin="0,24,0,0"
                  Classes="ProjectGridHost"
                  IsVisible="{Binding ProjectPanel.HasProjects}">
            <ItemsControl ItemsSource="{Binding ProjectPanel.FilteredProjects}">
              <ItemsControl.ItemsPanel>
                <ItemsPanelTemplate>
                  <WrapPanel Orientation="Horizontal"
                             ItemWidth="320"
                             ItemHeight="248" />
                </ItemsPanelTemplate>
              </ItemsControl.ItemsPanel>
              <ItemsControl.ItemTemplate>
                <DataTemplate x:DataType="vm:ProjectWorkspaceItemViewModel">
                  <Button Classes="ProjectCardButton"
                          Command="{Binding $parent[Window].((vm:MainWindowViewModel)DataContext).OpenProjectWorkspaceCommand}"
                          CommandParameter="{Binding}">
                    <Border Classes="ProjectCard">
                      <Grid RowDefinitions="Auto,Auto,*,Auto"
                            RowSpacing="{StaticResource Space.4}">
                        <Border Classes="ProjectCardGlow" />

                        <Grid ColumnDefinitions="Auto,*,Auto"
                              ColumnSpacing="{StaticResource Space.3}">
                          <Border Width="56"
                                  Height="52"
                                  Classes="ProjectCardIcon">
                            <TextBlock Classes="ProjectAvatarText"
                                       Text="{Binding AvatarText}" />
                          </Border>

                          <StackPanel Grid.Column="1"
                                      Spacing="3"
                                      VerticalAlignment="Center">
                            <TextBlock Classes="ProjectCardTitle"
                                       Text="{Binding Name}" />
                            <TextBlock Classes="CaptionText"
                                       Text="本地项目工作区" />
                          </StackPanel>

                          <u:Badge Grid.Column="2"
                                   Header="默认"
                                   IsVisible="{Binding IsDefault}"
                                   iri:ClassHelper.Classes="Light Primary" />
                        </Grid>

                        <StackPanel Grid.Row="1"
                                    Orientation="Horizontal"
                                    Spacing="{StaticResource Space.2}">
                          <Border Classes="ProjectMetaPill">
                            <TextBlock Classes="CaptionText"
                                       Text="{Binding CategoryText}" />
                          </Border>
                          <Border Classes="ProjectMetaPill ProjectMetaPillMuted">
                            <TextBlock Classes="CaptionText"
                                       Text="项目级隔离" />
                          </Border>
                        </StackPanel>

                        <TextBlock Grid.Row="2"
                                   Classes="ProjectCardSummary"
                                   Text="{Binding SummaryText}"
                                   TextWrapping="Wrap" />

                        <Grid Grid.Row="3"
                              ColumnDefinitions="*,Auto"
                              ColumnSpacing="{StaticResource Space.3}">
                          <TextBlock Grid.Column="0"
                                     Classes="ProjectEntryHint"
                                     Text="点击卡片进入项目详情与调试工作台" />
                          <Border Grid.Column="1"
                                  Classes="ProjectEntryBadge">
                            <StackPanel Orientation="Horizontal"
                                        Spacing="6">
                              <TextBlock Classes="ProjectEntryBadgeText"
                                         Text="进入项目" />
                              <TextBlock Classes="ProjectEntryBadgeText"
                                         Text="→" />
                            </StackPanel>
                          </Border>
                        </Grid>
                      </Grid>
                    </Border>
                  </Button>
                </DataTemplate>
              </ItemsControl.ItemTemplate>
            </ItemsControl>
          </Border>
        </Grid>
      </ScrollViewer>

      <Grid IsVisible="{Binding IsWorkspaceMode}"
            ColumnDefinitions="88,*"
            ColumnSpacing="{StaticResource Space.4}"
            Margin="{StaticResource Pad.5}">
        <Border Grid.Column="0"
                Classes="SideRail">
          <StackPanel Spacing="{StaticResource Space.3}">
            <Button Classes="RailButton"
                    Content="工作台"
                    Command="{Binding ShowWorkbenchCommand}" />
            <Button Classes="RailButton"
                    Content="历史"
                    Command="{Binding ShowHistoryCommand}" />
            <Button Classes="RailButton"
                    Content="设置"
                    Command="{Binding ShowProjectSettingsCommand}" />
          </StackPanel>
        </Border>

        <Grid Grid.Column="1"
              RowDefinitions="Auto,*"
              RowSpacing="{StaticResource Space.4}">
          <Border Classes="WorkspaceHeaderCard">
            <Grid ColumnDefinitions="*,Auto"
                  ColumnSpacing="{StaticResource Space.4}">
              <StackPanel Spacing="{StaticResource Space.2}">
                <TextBlock Classes="HeroTitle"
                           Text="{Binding CurrentProjectName}" />
                <TextBlock Classes="SubtleText"
                           Text="{Binding CurrentProjectSummary}" />
              </StackPanel>

              <StackPanel Grid.Column="1"
                          Width="260"
                          Spacing="{StaticResource Space.2}">
                <TextBlock Classes="CaptionText"
                           Text="当前环境" />
                <ComboBox Classes="SectionInput"
                          ItemsSource="{Binding EnvironmentPanel.Environments}"
                          SelectedItem="{Binding EnvironmentPanel.SelectedEnvironment}">
                  <ComboBox.ItemTemplate>
                    <DataTemplate x:DataType="vm:ProjectEnvironmentItemViewModel">
                      <TextBlock Text="{Binding DisplayName}" />
                    </DataTemplate>
                  </ComboBox.ItemTemplate>
                </ComboBox>
              </StackPanel>
            </Grid>
          </Border>

          <Grid Grid.Row="1"
                IsVisible="{Binding ShowWorkbenchSection}"
                ColumnDefinitions="320,*"
                ColumnSpacing="{StaticResource Space.4}">
            <ScrollViewer Grid.Column="0">
              <StackPanel Spacing="{StaticResource Space.3}">
                <Border Classes="PanelCard">
                  <StackPanel Spacing="{StaticResource Space.2}">
                    <TextBlock Classes="SectionTitle"
                               Text="项目概览" />
                    <TextBlock Classes="CaptionText"
                               Text="当前项目的调试资产会按项目隔离保存。" />
                    <TextBlock Text="{Binding ProjectPanel.SelectedProject.DisplayName}"
                               FontSize="{StaticResource Font.Size.BodyLarge}"
                               FontWeight="SemiBold" />
                    <TextBlock Classes="SubtleText"
                               Text="{Binding ProjectPanel.SelectedProject.SummaryText}"
                               TextWrapping="Wrap" />
                  </StackPanel>
                </Border>

                <Border Classes="PanelCard">
                  <StackPanel Spacing="{StaticResource Space.3}">
                    <Grid ColumnDefinitions="*,Auto">
                      <TextBlock Classes="SectionTitle"
                                 Text="环境概览" />
                      <Button Grid.Column="1"
                              Classes="SecondaryButton"
                              Content="管理"
                              Click="OnOpenEnvironmentDrawer" />
                    </Grid>
                    <TextBlock Classes="CaptionText"
                               Text="{Binding CurrentEnvironmentLabel}" />
                    <ItemsControl ItemsSource="{Binding EnvironmentPanel.Environments}">
                      <ItemsControl.ItemTemplate>
                        <DataTemplate x:DataType="vm:ProjectEnvironmentItemViewModel">
                          <Border Classes="MiniInfoCard">
                            <Grid ColumnDefinitions="*,Auto">
                              <StackPanel Spacing="2">
                                <TextBlock Text="{Binding Name}"
                                           FontWeight="SemiBold" />
                                <TextBlock Classes="CaptionText"
                                           Text="{Binding BaseUrl}" />
                              </StackPanel>
                              <u:Badge Grid.Column="1"
                                       Header="激活"
                                       IsVisible="{Binding IsActive}"
                                       iri:ClassHelper.Classes="Light Success" />
                            </Grid>
                          </Border>
                        </DataTemplate>
                      </ItemsControl.ItemTemplate>
                    </ItemsControl>
                  </StackPanel>
                </Border>

                <Border Classes="PanelCard">
                  <StackPanel Spacing="{StaticResource Space.3}">
                    <Grid ColumnDefinitions="*,Auto">
                      <TextBlock Classes="SectionTitle"
                                 Text="常用用例" />
                      <Button Grid.Column="1"
                              Classes="SecondaryButton"
                              Content="管理"
                              Click="OnOpenUseCasesDrawer" />
                    </Grid>

                    <ListBox Classes="FlatListBox"
                             ItemsSource="{Binding UseCasesPanel.RequestCases}"
                             SelectedItem="{Binding UseCasesPanel.SelectedRequestCase}"
                             MaxHeight="280">
                      <ListBox.ItemTemplate>
                        <DataTemplate x:DataType="vm:RequestCaseItemViewModel">
                          <StackPanel Spacing="2">
                            <TextBlock Text="{Binding Name}" />
                            <TextBlock Classes="CaptionText"
                                       Text="{Binding GroupName}" />
                            <TextBlock Classes="CaptionText"
                                       Text="{Binding UpdatedAt, StringFormat='更新于 {0:yyyy-MM-dd HH:mm}'}" />
                          </StackPanel>
                        </DataTemplate>
                      </ListBox.ItemTemplate>
                    </ListBox>

                    <Button Classes="PrimaryButton"
                            Content="加载选中用例"
                            Command="{Binding UseCasesPanel.LoadSelectedCaseCommand}" />
                  </StackPanel>
                </Border>
              </StackPanel>
            </ScrollViewer>

            <Grid Grid.Column="1"
                  RowDefinitions="Auto,Auto,*"
                  RowSpacing="{StaticResource Space.3}">
              <Grid ColumnDefinitions="110,*,Auto,Auto"
                    ColumnSpacing="{StaticResource Space.2}">
                <ComboBox Grid.Column="0"
                          Classes="MethodSelector"
                          ItemsSource="{Binding HttpMethods}"
                          SelectedItem="{Binding SelectedMethod}" />
                <TextBox Grid.Column="1"
                         Classes="UrlInput"
                         Watermark="输入完整地址或相对路径"
                         Text="{Binding RequestUrl}" />
                <Button Grid.Column="2"
                        Classes="SecondaryButton"
                        Content="保存为用例"
                        Command="{Binding SaveCaseCommand}" />
                <Button Grid.Column="3"
                        Classes="SendButton"
                        Content="发送"
                        Command="{Binding SendRequestCommand}"
                        IsEnabled="{Binding HasEnvironmentContext}" />
              </Grid>

              <Border Grid.Row="1"
                      Classes="PanelCard"
                      Padding="0">
                <TabControl Classes="ConfigTabControl"
                            SelectedIndex="{Binding ConfigTab.SelectedTabIndex}"
                            MinHeight="252">
                  <TabItem Header="Params">
                    <DockPanel Margin="{StaticResource Pad.3}">
                      <Border DockPanel.Dock="Top"
                              Classes="ParameterHeader">
                        <Grid ColumnDefinitions="*,*,Auto">
                          <TextBlock Grid.Column="0"
                                     Classes="CaptionText"
                                     Text="参数名" />
                          <TextBlock Grid.Column="1"
                                     Classes="CaptionText"
                                     Text="参数值" />
                        </Grid>
                      </Border>
                      <Button DockPanel.Dock="Bottom"
                              Classes="AddButton"
                              HorizontalAlignment="Left"
                              Margin="0,8,0,0"
                              Content="+ 添加参数"
                              Command="{Binding ConfigTab.AddQueryParameterCommand}" />
                      <ScrollViewer>
                        <ItemsControl ItemsSource="{Binding ConfigTab.QueryParameters}">
                          <ItemsControl.ItemTemplate>
                            <DataTemplate x:DataType="vm:RequestParameterItemViewModel">
                              <Border Classes="ParameterRow">
                                <Grid ColumnDefinitions="*,*,Auto"
                                      ColumnSpacing="{StaticResource Space.2}">
                                  <TextBox Grid.Column="0"
                                           Classes="ParameterInput"
                                           Text="{Binding Name}"
                                           Watermark="参数名" />
                                  <TextBox Grid.Column="1"
                                           Classes="ParameterInput"
                                           Text="{Binding Value}"
                                           Watermark="参数值" />
                                  <u:IconButton Grid.Column="2"
                                                Classes="Danger"
                                                Theme="{DynamicResource BorderlessIconButton}"
                                                Icon="{StaticResource SemiIconDelete}"
                                                Command="{Binding $parent[Window].((vm:MainWindowViewModel)DataContext).ConfigTab.RemoveParameterCommand}"
                                                CommandParameter="{Binding}" />
                                </Grid>
                              </Border>
                            </DataTemplate>
                          </ItemsControl.ItemTemplate>
                        </ItemsControl>
                      </ScrollViewer>
                    </DockPanel>
                  </TabItem>

                  <TabItem Header="Body">
                    <DockPanel Margin="{StaticResource Pad.3}">
                      <u:SelectionList DockPanel.Dock="Top"
                                       ItemsSource="{Binding ConfigTab.BodyModeOptions}"
                                       SelectedItem="{Binding ConfigTab.SelectedBodyModeOption}"
                                       Margin="0,0,0,12">
                        <u:SelectionList.ItemsPanel>
                          <ItemsPanelTemplate>
                            <StackPanel Orientation="Horizontal" />
                          </ItemsPanelTemplate>
                        </u:SelectionList.ItemsPanel>
                        <u:SelectionList.ItemTemplate>
                          <DataTemplate x:DataType="vm:BodyModeOptionViewModel">
                            <Border Padding="{StaticResource Pad.2}">
                              <TextBlock Text="{Binding DisplayName}" />
                            </Border>
                          </DataTemplate>
                        </u:SelectionList.ItemTemplate>
                      </u:SelectionList>

                      <DockPanel IsVisible="{Binding ConfigTab.IsBodyModeFormData}">
                        <Border DockPanel.Dock="Top"
                                Classes="ParameterHeader">
                          <Grid ColumnDefinitions="2*,3*,Auto">
                            <TextBlock Grid.Column="0"
                                       Classes="CaptionText"
                                       Text="字段名" />
                            <TextBlock Grid.Column="1"
                                       Classes="CaptionText"
                                       Text="字段值" />
                          </Grid>
                        </Border>
                        <Button DockPanel.Dock="Bottom"
                                Classes="AddButton"
                                HorizontalAlignment="Left"
                                Margin="0,8,0,0"
                                Content="+ 添加字段"
                                Command="{Binding ConfigTab.AddFormFieldCommand}" />
                        <ScrollViewer>
                          <ItemsControl ItemsSource="{Binding ConfigTab.FormFields}">
                            <ItemsControl.ItemTemplate>
                              <DataTemplate x:DataType="vm:RequestParameterItemViewModel">
                                <Border Classes="ParameterRow">
                                  <Grid ColumnDefinitions="2*,3*,Auto"
                                        ColumnSpacing="{StaticResource Space.2}">
                                    <TextBox Grid.Column="0"
                                             Classes="ParameterInput"
                                             Text="{Binding Name}"
                                             Watermark="字段名" />
                                    <TextBox Grid.Column="1"
                                             Classes="ParameterInput"
                                             Text="{Binding Value}"
                                             Watermark="字段值" />
                                    <u:IconButton Grid.Column="2"
                                                  Classes="Danger"
                                                  Theme="{DynamicResource BorderlessIconButton}"
                                                  Icon="{StaticResource SemiIconDelete}"
                                                  Command="{Binding $parent[Window].((vm:MainWindowViewModel)DataContext).ConfigTab.RemoveParameterCommand}"
                                                  CommandParameter="{Binding}" />
                                  </Grid>
                                </Border>
                              </DataTemplate>
                            </ItemsControl.ItemTemplate>
                          </ItemsControl>
                        </ScrollViewer>
                      </DockPanel>

                      <Border IsVisible="{Binding ConfigTab.HasRawBodyEditor}"
                              Classes="RawEditorCard">
                        <TextBox AcceptsReturn="True"
                                 BorderThickness="0"
                                 Background="Transparent"
                                 TextWrapping="Wrap"
                                 VerticalContentAlignment="Top"
                                 Watermark="{Binding ConfigTab.RequestBodyWatermark}"
                                 Text="{Binding ConfigTab.RequestBody}"
                                 FontFamily="{StaticResource Font.Monospace}" />
                      </Border>
                    </DockPanel>
                  </TabItem>

                  <TabItem Header="Headers">
                    <DockPanel Margin="{StaticResource Pad.3}">
                      <Border DockPanel.Dock="Top"
                              Classes="ParameterHeader">
                        <Grid ColumnDefinitions="*,*,Auto">
                          <TextBlock Grid.Column="0"
                                     Classes="CaptionText"
                                     Text="Header 名" />
                          <TextBlock Grid.Column="1"
                                     Classes="CaptionText"
                                     Text="Header 值" />
                        </Grid>
                      </Border>
                      <Button DockPanel.Dock="Bottom"
                              Classes="AddButton"
                              HorizontalAlignment="Left"
                              Margin="0,8,0,0"
                              Content="+ 添加 Header"
                              Command="{Binding ConfigTab.AddHeaderCommand}" />
                      <ScrollViewer>
                        <ItemsControl ItemsSource="{Binding ConfigTab.Headers}">
                          <ItemsControl.ItemTemplate>
                            <DataTemplate x:DataType="vm:RequestParameterItemViewModel">
                              <Border Classes="ParameterRow">
                                <Grid ColumnDefinitions="*,*,Auto"
                                      ColumnSpacing="{StaticResource Space.2}">
                                  <TextBox Grid.Column="0"
                                           Classes="ParameterInput"
                                           Text="{Binding Name}"
                                           Watermark="Header 名" />
                                  <TextBox Grid.Column="1"
                                           Classes="ParameterInput"
                                           Text="{Binding Value}"
                                           Watermark="Header 值" />
                                  <u:IconButton Grid.Column="2"
                                                Classes="Danger"
                                                Theme="{DynamicResource BorderlessIconButton}"
                                                Icon="{StaticResource SemiIconDelete}"
                                                Command="{Binding $parent[Window].((vm:MainWindowViewModel)DataContext).ConfigTab.RemoveParameterCommand}"
                                                CommandParameter="{Binding}" />
                                </Grid>
                              </Border>
                            </DataTemplate>
                          </ItemsControl.ItemTemplate>
                        </ItemsControl>
                      </ScrollViewer>
                    </DockPanel>
                  </TabItem>
                </TabControl>
              </Border>

              <Border Grid.Row="2"
                      Classes="PanelCard">
                <DockPanel>
                  <Grid DockPanel.Dock="Top"
                        ColumnDefinitions="*,Auto,Auto"
                        Margin="0,0,0,8">
                    <TextBlock Classes="SectionTitle"
                               Text="响应结果" />
                    <TextBlock Grid.Column="1"
                               Classes="CaptionText"
                               Text="{Binding CurrentEnvironmentLabel}"
                               VerticalAlignment="Center" />
                  </Grid>

                  <StackPanel IsVisible="{Binding ResponseSection.ShowPlaceholder}"
                              HorizontalAlignment="Center"
                              VerticalAlignment="Center"
                              Spacing="{StaticResource Space.2}">
                    <TextBlock Classes="SubtleText"
                               Text="发送请求后在这里查看响应内容" />
                  </StackPanel>

                  <Grid IsVisible="{Binding ResponseSection.HasResponse}"
                        RowDefinitions="Auto,*"
                        RowSpacing="{StaticResource Space.2}">
                    <Grid ColumnDefinitions="Auto,Auto,Auto,*"
                          ColumnSpacing="{StaticResource Space.3}">
                      <u:Badge Grid.Column="0"
                               Header="{Binding ResponseSection.StatusText}"
                               iri:ClassHelper.Classes="{Binding ResponseSection.StatusBadgeClass}" />
                      <TextBlock Grid.Column="1"
                                 Classes="CaptionText"
                                 Text="{Binding ResponseSection.DurationText}" />
                      <TextBlock Grid.Column="2"
                                 Classes="CaptionText"
                                 Text="{Binding ResponseSection.SizeText}" />
                    </Grid>

                    <TabControl Grid.Row="1"
                                Classes="ResponseTabs"
                                SelectedIndex="{Binding ResponseSection.SelectedResponseTab}">
                      <TabItem Header="Body">
                        <TextBox AcceptsReturn="True"
                                 BorderThickness="0"
                                 Background="Transparent"
                                 IsReadOnly="True"
                                 TextWrapping="Wrap"
                                 VerticalContentAlignment="Top"
                                 Text="{Binding ResponseSection.BodyText}"
                                 FontFamily="{StaticResource Font.Monospace}" />
                      </TabItem>
                      <TabItem Header="Headers">
                        <TextBox AcceptsReturn="True"
                                 BorderThickness="0"
                                 Background="Transparent"
                                 IsReadOnly="True"
                                 TextWrapping="Wrap"
                                 VerticalContentAlignment="Top"
                                 Text="{Binding ResponseSection.HeadersText}"
                                 FontFamily="{StaticResource Font.Monospace}" />
                      </TabItem>
                    </TabControl>
                  </Grid>
                </DockPanel>
              </Border>
            </Grid>
          </Grid>

          <Border Grid.Row="1"
                  Classes="PanelCard"
                  IsVisible="{Binding ShowHistorySection}">
            <Grid RowDefinitions="Auto,*"
                  RowSpacing="{StaticResource Space.3}">
              <Grid ColumnDefinitions="*,Auto">
                <StackPanel Spacing="2">
                  <TextBlock Classes="SectionTitle"
                             Text="项目历史记录" />
                  <TextBlock Classes="CaptionText"
                             Text="这里展示当前项目下已发送的请求，可再次载入或转存为用例。" />
                </StackPanel>
                <u:PopConfirm Grid.Column="1"
                              PopupHeader="确认清空当前项目的请求历史？"
                              PopupContent="清空后无法恢复。"
                              ConfirmCommand="{Binding ClearHistoryCommand}">
                  <Button Classes="SecondaryButton"
                          Content="清空历史" />
                </u:PopConfirm>
              </Grid>

              <ScrollViewer Grid.Row="1">
                <ItemsControl ItemsSource="{Binding RequestHistory}">
                  <ItemsControl.ItemTemplate>
                    <DataTemplate x:DataType="vm:RequestHistoryItemViewModel">
                      <Border Classes="HistoryItemCard"
                              Margin="0,0,0,12"
                              Padding="{StaticResource Pad.3}">
                        <Grid RowDefinitions="Auto,Auto,Auto"
                              RowSpacing="{StaticResource Space.2}">
                          <Grid ColumnDefinitions="Auto,*,Auto"
                                ColumnSpacing="{StaticResource Space.2}">
                            <u:Badge Grid.Column="0"
                                     Header="{Binding Method}"
                                     iri:ClassHelper.Classes="{Binding MethodBadgeClass}" />
                            <TextBlock Grid.Column="1"
                                       Text="{Binding Url}"
                                       TextTrimming="CharacterEllipsis" />
                            <TextBlock Grid.Column="2"
                                       Classes="CaptionText"
                                       Text="{Binding Timestamp, StringFormat='{}{0:yyyy-MM-dd HH:mm}'}" />
                          </Grid>

                          <Grid Grid.Row="1"
                                ColumnDefinitions="Auto,Auto,Auto,*"
                                ColumnSpacing="{StaticResource Space.2}">
                            <u:Badge Grid.Column="0"
                                     Header="{Binding StatusText}"
                                     IsVisible="{Binding HasResponse}"
                                     iri:ClassHelper.Classes="{Binding StatusBadgeClass}" />
                            <TextBlock Grid.Column="1"
                                       Classes="CaptionText"
                                       IsVisible="{Binding HasResponse}"
                                       Text="{Binding DurationText}" />
                            <TextBlock Grid.Column="2"
                                       Classes="CaptionText"
                                       IsVisible="{Binding HasResponse}"
                                       Text="{Binding SizeText}" />
                          </Grid>

                          <StackPanel Grid.Row="2"
                                      Orientation="Horizontal"
                                      Spacing="{StaticResource Space.2}">
                            <Button Classes="SecondaryButton"
                                    Content="载入请求"
                                    Command="{Binding $parent[Window].((vm:MainWindowViewModel)DataContext).LoadHistoryItemCommand}"
                                    CommandParameter="{Binding}" />
                            <Button Classes="SecondaryButton"
                                    Content="保存为用例"
                                    Command="{Binding $parent[Window].((vm:MainWindowViewModel)DataContext).SaveHistoryAsCaseCommand}"
                                    CommandParameter="{Binding}" />
                          </StackPanel>
                        </Grid>
                      </Border>
                    </DataTemplate>
                  </ItemsControl.ItemTemplate>
                </ItemsControl>
              </ScrollViewer>
            </Grid>
          </Border>

          <Grid Grid.Row="1"
                IsVisible="{Binding ShowProjectSettingsSection}"
                ColumnDefinitions="1.6*,*"
                ColumnSpacing="{StaticResource Space.4}">
            <Border Grid.Column="0"
                    Classes="PanelCard">
              <StackPanel Spacing="{StaticResource Space.3}">
                <TextBlock Classes="SectionTitle"
                           Text="项目设置" />
                <TextBlock Classes="CaptionText"
                           Text="在这里维护项目名称、项目说明和默认项目设置。" />

                <u:Form LabelPosition="Top">
                  <TextBox Classes="SectionInput"
                           u:FormItem.Label="项目名称"
                           Text="{Binding ProjectPanel.SelectedProject.Name}" />
                  <TextBox Classes="SectionInput"
                           u:FormItem.Label="项目说明"
                           AcceptsReturn="True"
                           Height="128"
                           TextWrapping="Wrap"
                           Text="{Binding ProjectPanel.SelectedProject.Description}" />
                </u:Form>

                <Grid ColumnDefinitions="*,*,*"
                      ColumnSpacing="{StaticResource Space.2}">
                  <Button Grid.Column="0"
                          Classes="SecondaryButton"
                          Content="设为默认"
                          Command="{Binding ProjectPanel.SetSelectedProjectAsDefaultCommand}" />
                  <Button Grid.Column="1"
                          Classes="PrimaryButton"
                          Content="保存项目"
                          Command="{Binding ProjectPanel.SaveSelectedProjectCommand}" />
                  <u:PopConfirm Grid.Column="2"
                                PopupHeader="确认删除当前项目？"
                                PopupContent="该项目下的环境、历史和用例都会一并删除。"
                                ConfirmCommand="{Binding ProjectPanel.DeleteSelectedProjectCommand}">
                    <Button Classes="SecondaryButton"
                            Content="删除项目" />
                  </u:PopConfirm>
                </Grid>
              </StackPanel>
            </Border>

            <StackPanel Grid.Column="1"
                        Spacing="{StaticResource Space.3}">
              <Border Classes="PanelCard">
                <StackPanel Spacing="{StaticResource Space.3}">
                  <TextBlock Classes="SectionTitle"
                             Text="环境与变量" />
                  <TextBlock Classes="CaptionText"
                             Text="环境和变量继续通过右上角环境入口管理，保持项目级隔离。" />
                  <Button Classes="PrimaryButton"
                          Content="打开环境管理"
                          Click="OnOpenEnvironmentDrawer" />
                </StackPanel>
              </Border>

              <Border Classes="PanelCard">
                <StackPanel Spacing="{StaticResource Space.3}">
                  <TextBlock Classes="SectionTitle"
                             Text="请求用例" />
                  <TextBlock Classes="CaptionText"
                             Text="用例通过抽屉集中维护，也可以从历史记录中快速转存。" />
                  <Button Classes="SecondaryButton"
                          Content="打开用例管理"
                          Click="OnOpenUseCasesDrawer" />
                </StackPanel>
              </Border>
            </StackPanel>
          </Grid>
        </Grid>
      </Grid>

      <Border Classes="NotificationFlyoutCard"
              IsVisible="{Binding IsNotificationCenterOpen}"
              HorizontalAlignment="Right"
              VerticalAlignment="Top"
              Margin="0,16,160,0">
        <Grid RowDefinitions="Auto,*,Auto"
              RowSpacing="{StaticResource Space.3}">
          <Grid ColumnDefinitions="*,Auto">
            <StackPanel Spacing="2">
              <TextBlock Classes="SectionTitle"
                         Text="通知中心" />
              <TextBlock Classes="CaptionText"
                         Text="近期更新和系统提醒都会显示在这里。" />
            </StackPanel>
            <Button Grid.Column="1"
                    Classes="DialogIconButton"
                    Command="{Binding MarkAllNotificationsReadCommand}"
                    Content="全部已读" />
          </Grid>

          <ItemsControl Grid.Row="1"
                        ItemsSource="{Binding Notifications}">
            <ItemsControl.ItemTemplate>
              <DataTemplate x:DataType="vm:NotificationItemViewModel">
                <Border Classes="NotificationItemCard">
                  <Grid ColumnDefinitions="Auto,*"
                        ColumnSpacing="{StaticResource Space.3}">
                    <Border Width="10"
                            Height="10"
                            Classes="NotificationItemDot"
                            IsVisible="{Binding IsUnread}" />
                    <StackPanel Grid.Column="1"
                                Spacing="4">
                      <Grid ColumnDefinitions="*,Auto"
                            ColumnSpacing="{StaticResource Space.2}">
                        <TextBlock Text="{Binding Title}"
                                   FontWeight="SemiBold" />
                        <TextBlock Grid.Column="1"
                                   Classes="CaptionText"
                                   Text="{Binding RelativeTimeText}" />
                      </Grid>
                      <TextBlock Classes="CaptionText"
                                 Text="{Binding Message}"
                                 TextWrapping="Wrap" />
                    </StackPanel>
                  </Grid>
                </Border>
              </DataTemplate>
            </ItemsControl.ItemTemplate>
          </ItemsControl>

          <TextBlock Grid.Row="2"
                     Classes="CaptionText"
                     Text="点击铃铛可再次收起此面板。" />
        </Grid>
      </Border>

      <Border Classes="SettingsDialogBackdrop"
              IsVisible="{Binding IsSettingsDialogOpen}">
        <Grid HorizontalAlignment="Center"
              VerticalAlignment="Center">
          <Border Classes="SettingsDialogCard">
            <Grid ColumnDefinitions="220,*"
                  RowDefinitions="*">
              <Border Classes="SettingsSidebar">
                <StackPanel Spacing="{StaticResource Space.2}">
                  <TextBlock Classes="SectionTitle"
                             Text="设置中心" />
                  <TextBlock Classes="CaptionText"
                             Text="先保留通用和关于两个分组。" />

                  <ToggleButton Classes="SettingsNavButton"
                                Command="{Binding ShowGeneralSettingsCommand}"
                                IsChecked="{Binding ShowGeneralSettingsSection, Mode=OneWay}">
                    <TextBlock Text="通用" />
                  </ToggleButton>

                  <ToggleButton Classes="SettingsNavButton"
                                Command="{Binding ShowAboutSettingsCommand}"
                                IsChecked="{Binding ShowAboutSettingsSection, Mode=OneWay}">
                    <TextBlock Text="关于" />
                  </ToggleButton>
                </StackPanel>
              </Border>

              <Grid Grid.Column="1"
                    RowDefinitions="Auto,*"
                    RowSpacing="{StaticResource Space.4}"
                    Margin="{StaticResource Pad.5}">
                <Grid ColumnDefinitions="*,Auto">
                  <StackPanel Spacing="2">
                    <TextBlock Classes="PageTitle"
                               Text="{Binding CurrentSettingsTitle}" />
                    <TextBlock Classes="CaptionText"
                               Text="设置会自动保存到本地工作目录，并在后续请求中生效。" />
                  </StackPanel>
                  <Button Grid.Column="1"
                          Classes="DialogIconButton"
                          Command="{Binding CloseSettingsDialogCommand}"
                          Content="×" />
                </Grid>

                <ScrollViewer Grid.Row="1">
                  <StackPanel>
                    <Grid RowDefinitions="Auto,Auto"
                          IsVisible="{Binding ShowGeneralSettingsSection}"
                          RowSpacing="{StaticResource Space.4}">
                    <Border Classes="SettingsPageSection">
                      <Grid ColumnDefinitions="*,Auto"
                            ColumnSpacing="{StaticResource Space.4}">
                        <StackPanel Spacing="4">
                          <TextBlock Classes="SettingsGroupTitle"
                                     Text="请求超时时间" />
                          <TextBlock Classes="CaptionText"
                                     Text="输入 0 表示不限时，其余值会作为请求超时毫秒数。" />
                        </StackPanel>
                        <NumericUpDown Grid.Column="1"
                                       Classes="SettingsNumberInput"
                                       Minimum="0"
                                       Maximum="120000"
                                       Increment="1000"
                                       Value="{Binding RequestTimeoutMilliseconds}" />
                      </Grid>
                    </Border>

                    <StackPanel Grid.Row="1"
                                Spacing="{StaticResource Space.3}">
                      <Border Classes="SettingsPageSection">
                        <Grid ColumnDefinitions="*,Auto"
                              ColumnSpacing="{StaticResource Space.4}">
                          <StackPanel Spacing="4">
                            <TextBlock Classes="SettingsGroupTitle"
                                       Text="SSL 证书验证" />
                            <TextBlock Classes="CaptionText"
                                       Text="关闭后会忽略证书校验，适合本地或自签名环境调试。" />
                          </StackPanel>
                          <ToggleSwitch Grid.Column="1"
                                        IsChecked="{Binding ValidateSslCertificate}" />
                        </Grid>
                      </Border>

                      <Border Classes="SettingsPageSection">
                        <Grid ColumnDefinitions="*,Auto"
                              ColumnSpacing="{StaticResource Space.4}">
                          <StackPanel Spacing="4">
                            <TextBlock Classes="SettingsGroupTitle"
                                       Text="自动跟随重定向" />
                            <TextBlock Classes="CaptionText"
                                       Text="开启后，请求会自动处理 3xx 跳转响应。" />
                          </StackPanel>
                          <ToggleSwitch Grid.Column="1"
                                        IsChecked="{Binding AutoFollowRedirects}" />
                        </Grid>
                      </Border>

                      <Border Classes="SettingsPageSection">
                        <Grid ColumnDefinitions="*,Auto"
                              ColumnSpacing="{StaticResource Space.4}">
                          <StackPanel Spacing="4">
                            <TextBlock Classes="SettingsGroupTitle"
                                       Text="发送无缓存头" />
                            <TextBlock Classes="CaptionText"
                                       Text="开启后会自动补充 no-cache / no-store 请求头。" />
                          </StackPanel>
                          <ToggleSwitch Grid.Column="1"
                                        IsChecked="{Binding SendNoCacheHeader}" />
                        </Grid>
                      </Border>

                      <Border Classes="SettingsPageSection">
                        <Grid ColumnDefinitions="*,Auto"
                              ColumnSpacing="{StaticResource Space.4}">
                          <StackPanel Spacing="4">
                            <TextBlock Classes="SettingsGroupTitle"
                                       Text="详细日志 (Verbose Logging)" />
                            <TextBlock Classes="CaptionText"
                                       Text="当前先保存为本地偏好项，后续会继续扩展到更完整的调试输出。" />
                          </StackPanel>
                          <ToggleSwitch Grid.Column="1"
                                        IsChecked="{Binding EnableVerboseLogging}" />
                        </Grid>
                      </Border>

                      <Border Classes="SettingsPageSection">
                        <Grid ColumnDefinitions="*,Auto"
                              ColumnSpacing="{StaticResource Space.4}">
                          <StackPanel Spacing="4">
                            <TextBlock Classes="SettingsGroupTitle"
                                       Text="新版本提醒" />
                            <TextBlock Classes="CaptionText"
                                       Text="控制是否在设置中心展示 mock 更新提示。" />
                          </StackPanel>
                          <ToggleSwitch Grid.Column="1"
                                        IsChecked="{Binding EnableUpdateReminder}" />
                        </Grid>
                      </Border>

                      <TextBlock Classes="CaptionText"
                                 Text="{Binding GeneralSettingsSaveStatus}" />
                    </StackPanel>
                    </Grid>

                    <Grid IsVisible="{Binding ShowAboutSettingsSection}">
                      <StackPanel Spacing="{StaticResource Space.4}">
                      <Border Classes="AboutHeroCard">
                        <Grid ColumnDefinitions="Auto,*"
                              ColumnSpacing="{StaticResource Space.4}">
                          <Border Width="88"
                                  Height="88"
                                  Classes="AboutIconBadge">
                            <Path Width="42"
                                  Height="42"
                                  HorizontalAlignment="Center"
                                  VerticalAlignment="Center"
                                  Fill="{DynamicResource Brush.Text.Inverse}"
                                  Data="M12,2 C17.5,2 22,6.5 22,12 C22,17.5 17.5,22 12,22 C6.5,22 2,17.5 2,12 C2,6.5 6.5,2 12,2 Z M7,8 L17,8 L17,10 L7,10 Z M7,12 L14,12 L14,14 L7,14 Z" />
                          </Border>

                          <StackPanel Grid.Column="1"
                                      Spacing="{StaticResource Space.2}"
                                      VerticalAlignment="Center">
                            <TextBlock Classes="HeroTitle"
                                       Text="{Binding AppDisplayName}" />
                            <TextBlock Classes="SubtleText"
                                       Text="{Binding CurrentAppVersion, StringFormat='当前版本 {0}'}" />
                            <TextBlock Classes="CaptionText"
                                       Text="{Binding LatestMockVersion, StringFormat='Mock 最新版本 {0}'}" />
                            <StackPanel Orientation="Horizontal"
                                        Spacing="{StaticResource Space.2}">
                              <Button Classes="PrimaryButton"
                                      Content="检查更新"
                                      Command="{Binding CheckForUpdatesCommand}" />
                              <Border Classes="VersionTag">
                                <TextBlock Classes="CaptionText"
                                           Text="Mock 通道" />
                              </Border>
                            </StackPanel>
                          </StackPanel>
                        </Grid>
                      </Border>

                      <Border Classes="SettingsPageSection">
                        <StackPanel Spacing="{StaticResource Space.2}">
                          <TextBlock Classes="SettingsGroupTitle"
                                     Text="更新状态" />
                          <TextBlock Classes="CaptionText"
                                     Text="{Binding AboutUpdateStatus}" />
                          <TextBlock Classes="CaptionText"
                                     Text="{Binding LastUpdateCheckText, StringFormat='最近检查：{0}'}" />
                        </StackPanel>
                      </Border>

                      <Border Classes="SettingsPageSection">
                        <StackPanel Spacing="{StaticResource Space.2}">
                          <TextBlock Classes="SettingsGroupTitle"
                                     Text="软件信息" />
                          <TextBlock Classes="CaptionText"
                                     Text="{Binding AppDisplayName, StringFormat='软件名称：{0}'}" />
                          <TextBlock Classes="CaptionText"
                                     Text="{Binding CurrentAppVersion, StringFormat='版本号：{0}'}" />
                          <TextBlock Classes="CaptionText"
                                     Text="{Binding RuntimeStackText, StringFormat='技术栈：{0}'}" />
                          <TextBlock Classes="CaptionText"
                                     Text="本地数据：SQLite / 项目级工作目录隔离" />
                        </StackPanel>
                      </Border>
                      </StackPanel>
                    </Grid>
                  </StackPanel>
                </ScrollViewer>
              </Grid>
            </Grid>
          </Border>
        </Grid>
      </Border>

      <Border Classes="CreateProjectDialogBackdrop"
              IsVisible="{Binding IsCreateProjectDialogOpen}">
        <Grid HorizontalAlignment="Center"
              VerticalAlignment="Center">
          <Border Classes="CreateProjectDialogCard">
            <Grid RowDefinitions="Auto,Auto,Auto"
                  RowSpacing="{StaticResource Space.3}">
              <StackPanel Spacing="2">
                <TextBlock Classes="DialogTitle"
                           Text="新建项目" />
                <TextBlock Classes="CaptionText"
                           Text="只需要填写项目名称和备注信息。创建后会自动生成该项目的默认环境。" />
              </StackPanel>

              <Border Grid.Row="1"
                      Classes="CreateProjectFormShell">
                <u:Form LabelPosition="Top">
                  <TextBox Classes="SectionInput DialogInput"
                           u:FormItem.Label="项目名称"
                           Watermark="请输入项目名称"
                           Text="{Binding ProjectPanel.DraftProjectName}" />
                  <TextBox Classes="SectionInput DialogInput"
                           u:FormItem.Label="备注信息"
                           AcceptsReturn="True"
                           Height="112"
                           TextWrapping="Wrap"
                           Watermark="补充项目用途、团队或说明"
                           Text="{Binding ProjectPanel.DraftProjectDescription}" />
                </u:Form>
              </Border>

              <StackPanel Grid.Row="2"
                          Orientation="Horizontal"
                          HorizontalAlignment="Right"
                          Spacing="{StaticResource Space.2}">
                <Button Classes="DialogSecondaryButton"
                        Content="取消"
                        Command="{Binding CloseCreateProjectDialogCommand}" />
                <Button Classes="DialogPrimaryButton"
                        Content="创建项目"
                        Command="{Binding ProjectPanel.CreateProjectCommand}" />
              </StackPanel>
            </Grid>
          </Border>
        </Grid>
      </Border>

      <u:OverlayDialogHost />
    </Grid>
  </Grid>
</Window>
