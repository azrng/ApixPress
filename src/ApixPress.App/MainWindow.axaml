<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:iri="https://irihi.tech/shared"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:u="https://irihi.tech/ursa"
        xmlns:vm="using:ApixPress.App.ViewModels"
        mc:Ignorable="d"
        d:DesignWidth="1440"
        d:DesignHeight="920"
        x:Class="ApixPress.App.MainWindow"
        x:Name="RootWindow"
        x:DataType="vm:MainWindowViewModel"
        Width="1440"
        Height="920"
        MinWidth="1280"
        MinHeight="800"
        WindowState="Maximized"
        SystemDecorations="None"
        ExtendClientAreaToDecorationsHint="True"
        ExtendClientAreaChromeHints="NoChrome"
        Title="ApixPress">
  <Window.Resources>
    <DataTemplate x:Key="ProjectSidebarExplorerItemTemplate"
                  x:DataType="vm:ExplorerItemViewModel">
      <StackPanel Spacing="0">
        <StackPanel Orientation="Horizontal"
                    Spacing="1">
          <ToggleButton x:Name="ExplorerExpandToggle"
                        Classes="ProjectSidebarTreeExpanderToggle"
                        IsChecked="{Binding IsExpanded, Mode=TwoWay}"
                        IsVisible="{Binding HasChildren}">
            <Grid>
              <TextBlock Classes="ProjectSidebarCatalogChevron"
                         FontFamily="Segoe Fluent Icons, Segoe MDL2 Assets"
                         IsVisible="{Binding !#ExplorerExpandToggle.IsChecked}"
                         Text="&#xE76C;" />
              <TextBlock Classes="ProjectSidebarCatalogChevron"
                         FontFamily="Segoe Fluent Icons, Segoe MDL2 Assets"
                         IsVisible="{Binding #ExplorerExpandToggle.IsChecked}"
                         Text="&#xE70D;" />
            </Grid>
          </ToggleButton>
          <Border
                  Classes="ProjectSidebarTreeExpanderSpacer"
                  IsVisible="{Binding !HasChildren}" />

          <Button
                  Classes="WorkspaceTreeNodeButton"
                  IsHitTestVisible="{Binding IsClickable}"
                  Command="{Binding $parent[Window].((vm:MainWindowViewModel)DataContext).LoadSavedRequestCommand}"
                  CommandParameter="{Binding}">
            <StackPanel Spacing="1">
              <Grid ColumnDefinitions="Auto,Auto,*,Auto"
                    ColumnSpacing="2">
                <TextBlock Grid.Column="0"
                           Classes="WorkspaceTreeNodeGlyph"
                           FontFamily="Segoe Fluent Icons, Segoe MDL2 Assets"
                           Text="{Binding NodeGlyph}"
                           IsVisible="{Binding ShowLeadingGlyph}" />
                <TextBlock Grid.Column="0"
                           Classes="WorkspaceTreeNodeGlyph WorkspaceTreeCaseGlyph"
                           FontFamily="Segoe Fluent Icons, Segoe MDL2 Assets"
                           Text="{Binding NodeGlyph}"
                           IsVisible="{Binding IsHttpCaseNode}" />
                <u:Badge Grid.Column="1"
                         Margin="0,0,2,0"
                         Header="{Binding MethodBadgeText}"
                         IsVisible="{Binding ShowMethodBadge}"
                         iri:ClassHelper.Classes="{Binding MethodBadgeClass}" />
                <TextBlock Grid.Column="2"
                           Text="{Binding Title}"
                           VerticalAlignment="Center"
                           TextWrapping="Wrap" />
                <Border Grid.Column="3"
                        Classes="WorkspaceTreeStatusDot"
                        IsVisible="{Binding ShowTrailingDot}" />
              </Grid>
              <TextBlock Classes="CaptionText WorkspaceTreeSubtitleText"
                         Text="{Binding Subtitle}"
                         IsVisible="{Binding HasSubtitle}" />
            </StackPanel>
          </Button>
        </StackPanel>

        <ItemsControl Classes="ProjectSidebarInlineTreeChildren"
                      Margin="0,0,0,0"
                      ItemsSource="{Binding Children}"
                      IsVisible="{Binding IsExpanded}">
          <ItemsControl.ItemTemplate>
            <StaticResource ResourceKey="ProjectSidebarExplorerItemTemplate" />
          </ItemsControl.ItemTemplate>
        </ItemsControl>
      </StackPanel>
    </DataTemplate>
  </Window.Resources>
  <Grid RowDefinitions="Auto,*">
    <Border Grid.Row="0"
            Classes="TopBarCard AppTopBar"
            PointerPressed="OnTitleBarPointerPressed">
      <Grid ColumnDefinitions="Auto,Auto,*,Auto,Auto"
            ColumnSpacing="{StaticResource Space.3}">
        <StackPanel Grid.Column="0"
                    Orientation="Horizontal"
                    Spacing="{StaticResource Space.3}"
                    VerticalAlignment="Center">
          <Border Width="42"
                  Height="42"
                  Classes="AppIconBadge">
            <Path Width="20"
                  Height="20"
                  HorizontalAlignment="Center"
                  VerticalAlignment="Center"
                  Fill="{DynamicResource Brush.Border.Focus}"
                  Stretch="Uniform"
                  Data="M6,4 L18,4 C19.1,4 20,4.9 20,6 L20,18 C20,19.1 19.1,20 18,20 L6,20 C4.9,20 4,19.1 4,18 L4,6 C4,4.9 4.9,4 6,4 Z M8,8 L16,8 L16,10 L8,10 Z M8,12 L13,12 L13,14 L8,14 Z M8,16 L15,16 L15,18 L8,18 Z" />
          </Border>

          <TextBlock Classes="PageTitle"
                     VerticalAlignment="Center"
                     Text="ApixPress" />
        </StackPanel>

        <Border Grid.Column="1"
                Classes="TopTabStripShell">
          <ScrollViewer HorizontalScrollBarVisibility="Hidden"
                        VerticalScrollBarVisibility="Disabled">
            <StackPanel Orientation="Horizontal"
                        Spacing="{StaticResource Space.2}">
              <ToggleButton Classes="WorkspaceTabButton HomeTabButton"
                            Command="{Binding ActivateHomeTabCommand}"
                            IsChecked="{Binding IsHomeTabActive, Mode=OneWay}">
                <StackPanel Orientation="Horizontal"
                            Spacing="{StaticResource Space.2}">
                  <TextBlock Text="首页" />
                  <Border Classes="WorkspaceTabBadge">
                    <TextBlock Classes="CaptionText"
                               Text="{Binding ProjectPanel.Projects.Count}" />
                  </Border>
                </StackPanel>
              </ToggleButton>

              <ItemsControl ItemsSource="{Binding ProjectTabs}">
                <ItemsControl.ItemsPanel>
                  <ItemsPanelTemplate>
                    <StackPanel Orientation="Horizontal"
                                Spacing="{StaticResource Space.2}" />
                  </ItemsPanelTemplate>
                </ItemsControl.ItemsPanel>
                <ItemsControl.ItemTemplate>
                  <DataTemplate x:DataType="vm:ProjectTabViewModel">
                    <Border Classes="WorkspaceTabItemShell">
                      <Grid ColumnDefinitions="*,Auto"
                            ColumnSpacing="{StaticResource Space.2}">
                        <ToggleButton Grid.Column="0"
                                      Classes="WorkspaceTabButton"
                                      Command="{Binding $parent[Window].((vm:MainWindowViewModel)DataContext).ActivateProjectTabCommand}"
                                      CommandParameter="{Binding}"
                                      IsChecked="{Binding IsActive, Mode=OneWay}">
                          <StackPanel Orientation="Horizontal"
                                      Spacing="{StaticResource Space.2}">
                            <TextBlock Text="{Binding TabTitle}" />
                            <u:Badge Header="默认"
                                     IsVisible="{Binding Project.IsDefault}"
                                     iri:ClassHelper.Classes="Light Primary" />
                          </StackPanel>
                        </ToggleButton>
                        <Button Grid.Column="1"
                                Classes="WorkspaceTabCloseButton"
                                Command="{Binding $parent[Window].((vm:MainWindowViewModel)DataContext).CloseProjectTabCommand}"
                                CommandParameter="{Binding}"
                                Content="×" />
                      </Grid>
                    </Border>
                  </DataTemplate>
                </ItemsControl.ItemTemplate>
              </ItemsControl>
            </StackPanel>
          </ScrollViewer>
        </Border>

        <StackPanel Grid.Column="3"
                    Orientation="Horizontal"
                    Spacing="{StaticResource Space.1}"
                    VerticalAlignment="Center">
          <Button Classes="ShellIconButton"
                  Command="{Binding RefreshWorkspaceCommand}"
                  ToolTip.Tip="刷新">
            <Path Classes="ShellIconPath"
                  Data="M12,5 A7,7 0 1 0 19,12 M19,5 L19,9 L15,9" />
          </Button>
          <Button Classes="ShellIconButton"
                  Command="{Binding OpenSettingsDialogCommand}"
                  ToolTip.Tip="设置">
            <Path Classes="ShellIconPath"
                  Data="M12,8.5 A3.5,3.5 0 1 0 12,15.5 A3.5,3.5 0 1 0 12,8.5 M12,3 L13.2,3.3 L13.8,5 L15.5,5.5 L17,4.7 L18.3,6 L17.5,7.5 L18,9.2 L19.7,9.8 L20,11 L18.3,12.2 L18,13.8 L19.5,15 L18.3,16.3 L16.8,15.5 L15.2,16 L14.5,17.7 L13.3,18 L12,16.7 L10.7,18 L9.5,17.7 L8.8,16 L7.2,15.5 L5.7,16.3 L4.5,15 L6,13.8 L5.7,12.2 L4,11 L4.3,9.8 L6,9.2 L6.5,7.5 L5.7,6 L7,4.7 L8.5,5.5 L10.2,5 L10.8,3.3 Z" />
          </Button>
          <Button Classes="ShellIconButton"
                  Command="{Binding ToggleNotificationCenterCommand}"
                  ToolTip.Tip="通知">
            <Grid>
              <Path Classes="ShellIconPath"
                    Data="M12,4 C9.8,4 8,5.8 8,8 L8,10.7 C8,11.5 7.7,12.3 7.2,12.9 L6,14.3 L6,15 L18,15 L18,14.3 L16.8,12.9 C16.3,12.3 16,11.5 16,10.7 L16,8 C16,5.8 14.2,4 12,4 M10,17 A2,2 0 0 0 14,17" />
              <Border Width="8"
                      Height="8"
                      Classes="NotificationDot"
                      HorizontalAlignment="Right"
                      VerticalAlignment="Top"
                      IsVisible="{Binding HasUnreadNotifications}" />
            </Grid>
          </Button>
        </StackPanel>

        <StackPanel Grid.Column="4"
                    Orientation="Horizontal"
                    Spacing="0"
                    VerticalAlignment="Center">
          <Button Classes="WindowControlButton"
                  Click="OnMinimizeWindow">
            <TextBlock Classes="WindowControlGlyph"
                       Text="&#x2014;" />
          </Button>
          <Button Classes="WindowControlButton"
                  Click="OnToggleMaximizeWindow">
            <TextBlock Classes="WindowControlGlyph"
                       Text="{Binding WindowMaximizeGlyph}" />
          </Button>
          <Button Classes="WindowControlButton WindowCloseButton"
                  Click="OnCloseWindow">
            <TextBlock Classes="WindowControlGlyph"
                       Text="&#x00D7;" />
          </Button>
        </StackPanel>
      </Grid>
    </Border>

    <Grid Grid.Row="1">
      <ScrollViewer IsVisible="{Binding IsHomeTabActive}">
        <Grid Margin="{StaticResource Pad.6}"
              RowDefinitions="Auto,*"
              RowSpacing="{StaticResource Space.5}">
          <Border Classes="HomeHeroCard">
            <Grid RowDefinitions="Auto,Auto">
              <Grid ColumnDefinitions="*,Auto"
                    ColumnSpacing="{StaticResource Space.5}">
                <StackPanel Spacing="{StaticResource Space.2}">
                  <TextBlock Classes="HeroTitle"
                             Text="项目首页" />
                  <TextBlock Classes="SubtleText"
                             Text="默认打开这里查看全部项目。点击任意项目后，会在顶部以新标签页打开对应的快捷请求工作区。" />
                </StackPanel>
                <StackPanel Grid.Column="1"
                            Orientation="Horizontal"
                            Spacing="{StaticResource Space.3}"
                            VerticalAlignment="Center">
                  <Border Classes="DashboardStatCard">
                    <StackPanel Spacing="4">
                      <TextBlock Classes="CaptionText"
                                 Text="项目总数" />
                      <TextBlock Classes="SectionTitle"
                                 Text="{Binding ProjectPanel.Projects.Count}" />
                    </StackPanel>
                  </Border>
                  <Border Classes="DashboardStatCard">
                    <StackPanel Spacing="4">
                      <TextBlock Classes="CaptionText"
                                 Text="当前模式" />
                      <TextBlock Classes="SectionTitle"
                                 Text="多项目 Tab" />
                    </StackPanel>
                  </Border>
                </StackPanel>
              </Grid>

              <Border Grid.Row="1"
                      Classes="HomeOverviewToolbarSection">
                <Grid ColumnDefinitions="*,Auto"
                      ColumnSpacing="{StaticResource Space.4}">
                  <TextBlock Classes="SectionTitle"
                             VerticalAlignment="Center"
                             Text="项目列表" />
                  <Grid Grid.Column="1"
                        ColumnDefinitions="280,Auto"
                        ColumnSpacing="{StaticResource Space.2}">
                    <TextBox Grid.Column="0"
                             Classes="ToolbarSearchBox"
                             Watermark="搜索项目名称或备注"
                             Text="{Binding ProjectPanel.SearchText}" />
                    <Button Grid.Column="1"
                            Classes="PrimaryButton"
                            Content="新建项目"
                            Command="{Binding OpenCreateProjectDialogCommand}" />
                  </Grid>
                </Grid>
              </Border>
            </Grid>
          </Border>

          <Border Grid.Row="1"
                  Classes="EmptyStateCard"
                  IsVisible="{Binding ShowProjectListEmptyState}">
            <StackPanel Spacing="{StaticResource Space.3}"
                        HorizontalAlignment="Center">
              <TextBlock Classes="SectionTitle"
                         Text="还没有项目" />
              <TextBlock Classes="CaptionText"
                         Text="点击右上角“新建项目”，填写项目名称和备注后即可开始。" />
              <Button Classes="PrimaryButton"
                      HorizontalAlignment="Center"
                      Content="新建项目"
                      Command="{Binding OpenCreateProjectDialogCommand}" />
            </StackPanel>
          </Border>

          <Border Grid.Row="1"
                  Classes="ProjectGridHost"
                  IsVisible="{Binding ProjectPanel.HasProjects}">
            <ItemsControl ItemsSource="{Binding ProjectPanel.FilteredProjects}">
              <ItemsControl.ItemsPanel>
                <ItemsPanelTemplate>
                  <WrapPanel Orientation="Horizontal"
                             ItemWidth="332"
                             ItemHeight="264" />
                </ItemsPanelTemplate>
              </ItemsControl.ItemsPanel>
              <ItemsControl.ItemTemplate>
                <DataTemplate x:DataType="vm:ProjectWorkspaceItemViewModel">
                  <Button Classes="ProjectCardButton"
                          Command="{Binding $parent[Window].((vm:MainWindowViewModel)DataContext).OpenProjectWorkspaceCommand}"
                          CommandParameter="{Binding}">
                    <Border Classes="ProjectCard">
                      <Grid RowDefinitions="Auto,Auto,*,Auto"
                            RowSpacing="{StaticResource Space.4}">
                        <Border Classes="ProjectCardGlow" />
                        <Grid ColumnDefinitions="Auto,*,Auto"
                              ColumnSpacing="{StaticResource Space.3}">
                          <Border Width="56"
                                  Height="56"
                                  Classes="ProjectCardIcon">
                            <TextBlock Classes="ProjectAvatarText"
                                       Text="{Binding AvatarText}" />
                          </Border>
                          <StackPanel Grid.Column="1"
                                      Spacing="3"
                                      VerticalAlignment="Center">
                            <TextBlock Classes="ProjectCardTitle"
                                       Text="{Binding Name}" />
                            <TextBlock Classes="CaptionText"
                                       Text="点击后在顶部打开独立工作标签" />
                          </StackPanel>
                          <u:Badge Grid.Column="2"
                                   Header="默认"
                                   IsVisible="{Binding IsDefault}"
                                   iri:ClassHelper.Classes="Light Primary" />
                        </Grid>
                        <StackPanel Grid.Row="1"
                                    Orientation="Horizontal"
                                    Spacing="{StaticResource Space.2}">
                          <Border Classes="ProjectMetaPill">
                            <TextBlock Classes="CaptionText"
                                       Text="{Binding CategoryText}" />
                          </Border>
                          <Border Classes="ProjectMetaPill ProjectMetaPillMuted">
                            <TextBlock Classes="CaptionText"
                                       Text="快捷请求" />
                          </Border>
                          <Border Classes="ProjectMetaPill ProjectMetaPillMuted">
                            <TextBlock Classes="CaptionText"
                                       Text="环境隔离" />
                          </Border>
                        </StackPanel>
                        <TextBlock Grid.Row="2"
                                   Classes="ProjectCardSummary"
                                   Text="{Binding SummaryText}"
                                   TextWrapping="Wrap" />
                        <Grid Grid.Row="3"
                              ColumnDefinitions="*,Auto"
                              ColumnSpacing="{StaticResource Space.3}">
                          <StackPanel Spacing="2">
                            <TextBlock Classes="ProjectEntryHint"
                                       Text="打开后保留首页，不会替换当前列表。" />
                            <TextBlock Classes="CaptionText"
                                       Text="{Binding DisplayName}" />
                          </StackPanel>
                          <Border Grid.Column="1"
                                  Classes="ProjectEntryBadge">
                            <StackPanel Orientation="Horizontal"
                                        Spacing="6">
                              <TextBlock Classes="ProjectEntryBadgeText"
                                         Text="打开标签页" />
                              <TextBlock Classes="ProjectEntryBadgeText"
                                         Text="→" />
                            </StackPanel>
                          </Border>
                        </Grid>
                      </Grid>
                    </Border>
                  </Button>
                </DataTemplate>
              </ItemsControl.ItemTemplate>
            </ItemsControl>
          </Border>
        </Grid>
      </ScrollViewer>

      <Border IsVisible="{Binding HasActiveProjectTab}"
              Background="Transparent">
        <Grid DataContext="{Binding ActiveProjectTab}"
              x:DataType="vm:ProjectTabViewModel"
              Margin="{StaticResource Pad.5}"
              RowDefinitions="*">
          <Grid
                ColumnDefinitions="84,286,*"
                ColumnSpacing="{StaticResource Space.3}">
            <Border Grid.Column="0"
                    Classes="ProjectWorkspaceNavigationRail">
              <Grid VerticalAlignment="Top"
                    HorizontalAlignment="Center">
                <u:NavMenu Classes="ProjectWorkspaceNavMenu"
                           ExpandWidth="68"
                           CommandBinding="{Binding Command}"
                           HeaderBinding="{Binding}"
                           ItemsSource="{Binding WorkspaceNavigationItems}"
                           SelectedItem="{Binding SelectedWorkspaceNavigationItem, Mode=TwoWay}">
                  <u:NavMenu.HeaderTemplate>
                    <DataTemplate x:DataType="vm:ProjectWorkspaceNavItemViewModel">
                      <StackPanel HorizontalAlignment="Center"
                                  Spacing="6">
                        <Border Classes="ProjectWorkspaceNavIcon">
                          <Path Width="18"
                                Height="18"
                                Stretch="Uniform"
                                Fill="{DynamicResource Brush.Border.Focus}"
                                Data="{Binding IconData}" />
                        </Border>
                        <TextBlock Classes="ProjectWorkspaceNavText"
                                   Text="{Binding Title}"
                                   TextAlignment="Center"
                                   TextWrapping="Wrap" />
                      </StackPanel>
                    </DataTemplate>
                  </u:NavMenu.HeaderTemplate>
                </u:NavMenu>
              </Grid>
            </Border>

            <Border Grid.Column="1"
                    Classes="PanelCard ProjectWorkspaceSidebarCard">
              <Grid>
                <Grid IsVisible="{Binding IsInterfaceManagementSection}"
                      RowDefinitions="Auto,Auto,*"
                      RowSpacing="{StaticResource Space.3}">
                  <Grid ColumnDefinitions="*">
                    <StackPanel Spacing="4">
                      <TextBlock Classes="SectionTitle"
                                 Text="接口管理" />
                    </StackPanel>
                  </Grid>

                  <Grid Grid.Row="1"
                        ColumnDefinitions="*,Auto"
                        ColumnSpacing="{StaticResource Space.2}">
                    <TextBox Grid.Column="0"
                             Classes="ProjectSidebarSearchBox"
                             Watermark="搜索" />
                    <Button Grid.Column="1"
                            Classes="ProjectSidebarAddButton"
                            Command="{Binding OpenHttpInterfaceWorkspaceCommand}">
                      <TextBlock FontFamily="Segoe Fluent Icons, Segoe MDL2 Assets"
                                 Text="&#xE710;" />
                    </Button>
                  </Grid>

                  <ScrollViewer Grid.Row="2">
                    <StackPanel Spacing="{StaticResource Space.3}">
                      <Border Classes="ProjectSidebarSectionCard ProjectSidebarModuleSectionCard">
                        <StackPanel Classes="ProjectSidebarModuleGroup">
                          <Grid Classes="ProjectSidebarModuleHeader"
                                ColumnDefinitions="Auto,Auto,*"
                                ColumnSpacing="{StaticResource Space.2}">
                            <TextBlock Grid.Column="0"
                                       Classes="ProjectSidebarTreeChevron"
                                       FontFamily="Segoe Fluent Icons, Segoe MDL2 Assets"
                                       Text="&#xE70D;" />
                            <TextBlock Grid.Column="1"
                                       Classes="WorkspaceTreeNodeGlyph"
                                       FontFamily="Segoe Fluent Icons, Segoe MDL2 Assets"
                                       Text="&#xE8B7;" />
                            <TextBlock Grid.Column="2"
                                       Classes="ProjectSidebarSectionTitle"
                                       Text="默认模块" />
                          </Grid>
                          <StackPanel Classes="ProjectSidebarModuleChildren">
                            <ToggleButton x:Name="InterfaceCatalogToggle"
                                          Classes="ProjectSidebarCatalogToggleButton ProjectSidebarCatalogActiveButton ProjectSidebarCatalogFlatButton"
                                          IsChecked="{Binding IsInterfaceCatalogExpanded, Mode=TwoWay}">
                              <Grid ColumnDefinitions="Auto,Auto,*,Auto"
                                    ColumnSpacing="{StaticResource Space.2}">
                                <TextBlock Grid.Column="0"
                                           Classes="ProjectSidebarCatalogChevron"
                                           FontFamily="Segoe Fluent Icons, Segoe MDL2 Assets"
                                           IsVisible="{Binding !#InterfaceCatalogToggle.IsChecked}"
                                           Text="&#xE76C;" />
                                <TextBlock Grid.Column="0"
                                           Classes="ProjectSidebarCatalogChevron"
                                           FontFamily="Segoe Fluent Icons, Segoe MDL2 Assets"
                                           IsVisible="{Binding #InterfaceCatalogToggle.IsChecked}"
                                           Text="&#xE70D;" />
                                <TextBlock Grid.Column="1"
                                           Classes="WorkspaceTreeNodeGlyph"
                                           FontFamily="Segoe Fluent Icons, Segoe MDL2 Assets"
                                           Text="&#xE8C8;" />
                                <TextBlock Grid.Column="2"
                                           Classes="ProjectSidebarCatalogTitle"
                                           Text="接口" />
                                <TextBlock Grid.Column="3"
                                           Classes="ProjectSidebarCatalogChevron"
                                           FontFamily="Segoe Fluent Icons, Segoe MDL2 Assets"
                                           Text="&#xE70E;"
                                           IsVisible="False" />
                              </Grid>
                            </ToggleButton>

                            <Border Classes="ProjectSidebarCatalogBody"
                                    IsVisible="{Binding IsInterfaceCatalogExpanded}">
                              <StackPanel Classes="ProjectSidebarCatalogContent">
                                <TextBlock Classes="CaptionText ProjectSidebarEmptyHint"
                                           Text="当前还没有保存的 HTTP 接口"
                                           IsVisible="{Binding ShowInterfaceEntriesEmptyState}" />
                                <ItemsControl Classes="ProjectSidebarInlineTree"
                                              ItemsSource="{Binding InterfaceCatalogItems}">
                                  <ItemsControl.ItemTemplate>
                                    <StaticResource ResourceKey="ProjectSidebarExplorerItemTemplate" />
                                  </ItemsControl.ItemTemplate>
                                </ItemsControl>
                              </StackPanel>
                            </Border>

                            <ToggleButton x:Name="DataModelCatalogToggle"
                                          Classes="ProjectSidebarCatalogToggleButton"
                                          IsChecked="{Binding IsDataModelCatalogExpanded, Mode=TwoWay}">
                              <Grid ColumnDefinitions="Auto,*,Auto"
                                    ColumnSpacing="{StaticResource Space.2}">
                                <TextBlock Grid.Column="0"
                                           Classes="WorkspaceTreeNodeGlyph"
                                           FontFamily="Segoe Fluent Icons, Segoe MDL2 Assets"
                                           Text="&#xEC1A;" />
                                <TextBlock Grid.Column="1"
                                           Classes="ProjectSidebarSectionTitle"
                                           Text="数据模型" />
                                <TextBlock Grid.Column="2"
                                           Classes="ProjectSidebarCatalogChevron"
                                           FontFamily="Segoe Fluent Icons, Segoe MDL2 Assets"
                                           IsVisible="{Binding !#DataModelCatalogToggle.IsChecked}"
                                           Text="&#xE76C;" />
                                <TextBlock Grid.Column="2"
                                           Classes="ProjectSidebarCatalogChevron"
                                           FontFamily="Segoe Fluent Icons, Segoe MDL2 Assets"
                                           IsVisible="{Binding #DataModelCatalogToggle.IsChecked}"
                                           Text="&#xE70D;" />
                              </Grid>
                            </ToggleButton>

                            <ToggleButton x:Name="ComponentCatalogToggle"
                                          Classes="ProjectSidebarCatalogToggleButton"
                                          IsChecked="{Binding IsComponentLibraryCatalogExpanded, Mode=TwoWay}">
                              <Grid ColumnDefinitions="Auto,*,Auto"
                                    ColumnSpacing="{StaticResource Space.2}">
                                <TextBlock Grid.Column="0"
                                           Classes="WorkspaceTreeNodeGlyph"
                                           FontFamily="Segoe Fluent Icons, Segoe MDL2 Assets"
                                           Text="&#xE8FD;" />
                                <TextBlock Grid.Column="1"
                                           Classes="ProjectSidebarSectionTitle"
                                           Text="组件库" />
                                <TextBlock Grid.Column="2"
                                           Classes="ProjectSidebarCatalogChevron"
                                           FontFamily="Segoe Fluent Icons, Segoe MDL2 Assets"
                                           IsVisible="{Binding !#ComponentCatalogToggle.IsChecked}"
                                           Text="&#xE76C;" />
                                <TextBlock Grid.Column="2"
                                           Classes="ProjectSidebarCatalogChevron"
                                           FontFamily="Segoe Fluent Icons, Segoe MDL2 Assets"
                                           IsVisible="{Binding #ComponentCatalogToggle.IsChecked}"
                                           Text="&#xE70D;" />
                              </Grid>
                            </ToggleButton>
                          </StackPanel>
                        </StackPanel>
                      </Border>

                      <Border Classes="ProjectSidebarSectionCard">
                        <StackPanel Classes="ProjectSidebarTopLevelSection">
                          <ToggleButton x:Name="QuickRequestCatalogToggle"
                                        Classes="ProjectSidebarCatalogToggleButton ProjectSidebarCatalogFlatButton"
                                        IsChecked="{Binding IsQuickRequestCatalogExpanded, Mode=TwoWay}">
                            <Grid ColumnDefinitions="Auto,Auto,*,Auto"
                                  ColumnSpacing="{StaticResource Space.2}">
                              <TextBlock Grid.Column="0"
                                         Classes="ProjectSidebarCatalogChevron"
                                         FontFamily="Segoe Fluent Icons, Segoe MDL2 Assets"
                                         IsVisible="{Binding !#QuickRequestCatalogToggle.IsChecked}"
                                         Text="&#xE76C;" />
                              <TextBlock Grid.Column="0"
                                         Classes="ProjectSidebarCatalogChevron"
                                         FontFamily="Segoe Fluent Icons, Segoe MDL2 Assets"
                                         IsVisible="{Binding #QuickRequestCatalogToggle.IsChecked}"
                                         Text="&#xE70D;" />
                              <TextBlock Grid.Column="1"
                                         Classes="WorkspaceTreeNodeGlyph"
                                         FontFamily="Segoe Fluent Icons, Segoe MDL2 Assets"
                                         Text="&#xE945;" />
                              <TextBlock Grid.Column="2"
                                         Classes="ProjectSidebarSectionTitle"
                                         Text="快捷请求" />
                              <TextBlock Grid.Column="3"
                                         Classes="ProjectSidebarCatalogChevron"
                                         FontFamily="Segoe Fluent Icons, Segoe MDL2 Assets"
                                         Text="&#xE70E;"
                                         IsVisible="False" />
                            </Grid>
                          </ToggleButton>
                          <Border Classes="ProjectSidebarCatalogBody QuickRequestCatalogBody"
                                  IsVisible="{Binding IsQuickRequestCatalogExpanded}">
                            <StackPanel Classes="ProjectSidebarCatalogContent QuickRequestCatalogContent">
                              <TreeView Classes="WorkspaceTreeView ProjectSidebarTree QuickRequestSidebarTree"
                                        ItemsSource="{Binding QuickRequestTreeItems}">
                                <TreeView.ItemTemplate>
                                  <TreeDataTemplate x:DataType="vm:ExplorerItemViewModel"
                                                    ItemsSource="{Binding Children}">
                                    <Button Classes="WorkspaceTreeNodeButton QuickRequestTreeNodeButton"
                                            IsHitTestVisible="{Binding CanLoad}"
                                            Command="{Binding $parent[Window].((vm:MainWindowViewModel)DataContext).LoadSavedRequestCommand}"
                                            CommandParameter="{Binding}">
                                      <StackPanel Classes="QuickRequestTreeNodeContent">
                                        <Grid ColumnDefinitions="Auto,Auto,*,Auto"
                                              ColumnSpacing="{StaticResource Space.1}">
                                          <TextBlock Grid.Column="0"
                                                     Classes="WorkspaceTreeNodeGlyph"
                                                     FontFamily="Segoe Fluent Icons, Segoe MDL2 Assets"
                                                     Text="{Binding NodeGlyph}"
                                                     IsVisible="{Binding ShowLeadingGlyph}" />
                                          <TextBlock Grid.Column="0"
                                                     Classes="WorkspaceTreeNodeGlyph WorkspaceTreeCaseGlyph"
                                                     FontFamily="Segoe Fluent Icons, Segoe MDL2 Assets"
                                                     Text="{Binding NodeGlyph}"
                                                     IsVisible="{Binding IsHttpCaseNode}" />
                                          <u:Badge Grid.Column="1"
                                                   Margin="0,0,4,0"
                                                   Header="{Binding MethodBadgeText}"
                                                   IsVisible="{Binding ShowMethodBadge}"
                                                   iri:ClassHelper.Classes="{Binding MethodBadgeClass}" />
                                          <TextBlock Grid.Column="2"
                                                     Text="{Binding Title}"
                                                     VerticalAlignment="Center"
                                                     TextWrapping="Wrap" />
                                          <Border Grid.Column="3"
                                                  Classes="WorkspaceTreeStatusDot"
                                                  IsVisible="{Binding ShowTrailingDot}" />
                                        </Grid>
                                        <TextBlock Classes="CaptionText WorkspaceTreeSubtitleText"
                                                   Text="{Binding Subtitle}"
                                                   IsVisible="{Binding HasSubtitle}" />
                                      </StackPanel>
                                    </Button>
                                  </TreeDataTemplate>
                                </TreeView.ItemTemplate>
                              </TreeView>
                              <Button Classes="ProjectSidebarGhostButton ProjectSidebarBottomCreateButton QuickRequestBottomCreateButton"
                                      Content="+ 新建"
                                      Command="{Binding OpenQuickRequestWorkspaceCommand}" />
                            </StackPanel>
                          </Border>
                        </StackPanel>
                      </Border>
                    </StackPanel>
                  </ScrollViewer>
                </Grid>

                <Grid IsVisible="{Binding IsRequestHistorySection}"
                      RowDefinitions="Auto,*"
                      RowSpacing="{StaticResource Space.3}">
                  <Grid ColumnDefinitions="*,Auto"
                        ColumnSpacing="{StaticResource Space.2}">
                    <StackPanel Spacing="2">
                      <TextBlock Classes="SectionTitle"
                                 Text="请求历史" />
                      <TextBlock Classes="CaptionText"
                                 Text="可直接载入历史请求，或转存为接口草稿。" />
                    </StackPanel>
                    <u:PopConfirm Grid.Column="1"
                                  PopupHeader="确认清空当前项目的请求历史？"
                                  PopupContent="清空后无法恢复。"
                                  ConfirmCommand="{Binding $parent[Window].((vm:MainWindowViewModel)DataContext).ClearHistoryCommand}">
                      <Button Classes="SecondaryButton"
                              Content="清空" />
                    </u:PopConfirm>
                  </Grid>

                  <ScrollViewer Grid.Row="1">
                    <StackPanel Spacing="{StaticResource Space.2}">
                      <TextBlock Classes="CaptionText"
                                 Text="还没有发送记录"
                                 IsVisible="{Binding ShowHistoryEmptyState}" />
                      <ItemsControl ItemsSource="{Binding RequestHistory}"
                                    IsVisible="{Binding HasHistory}">
                        <ItemsControl.ItemTemplate>
                          <DataTemplate x:DataType="vm:RequestHistoryItemViewModel">
                            <Border Classes="SidebarListCard">
                              <StackPanel Spacing="{StaticResource Space.2}">
                                <Grid ColumnDefinitions="Auto,*"
                                      ColumnSpacing="{StaticResource Space.2}">
                                  <u:Badge Grid.Column="0"
                                           Header="{Binding Method}"
                                           iri:ClassHelper.Classes="{Binding MethodBadgeClass}" />
                                  <TextBlock Grid.Column="1"
                                             Text="{Binding Url}"
                                             TextTrimming="CharacterEllipsis" />
                                </Grid>
                                <Grid ColumnDefinitions="Auto,*,Auto,Auto"
                                      ColumnSpacing="{StaticResource Space.2}">
                                  <TextBlock Classes="CaptionText"
                                             Text="{Binding StatusText}" />
                                  <TextBlock Grid.Column="1"
                                             Classes="CaptionText"
                                             Text="{Binding TimestampText}" />
                                  <Button Grid.Column="2"
                                          Classes="TextButton"
                                          Content="载入"
                                          Command="{Binding $parent[Window].((vm:MainWindowViewModel)DataContext).LoadHistoryItemCommand}"
                                          CommandParameter="{Binding}" />
                                  <Button Grid.Column="3"
                                          Classes="TextButton"
                                          Content="转存"
                                          Command="{Binding $parent[Window].((vm:MainWindowViewModel)DataContext).SaveHistoryAsCaseCommand}"
                                          CommandParameter="{Binding}" />
                                </Grid>
                              </StackPanel>
                            </Border>
                          </DataTemplate>
                        </ItemsControl.ItemTemplate>
                      </ItemsControl>
                    </StackPanel>
                  </ScrollViewer>
                </Grid>

                <Grid IsVisible="{Binding IsProjectSettingsSection}"
                      RowDefinitions="Auto,*"
                      RowSpacing="{StaticResource Space.3}">
                  <StackPanel Spacing="2">
                    <TextBlock Classes="SectionTitle"
                               Text="项目设置" />
                    <TextBlock Classes="CaptionText"
                               Text="在这里管理项目设置、环境和导入数据入口。" />
                  </StackPanel>

                  <ScrollViewer Grid.Row="1"
                                HorizontalScrollBarVisibility="Disabled">
                    <Border Classes="ProjectSettingsSidebarCard">
                      <StackPanel Spacing="{StaticResource Space.4}">
                        <StackPanel Spacing="{StaticResource Space.2}">
                          <TextBlock Classes="ProjectSettingsGroupTitle"
                                     Text="基本设置" />
                          <Button Classes="ProjectSettingsSidebarItemButton"
                                  Classes.ProjectSettingsSidebarItemSelected="{Binding IsProjectSettingsOverviewSelected}"
                                  Command="{Binding ShowProjectOverviewSettingsCommand}">
                            <TextBlock Text="基本设置" />
                          </Button>
                        </StackPanel>

                        <StackPanel Spacing="{StaticResource Space.2}">
                          <TextBlock Classes="ProjectSettingsGroupTitle"
                                     Text="数据管理" />
                          <Button Classes="ProjectSettingsSidebarItemButton"
                                  Classes.ProjectSettingsSidebarItemSelected="{Binding IsProjectSettingsImportDataSelected}"
                                  Command="{Binding OpenProjectImportDialogCommand}">
                            <TextBlock Text="导入数据" />
                          </Button>
                        </StackPanel>

                        <Border Classes="ProjectSettingsSidebarMetaCard">
                          <StackPanel Spacing="{StaticResource Space.2}">
                            <TextBlock Text="{Binding Project.DisplayName}"
                                       FontWeight="SemiBold" />
                            <TextBlock Classes="CaptionText"
                                       Text="{Binding CurrentEnvironmentLabel, StringFormat='当前环境：{0}'}" />
                            <TextBlock Classes="CaptionText"
                                       Text="{Binding ImportedApiDocumentCountText, StringFormat='已导入：{0} 份文档'}" />
                          </StackPanel>
                        </Border>
                      </StackPanel>
                    </Border>
                  </ScrollViewer>
                </Grid>
              </Grid>
            </Border>

            <Border Grid.Column="2"
                    Classes="PanelCard ProjectWorkspaceCanvas"
                    IsVisible="{Binding ShowInterfaceManagementLanding}">
              <Grid RowDefinitions="Auto,*"
                    RowSpacing="{StaticResource Space.4}">
                <Border Classes="ProjectWorkspaceTopActionBar">
                  <Grid ColumnDefinitions="Auto,Auto,*,Auto,Auto"
                        ColumnSpacing="{StaticResource Space.3}">
                    <Border Classes="ProjectWorkspaceEditorTabs">
                      <ScrollViewer HorizontalScrollBarVisibility="Hidden"
                                    VerticalScrollBarVisibility="Disabled">
                        <StackPanel Orientation="Horizontal"
                                    Spacing="{StaticResource Space.2}">
                          <ItemsControl ItemsSource="{Binding VisibleWorkspaceTabs}">
                            <ItemsControl.ItemsPanel>
                              <ItemsPanelTemplate>
                                <StackPanel Orientation="Horizontal"
                                            Spacing="{StaticResource Space.2}" />
                              </ItemsPanelTemplate>
                            </ItemsControl.ItemsPanel>
                            <ItemsControl.ItemTemplate>
                              <DataTemplate x:DataType="vm:RequestWorkspaceTabViewModel">
                                <Border Classes="ProjectWorkspaceInnerTabShell">
                                  <Grid ColumnDefinitions="*,Auto"
                                        ColumnSpacing="{StaticResource Space.1}">
                                    <ToggleButton Grid.Column="0"
                                                  Classes="ProjectWorkspaceInnerTabButton"
                                                  Command="{Binding $parent[Window].((vm:MainWindowViewModel)DataContext).ActiveProjectTab.ActivateWorkspaceTabCommand}"
                                                  CommandParameter="{Binding}"
                                                  IsChecked="{Binding IsActive, Mode=OneWay}">
                                      <StackPanel Orientation="Horizontal"
                                                  Spacing="{StaticResource Space.2}">
                                        <Border Classes="ProjectWorkspaceInnerTabBadge"
                                                IsVisible="{Binding ShowMethodBadge}">
                                          <TextBlock Classes="CaptionText"
                                                     Text="{Binding MethodBadgeText}" />
                                        </Border>
                                        <TextBlock Text="{Binding HeaderText}" />
                                      </StackPanel>
                                    </ToggleButton>
                                    <Button Grid.Column="1"
                                            Classes="ProjectWorkspaceInnerTabCloseButton"
                                            Command="{Binding $parent[Window].((vm:MainWindowViewModel)DataContext).ActiveProjectTab.CloseWorkspaceTabCommand}"
                                            CommandParameter="{Binding}"
                                            Content="×" />
                                  </Grid>
                                </Border>
                              </DataTemplate>
                            </ItemsControl.ItemTemplate>
                          </ItemsControl>
                        </StackPanel>
                      </ScrollViewer>
                    </Border>

                    <Grid Grid.Column="1"
                          Width="72"
                          Height="28"
                          HorizontalAlignment="Left"
                          VerticalAlignment="Top">
                      <StackPanel Orientation="Horizontal"
                                  Spacing="{StaticResource Space.1}">
                        <Button Classes="ProjectWorkspaceInnerTabAddButton"
                                Content="+"
                                Command="{Binding CreateWorkspaceTabCommand}" />
                        <Button x:Name="LandingWorkspaceTabMenuButton"
                                Classes="ProjectWorkspaceInnerTabMoreButton"
                                Content="..."
                                Command="{Binding ToggleWorkspaceTabMenuCommand}" />
                      </StackPanel>

                      <Popup IsOpen="{Binding IsWorkspaceTabMenuOpen}"
                             PlacementTarget="{Binding #LandingWorkspaceTabMenuButton}"
                             Placement="Bottom"
                             VerticalOffset="6">
                        <Border Classes="WorkspaceTabMenuCard">
                          <StackPanel Spacing="{StaticResource Space.1}">
                            <Button Classes="WorkspaceTabMenuItem"
                                    Content="关闭全部标签页"
                                    Command="{Binding CloseAllWorkspaceTabsCommand}" />
                            <Button Classes="WorkspaceTabMenuItem"
                                    Content="关闭当前标签页"
                                    Command="{Binding CloseCurrentWorkspaceFromMenuCommand}" />
                            <Button Classes="WorkspaceTabMenuItem"
                                    Content="关闭其它标签页"
                                    Command="{Binding CloseOtherWorkspaceTabsCommand}" />
                          </StackPanel>
                        </Border>
                      </Popup>
                    </Grid>

                    <ComboBox Grid.Column="3"
                              Width="164"
                              Classes="SectionInput ProjectWorkspaceToolbarComboBox"
                              ItemsSource="{Binding EnvironmentPanel.Environments}"
                              SelectedItem="{Binding EnvironmentPanel.SelectedEnvironment}">
                      <ComboBox.ItemTemplate>
                        <DataTemplate x:DataType="vm:ProjectEnvironmentItemViewModel">
                          <TextBlock Text="{Binding CompactDisplayName}" />
                        </DataTemplate>
                      </ComboBox.ItemTemplate>
                    </ComboBox>

                    <StackPanel Grid.Column="4"
                              Orientation="Horizontal"
                              Spacing="{StaticResource Space.2}">
                      <Button Classes="SecondaryButton ProjectWorkspaceToolbarIconButton"
                              FontFamily="Segoe UI Symbol, Segoe UI, Microsoft YaHei UI"
                              Content="☰"
                              Command="{Binding $parent[Window].((vm:MainWindowViewModel)DataContext).OpenEnvironmentManagerCommand}" />
                    </StackPanel>
                  </Grid>
                </Border>

                <Grid Grid.Row="1">
                  <StackPanel Classes="WorkspaceLandingCenterStage"
                              HorizontalAlignment="Center"
                              VerticalAlignment="Center">
                    <StackPanel Classes="WorkspaceLandingChoicePanel"
                                Orientation="Horizontal"
                                HorizontalAlignment="Center">
                      <Button Classes="WorkspaceLandingChoiceButton"
                              Command="{Binding OpenHttpInterfaceWorkspaceCommand}">
                        <Grid RowDefinitions="*,Auto">
                          <TextBlock Classes="WorkspaceLandingChoiceIcon"
                                     FontFamily="Segoe Fluent Icons, Segoe MDL2 Assets"
                                     Text="&#xE8C8;" />
                          <TextBlock Grid.Row="1"
                                     Classes="WorkspaceLandingChoiceTitle"
                                     Text="新建 HTTP 接口" />
                        </Grid>
                      </Button>

                      <Button Classes="WorkspaceLandingChoiceButton"
                              Command="{Binding OpenQuickRequestWorkspaceCommand}">
                        <Grid RowDefinitions="*,Auto">
                          <TextBlock Classes="WorkspaceLandingChoiceIcon WorkspaceLandingChoiceQuickIcon"
                                     FontFamily="Segoe Fluent Icons, Segoe MDL2 Assets"
                                     Text="&#xE945;" />
                          <TextBlock Grid.Row="1"
                                     Classes="WorkspaceLandingChoiceTitle"
                                     Text="快捷请求" />
                        </Grid>
                      </Button>
                    </StackPanel>
                  </StackPanel>
                </Grid>
              </Grid>
            </Border>

            <Grid Grid.Column="2"
                  IsVisible="{Binding ShowRequestEditorWorkspace}"
                  RowDefinitions="Auto,Auto,*"
                  RowSpacing="{StaticResource Space.3}">
              <Border Classes="ProjectWorkspaceTopActionBar">
                <Grid ColumnDefinitions="Auto,Auto,*,Auto,Auto"
                      ColumnSpacing="{StaticResource Space.3}">
                  <Border Classes="ProjectWorkspaceEditorTabs">
                    <ScrollViewer HorizontalScrollBarVisibility="Hidden"
                                  VerticalScrollBarVisibility="Disabled">
                      <StackPanel Orientation="Horizontal"
                                  Spacing="{StaticResource Space.2}">
                        <ItemsControl ItemsSource="{Binding VisibleWorkspaceTabs}">
                          <ItemsControl.ItemsPanel>
                            <ItemsPanelTemplate>
                              <StackPanel Orientation="Horizontal"
                                          Spacing="{StaticResource Space.2}" />
                            </ItemsPanelTemplate>
                          </ItemsControl.ItemsPanel>
                          <ItemsControl.ItemTemplate>
                            <DataTemplate x:DataType="vm:RequestWorkspaceTabViewModel">
                              <Border Classes="ProjectWorkspaceInnerTabShell">
                                <Grid ColumnDefinitions="*,Auto"
                                      ColumnSpacing="{StaticResource Space.1}">
                                  <ToggleButton Grid.Column="0"
                                                Classes="ProjectWorkspaceInnerTabButton"
                                                Command="{Binding $parent[Window].((vm:MainWindowViewModel)DataContext).ActiveProjectTab.ActivateWorkspaceTabCommand}"
                                                CommandParameter="{Binding}"
                                                IsChecked="{Binding IsActive, Mode=OneWay}">
                                    <StackPanel Orientation="Horizontal"
                                                Spacing="{StaticResource Space.2}">
                                      <Border Classes="ProjectWorkspaceInnerTabBadge"
                                              IsVisible="{Binding ShowMethodBadge}">
                                        <TextBlock Classes="CaptionText"
                                                   Text="{Binding MethodBadgeText}" />
                                      </Border>
                                      <TextBlock Text="{Binding HeaderText}" />
                                    </StackPanel>
                                  </ToggleButton>
                                  <Button Grid.Column="1"
                                          Classes="ProjectWorkspaceInnerTabCloseButton"
                                          Command="{Binding $parent[Window].((vm:MainWindowViewModel)DataContext).ActiveProjectTab.CloseWorkspaceTabCommand}"
                                          CommandParameter="{Binding}"
                                          Content="×" />
                                </Grid>
                              </Border>
                            </DataTemplate>
                          </ItemsControl.ItemTemplate>
                        </ItemsControl>
                      </StackPanel>
                    </ScrollViewer>
                  </Border>

                  <Grid Grid.Column="1"
                        Width="72"
                        Height="28"
                        HorizontalAlignment="Left"
                        VerticalAlignment="Top">
                    <StackPanel Orientation="Horizontal"
                                Spacing="{StaticResource Space.1}">
                      <Button Classes="ProjectWorkspaceInnerTabAddButton"
                              Command="{Binding CreateWorkspaceTabCommand}">
                        <TextBlock Text="+"
                                   HorizontalAlignment="Center"
                                   VerticalAlignment="Center"
                                   TextAlignment="Center" />
                      </Button>
                      <Button x:Name="EditorWorkspaceTabMenuButton"
                              Classes="ProjectWorkspaceInnerTabMoreButton"
                              Content="..."
                              Command="{Binding ToggleWorkspaceTabMenuCommand}" />
                    </StackPanel>

                    <Popup IsOpen="{Binding IsWorkspaceTabMenuOpen}"
                           PlacementTarget="{Binding #EditorWorkspaceTabMenuButton}"
                           Placement="Bottom"
                           VerticalOffset="6">
                      <Border Classes="WorkspaceTabMenuCard">
                        <StackPanel Spacing="{StaticResource Space.1}">
                          <Button Classes="WorkspaceTabMenuItem"
                                  Content="关闭全部标签页"
                                  Command="{Binding CloseAllWorkspaceTabsCommand}" />
                          <Button Classes="WorkspaceTabMenuItem"
                                  Content="关闭当前标签页"
                                  Command="{Binding CloseCurrentWorkspaceFromMenuCommand}" />
                          <Button Classes="WorkspaceTabMenuItem"
                                  Content="关闭其它标签页"
                                  Command="{Binding CloseOtherWorkspaceTabsCommand}" />
                        </StackPanel>
                      </Border>
                    </Popup>
                  </Grid>

                  <ComboBox Grid.Column="3"
                            Width="164"
                            Classes="SectionInput ProjectWorkspaceToolbarComboBox"
                            HorizontalAlignment="Right"
                            ItemsSource="{Binding EnvironmentPanel.Environments}"
                            SelectedItem="{Binding EnvironmentPanel.SelectedEnvironment}">
                    <ComboBox.ItemTemplate>
                      <DataTemplate x:DataType="vm:ProjectEnvironmentItemViewModel">
                        <TextBlock Text="{Binding CompactDisplayName}" />
                      </DataTemplate>
                    </ComboBox.ItemTemplate>
                  </ComboBox>

                  <StackPanel Grid.Column="4"
                              Orientation="Horizontal"
                              Spacing="{StaticResource Space.2}">
                    <Button Classes="SecondaryButton ProjectWorkspaceToolbarIconButton"
                            FontFamily="Segoe UI Symbol, Segoe UI, Microsoft YaHei UI"
                            Content="☰"
                            Command="{Binding $parent[Window].((vm:MainWindowViewModel)DataContext).OpenEnvironmentManagerCommand}" />
                  </StackPanel>
                </Grid>
              </Border>

              <Grid Grid.Row="1"
                    ColumnDefinitions="Auto,*,Auto,Auto"
                    ColumnSpacing="{StaticResource Space.2}"
                    IsVisible="{Binding IsQuickRequestEditor}">
                <ComboBox Grid.Column="0"
                          Classes="MethodSelector"
                          ItemsSource="{Binding HttpMethods}"
                          SelectedItem="{Binding SelectedMethod}" />
                <TextBox Grid.Column="1"
                         Classes="UrlInput"
                         Watermark="{Binding CurrentEditorUrlWatermark}"
                         Text="{Binding RequestUrl}" />
                <Button Grid.Column="2"
                        Classes="SendButton QuickRequestPrimaryButton"
                        Content="发送"
                        Command="{Binding $parent[Window].((vm:MainWindowViewModel)DataContext).SendRequestCommand}" />
                <Button Grid.Column="3"
                        Classes="SecondaryButton QuickRequestToolbarButton"
                        Content="保存"
                        Command="{Binding $parent[Window].((vm:MainWindowViewModel)DataContext).SaveCaseCommand}" />
              </Grid>

              <Grid Grid.Row="1"
                    RowDefinitions="Auto,Auto"
                    RowSpacing="{StaticResource Space.2}"
                    IsVisible="{Binding IsHttpInterfaceEditor}">
                <Grid ColumnDefinitions="Auto,*"
                      ColumnSpacing="{StaticResource Space.3}">
                  <Border Grid.Column="0"
                          Classes="HttpEditorModeBar">
                    <StackPanel Orientation="Horizontal"
                                Spacing="{StaticResource Space.1}">
                      <ToggleButton Classes="HttpEditorModeButton"
                                    Command="{Binding ShowHttpDebugEditorModeCommand}"
                                    Content="调试"
                                    IsChecked="{Binding IsHttpDebugEditorMode, Mode=OneWay}" />
                      <ToggleButton Classes="HttpEditorModeButton"
                                    Command="{Binding ShowHttpDesignEditorModeCommand}"
                                    Content="设计"
                                    IsChecked="{Binding IsHttpDesignEditorMode, Mode=OneWay}" />
                      <ToggleButton Classes="HttpEditorModeButton"
                                    Command="{Binding ShowHttpDocumentPreviewModeCommand}"
                                    Content="文档预览"
                                    IsChecked="{Binding IsHttpDocumentPreviewMode, Mode=OneWay}" />
                    </StackPanel>
                  </Border>

                  <TextBox Grid.Column="1"
                           Classes="SectionInput HttpInterfaceNameInput"
                           HorizontalAlignment="Stretch"
                           Watermark="未命名接口"
                           Text="{Binding CurrentHttpInterfaceName}" />
                </Grid>

                <Grid Grid.Row="1"
                      ColumnDefinitions="*,Auto,Auto"
                      ColumnSpacing="{StaticResource Space.2}">
                  <Border Grid.Column="0"
                          Classes="HttpRequestUrlShell">
                    <Grid ColumnDefinitions="88,Auto,*"
                          ColumnSpacing="{StaticResource Space.2}">
                      <ComboBox Grid.Column="0"
                                Classes="HttpMethodSelector"
                                ItemsSource="{Binding HttpMethods}"
                                SelectedItem="{Binding SelectedMethod}" />
                      <Border Grid.Column="1"
                              Classes="BaseUrlPrefixCard HttpBaseUrlPrefixCard">
                        <TextBlock Classes="HttpBaseUrlPrefixText"
                                   Text="{Binding CurrentEditorBaseUrlCaption}"
                                   VerticalAlignment="Center"
                                   TextTrimming="CharacterEllipsis" />
                      </Border>
                      <TextBox Grid.Column="2"
                               Classes="HttpRequestPathInput"
                               Watermark="{Binding CurrentEditorUrlWatermark}"
                               Text="{Binding RequestUrl}" />
                    </Grid>
                  </Border>
                  <Button Grid.Column="1"
                          Classes="HttpSendButton"
                          Content="发送"
                          Command="{Binding $parent[Window].((vm:MainWindowViewModel)DataContext).SendRequestCommand}" />
                  <Button Grid.Column="2"
                          Classes="HttpSaveButton"
                          Content="保存"
                          Command="{Binding $parent[Window].((vm:MainWindowViewModel)DataContext).SaveCaseCommand}" />
                </Grid>
              </Grid>

              <Grid Grid.Row="2"
                    RowDefinitions="Auto,*"
                    RowSpacing="{StaticResource Space.3}"
                    IsVisible="{Binding IsQuickRequestEditor}">
                <Border Classes="PanelCard QuickRequestConfigCard"
                        Padding="0">
                  <TabControl Classes="ConfigTabControl QuickRequestInlineTabs"
                              SelectedIndex="{Binding ConfigTab.SelectedTabIndex}">
                    <TabItem Header="Params">
                      <DockPanel Margin="{StaticResource Pad.3}">
                        <Border DockPanel.Dock="Top"
                                Classes="ParameterHeader">
                          <Grid ColumnDefinitions="*,*,Auto">
                            <TextBlock Grid.Column="0"
                                       Classes="CaptionText"
                                       Text="参数名" />
                            <TextBlock Grid.Column="1"
                                       Classes="CaptionText"
                                       Text="参数值" />
                          </Grid>
                        </Border>
                        <Button DockPanel.Dock="Bottom"
                                Classes="AddButton"
                                HorizontalAlignment="Left"
                                Margin="0,8,0,0"
                                Content="+ 添加参数"
                                Command="{Binding ConfigTab.AddQueryParameterCommand}" />
                        <ScrollViewer>
                          <ItemsControl ItemsSource="{Binding ConfigTab.QueryParameters}">
                            <ItemsControl.ItemTemplate>
                              <DataTemplate x:DataType="vm:RequestParameterItemViewModel">
                                <Border Classes="ParameterRow">
                                  <Grid ColumnDefinitions="*,*,Auto"
                                        ColumnSpacing="{StaticResource Space.2}">
                                    <TextBox Grid.Column="0"
                                             Classes="ParameterInput"
                                             Text="{Binding Name}"
                                             Watermark="参数名" />
                                    <TextBox Grid.Column="1"
                                             Classes="ParameterInput"
                                             Text="{Binding Value}"
                                             Watermark="参数值" />
                                    <u:IconButton Grid.Column="2"
                                                  Classes="Danger"
                                                  Theme="{DynamicResource BorderlessIconButton}"
                                                  Icon="{StaticResource SemiIconDelete}"
                                                  Command="{Binding $parent[Window].((vm:MainWindowViewModel)DataContext).ConfigTab.RemoveParameterCommand}"
                                                  CommandParameter="{Binding}" />
                                  </Grid>
                                </Border>
                              </DataTemplate>
                            </ItemsControl.ItemTemplate>
                          </ItemsControl>
                        </ScrollViewer>
                      </DockPanel>
                    </TabItem>

                    <TabItem Header="Body">
                      <DockPanel Margin="{StaticResource Pad.3}">
                        <u:SelectionList DockPanel.Dock="Top"
                                         ItemsSource="{Binding ConfigTab.BodyModeOptions}"
                                         SelectedItem="{Binding ConfigTab.SelectedBodyModeOption}"
                                         Margin="0,0,0,12">
                          <u:SelectionList.ItemsPanel>
                            <ItemsPanelTemplate>
                              <StackPanel Orientation="Horizontal" />
                            </ItemsPanelTemplate>
                          </u:SelectionList.ItemsPanel>
                          <u:SelectionList.ItemTemplate>
                            <DataTemplate x:DataType="vm:BodyModeOptionViewModel">
                              <Border Padding="{StaticResource Pad.2}">
                                <TextBlock Text="{Binding DisplayName}" />
                              </Border>
                            </DataTemplate>
                          </u:SelectionList.ItemTemplate>
                        </u:SelectionList>

                        <DockPanel Classes="QuickRequestBodyFieldPanel"
                                   IsVisible="{Binding ConfigTab.IsBodyModeFormData}">
                          <Border DockPanel.Dock="Top"
                                  Classes="ParameterHeader">
                            <Grid ColumnDefinitions="2*,3*,Auto">
                              <TextBlock Grid.Column="0"
                                         Classes="CaptionText"
                                         Text="字段名" />
                              <TextBlock Grid.Column="1"
                                         Classes="CaptionText"
                                         Text="字段值" />
                            </Grid>
                          </Border>
                          <Button DockPanel.Dock="Bottom"
                                  Classes="AddButton QuickRequestBodyAddButton"
                                  HorizontalAlignment="Left"
                                  Content="+ 添加字段"
                                  Command="{Binding ConfigTab.AddFormFieldCommand}" />
                          <ScrollViewer Classes="QuickRequestBodyFieldScroller"
                                        VerticalScrollBarVisibility="Auto">
                            <ItemsControl ItemsSource="{Binding ConfigTab.FormFields}">
                              <ItemsControl.ItemTemplate>
                                <DataTemplate x:DataType="vm:RequestParameterItemViewModel">
                                  <Border Classes="ParameterRow">
                                    <Grid ColumnDefinitions="2*,3*,Auto"
                                          ColumnSpacing="{StaticResource Space.2}">
                                      <TextBox Grid.Column="0"
                                               Classes="ParameterInput"
                                               Text="{Binding Name}"
                                               Watermark="字段名" />
                                      <TextBox Grid.Column="1"
                                               Classes="ParameterInput"
                                               Text="{Binding Value}"
                                               Watermark="字段值" />
                                      <u:IconButton Grid.Column="2"
                                                    Classes="Danger"
                                                    Theme="{DynamicResource BorderlessIconButton}"
                                                    Icon="{StaticResource SemiIconDelete}"
                                                    Command="{Binding $parent[Window].((vm:MainWindowViewModel)DataContext).ConfigTab.RemoveParameterCommand}"
                                                    CommandParameter="{Binding}" />
                                    </Grid>
                                  </Border>
                                </DataTemplate>
                              </ItemsControl.ItemTemplate>
                            </ItemsControl>
                          </ScrollViewer>
                        </DockPanel>

                        <Border IsVisible="{Binding ConfigTab.HasRawBodyEditor}"
                                Classes="RawEditorCard">
                          <TextBox AcceptsReturn="True"
                                   BorderThickness="0"
                                   Background="Transparent"
                                   TextWrapping="Wrap"
                                   VerticalContentAlignment="Top"
                                   Watermark="{Binding ConfigTab.RequestBodyWatermark}"
                                   Text="{Binding ConfigTab.RequestBody}"
                                   FontFamily="{StaticResource Font.Monospace}" />
                        </Border>
                      </DockPanel>
                    </TabItem>

                    <TabItem Header="Headers">
                      <DockPanel Margin="{StaticResource Pad.3}">
                        <Border DockPanel.Dock="Top"
                                Classes="ParameterHeader">
                          <Grid ColumnDefinitions="*,*,Auto">
                            <TextBlock Grid.Column="0"
                                       Classes="CaptionText"
                                       Text="Header 名" />
                            <TextBlock Grid.Column="1"
                                       Classes="CaptionText"
                                       Text="Header 值" />
                          </Grid>
                        </Border>
                        <Button DockPanel.Dock="Bottom"
                                Classes="AddButton"
                                HorizontalAlignment="Left"
                                Margin="0,8,0,0"
                                Content="+ 添加 Header"
                                Command="{Binding ConfigTab.AddHeaderCommand}" />
                        <ScrollViewer>
                          <ItemsControl ItemsSource="{Binding ConfigTab.Headers}">
                            <ItemsControl.ItemTemplate>
                              <DataTemplate x:DataType="vm:RequestParameterItemViewModel">
                                <Border Classes="ParameterRow">
                                  <Grid ColumnDefinitions="*,*,Auto"
                                        ColumnSpacing="{StaticResource Space.2}">
                                    <TextBox Grid.Column="0"
                                             Classes="ParameterInput"
                                             Text="{Binding Name}"
                                             Watermark="Header 名" />
                                    <TextBox Grid.Column="1"
                                             Classes="ParameterInput"
                                             Text="{Binding Value}"
                                             Watermark="Header 值" />
                                    <u:IconButton Grid.Column="2"
                                                  Classes="Danger"
                                                  Theme="{DynamicResource BorderlessIconButton}"
                                                  Icon="{StaticResource SemiIconDelete}"
                                                  Command="{Binding $parent[Window].((vm:MainWindowViewModel)DataContext).ConfigTab.RemoveParameterCommand}"
                                                  CommandParameter="{Binding}" />
                                  </Grid>
                                </Border>
                              </DataTemplate>
                            </ItemsControl.ItemTemplate>
                          </ItemsControl>
                        </ScrollViewer>
                      </DockPanel>
                    </TabItem>

                  </TabControl>
                </Border>

                <Border Grid.Row="1"
                        Classes="PanelCard ResponsePanelCard">
                  <DockPanel>
                    <Grid DockPanel.Dock="Top"
                          Margin="0,0,0,12">
                      <TextBlock Classes="SectionTitle"
                                 Text="返回响应" />
                    </Grid>

                    <Grid IsVisible="{Binding ResponseSection.ShowPlaceholder}">
                      <StackPanel HorizontalAlignment="Center"
                                  VerticalAlignment="Center"
                                  Spacing="{StaticResource Space.2}">
                        <TextBlock Classes="HttpResponsePlaceholderIcon"
                                   FontFamily="Segoe Fluent Icons, Segoe MDL2 Assets"
                                   Text="&#xE7C3;" />
                        <TextBlock Classes="SubtleText"
                                   Text="点击“发送”按钮获取返回结果" />
                      </StackPanel>
                    </Grid>

                    <Grid IsVisible="{Binding ResponseSection.HasResponse}"
                          RowDefinitions="Auto,*"
                          RowSpacing="{StaticResource Space.2}">
                      <Grid ColumnDefinitions="Auto,Auto,Auto,*"
                            ColumnSpacing="{StaticResource Space.3}">
                        <u:Badge Grid.Column="0"
                                 Header="{Binding ResponseSection.StatusText}"
                                 iri:ClassHelper.Classes="{Binding ResponseSection.StatusBadgeClass}" />
                        <TextBlock Grid.Column="1"
                                   Classes="CaptionText"
                                   Text="{Binding ResponseSection.DurationText}" />
                        <TextBlock Grid.Column="2"
                                   Classes="CaptionText"
                                   Text="{Binding ResponseSection.SizeText}" />
                      </Grid>

                      <TabControl Grid.Row="1"
                                  Classes="ResponseTabs"
                                  SelectedIndex="{Binding ResponseSection.SelectedResponseTab}">
                        <TabItem Header="Body">
                          <TextBox AcceptsReturn="True"
                                   BorderThickness="0"
                                   Background="Transparent"
                                   IsReadOnly="True"
                                   TextWrapping="Wrap"
                                   VerticalContentAlignment="Top"
                                   Text="{Binding ResponseSection.BodyText}"
                                   FontFamily="{StaticResource Font.Monospace}" />
                        </TabItem>
                        <TabItem Header="Headers">
                          <TextBox AcceptsReturn="True"
                                   BorderThickness="0"
                                   Background="Transparent"
                                   IsReadOnly="True"
                                   TextWrapping="Wrap"
                                   VerticalContentAlignment="Top"
                                   Text="{Binding ResponseSection.HeadersText}"
                                   FontFamily="{StaticResource Font.Monospace}" />
                        </TabItem>
                      </TabControl>
                    </Grid>
                  </DockPanel>
                </Border>
              </Grid>

              <Grid Grid.Row="2"
                    RowDefinitions="Auto,2*,3*"
                    RowSpacing="{StaticResource Space.3}"
                    IsVisible="{Binding ShowHttpWorkbenchContent}">
                <Border Grid.Row="0"
                        Classes="PanelCard HttpDesignMetaCard"
                        IsVisible="{Binding IsHttpDesignEditorMode}">
                  <StackPanel Spacing="{StaticResource Space.3}">
                    <StackPanel Spacing="2">
                      <TextBlock Classes="SectionTitle"
                                 Text="接口设计" />
                      <TextBlock Classes="CaptionText"
                                 Text="这里只保留接口说明，用于补充接口用途、前置条件和返回约定。" />
                    </StackPanel>

                    <StackPanel Spacing="{StaticResource Space.2}">
                      <TextBlock Classes="CaptionText"
                                 Text="接口说明" />
                      <TextBox Classes="SectionInput HttpDesignMultilineInput"
                               AcceptsReturn="True"
                               Text="{Binding ConfigTab.RequestDescription}"
                               TextWrapping="Wrap"
                               VerticalContentAlignment="Top"
                               Watermark="补充接口用途、前置条件和返回约定" />
                    </StackPanel>
                  </StackPanel>
                </Border>

                <Border Grid.Row="2"
                        Classes="PanelCard HttpResponseCard">
                  <DockPanel>
                    <Grid DockPanel.Dock="Top"
                          Margin="0,0,0,12">
                      <TextBlock Classes="SectionTitle"
                                 Text="返回响应" />
                    </Grid>

                    <Grid IsVisible="{Binding ResponseSection.ShowPlaceholder}">
                      <StackPanel HorizontalAlignment="Center"
                                  VerticalAlignment="Center"
                                  Spacing="{StaticResource Space.2}">
                        <TextBlock Classes="HttpResponsePlaceholderIcon"
                                   FontFamily="Segoe Fluent Icons, Segoe MDL2 Assets"
                                   Text="&#xE7C3;" />
                        <TextBlock Classes="SubtleText"
                                   Text="点击“发送”按钮获取返回结果" />
                      </StackPanel>
                    </Grid>

                    <Grid IsVisible="{Binding ResponseSection.HasResponse}"
                          RowDefinitions="Auto,*"
                          RowSpacing="{StaticResource Space.2}">
                      <Grid ColumnDefinitions="Auto,Auto,Auto,*"
                            ColumnSpacing="{StaticResource Space.3}">
                        <u:Badge Grid.Column="0"
                                 Header="{Binding ResponseSection.StatusText}"
                                 iri:ClassHelper.Classes="{Binding ResponseSection.StatusBadgeClass}" />
                        <TextBlock Grid.Column="1"
                                   Classes="CaptionText"
                                   Text="{Binding ResponseSection.DurationText}" />
                        <TextBlock Grid.Column="2"
                                   Classes="CaptionText"
                                   Text="{Binding ResponseSection.SizeText}" />
                      </Grid>

                      <TabControl Grid.Row="1"
                                  Classes="ResponseTabs"
                                  SelectedIndex="{Binding ResponseSection.SelectedResponseTab}">
                        <TabItem Header="Body">
                          <TextBox AcceptsReturn="True"
                                   BorderThickness="0"
                                   Background="Transparent"
                                   IsReadOnly="True"
                                   TextWrapping="Wrap"
                                   VerticalContentAlignment="Top"
                                   Text="{Binding ResponseSection.BodyText}"
                                   FontFamily="{StaticResource Font.Monospace}" />
                        </TabItem>
                        <TabItem Header="Headers">
                          <TextBox AcceptsReturn="True"
                                   BorderThickness="0"
                                   Background="Transparent"
                                   IsReadOnly="True"
                                   TextWrapping="Wrap"
                                   VerticalContentAlignment="Top"
                                   Text="{Binding ResponseSection.HeadersText}"
                                   FontFamily="{StaticResource Font.Monospace}" />
                        </TabItem>
                      </TabControl>
                    </Grid>
                  </DockPanel>
                </Border>

                <Border Grid.Row="1"
                        Classes="PanelCard ProjectWorkspaceSettingsCard HttpWorkbenchConfigCard"
                        Padding="0">
                  <Grid RowDefinitions="*">
                    <TabControl Grid.Row="0"
                                Classes="ConfigTabControl HttpRequestTabs"
                                SelectedIndex="{Binding ConfigTab.SelectedTabIndex}">
                      <TabItem Header="Params">
                        <DockPanel Margin="{StaticResource Pad.3}">
                          <Border DockPanel.Dock="Top"
                                  Classes="HttpRequestTableHeader">
                            <Grid ColumnDefinitions="2.4*,2.4*,1.2*,2.2*,Auto"
                                  ColumnSpacing="{StaticResource Space.3}">
                              <TextBlock Grid.Column="0"
                                         Classes="CaptionText"
                                         Text="参数名" />
                              <TextBlock Grid.Column="1"
                                         Classes="CaptionText"
                                         Text="参数值" />
                              <TextBlock Grid.Column="2"
                                         Classes="CaptionText"
                                         Text="类型" />
                              <TextBlock Grid.Column="3"
                                         Classes="CaptionText"
                                         Text="说明" />
                            </Grid>
                          </Border>
                          <Button DockPanel.Dock="Bottom"
                                  Classes="AddButton"
                                  HorizontalAlignment="Left"
                                  Margin="0,8,0,0"
                                  Content="添加参数"
                                  Command="{Binding ConfigTab.AddQueryParameterCommand}" />
                          <ScrollViewer>
                            <ItemsControl ItemsSource="{Binding ConfigTab.QueryParameters}">
                              <ItemsControl.ItemTemplate>
                                <DataTemplate x:DataType="vm:RequestParameterItemViewModel">
                                  <Border Classes="ParameterRow HttpRequestParameterRow">
                                    <Grid ColumnDefinitions="2.4*,2.4*,1.2*,2.2*,Auto"
                                          ColumnSpacing="{StaticResource Space.3}">
                                      <TextBox Grid.Column="0"
                                               Classes="ParameterInput HttpTableInput"
                                               Text="{Binding Name}"
                                               Watermark="添加参数" />
                                      <TextBox Grid.Column="1"
                                               Classes="ParameterInput HttpTableInput"
                                               Text="{Binding Value}"
                                               Watermark="参数值" />
                                      <TextBlock Grid.Column="2"
                                                 Classes="CaptionText"
                                                 Text="String"
                                                 VerticalAlignment="Center" />
                                      <TextBox Grid.Column="3"
                                               Classes="ParameterInput HttpTableInput"
                                               Text="{Binding Description}"
                                               Watermark="说明" />
                                      <u:IconButton Grid.Column="4"
                                                    Classes="Danger"
                                                    Theme="{DynamicResource BorderlessIconButton}"
                                                    Icon="{StaticResource SemiIconDelete}"
                                                    Command="{Binding $parent[Window].((vm:MainWindowViewModel)DataContext).ConfigTab.RemoveParameterCommand}"
                                                    CommandParameter="{Binding}" />
                                    </Grid>
                                  </Border>
                                </DataTemplate>
                              </ItemsControl.ItemTemplate>
                            </ItemsControl>
                          </ScrollViewer>
                        </DockPanel>
                      </TabItem>

                      <TabItem Header="Body">
                        <DockPanel Margin="{StaticResource Pad.3}">
                          <u:SelectionList DockPanel.Dock="Top"
                                           ItemsSource="{Binding ConfigTab.BodyModeOptions}"
                                           SelectedItem="{Binding ConfigTab.SelectedBodyModeOption}"
                                           Margin="0,0,0,12">
                            <u:SelectionList.ItemsPanel>
                              <ItemsPanelTemplate>
                                <StackPanel Orientation="Horizontal" />
                              </ItemsPanelTemplate>
                            </u:SelectionList.ItemsPanel>
                            <u:SelectionList.ItemTemplate>
                              <DataTemplate x:DataType="vm:BodyModeOptionViewModel">
                                <Border Padding="{StaticResource Pad.2}">
                                  <TextBlock Text="{Binding DisplayName}" />
                                </Border>
                              </DataTemplate>
                            </u:SelectionList.ItemTemplate>
                          </u:SelectionList>

                        <DockPanel IsVisible="{Binding ConfigTab.IsBodyModeFormData}">
                          <Border DockPanel.Dock="Top"
                                  Classes="HttpRequestTableHeader">
                            <Grid ColumnDefinitions="2.4*,2.4*,1.2*,2.2*,Auto"
                                  ColumnSpacing="{StaticResource Space.3}">
                              <TextBlock Grid.Column="0"
                                         Classes="CaptionText"
                                         Text="字段名" />
                              <TextBlock Grid.Column="1"
                                         Classes="CaptionText"
                                         Text="字段值" />
                              <TextBlock Grid.Column="2"
                                         Classes="CaptionText"
                                         Text="类型" />
                              <TextBlock Grid.Column="3"
                                         Classes="CaptionText"
                                         Text="说明" />
                            </Grid>
                          </Border>
                          <Button DockPanel.Dock="Bottom"
                                  Classes="AddButton"
                                  HorizontalAlignment="Left"
                                  Margin="0,8,0,0"
                                  Content="添加字段"
                                  Command="{Binding ConfigTab.AddFormFieldCommand}" />
                          <ScrollViewer>
                            <ItemsControl ItemsSource="{Binding ConfigTab.FormFields}">
                              <ItemsControl.ItemTemplate>
                                <DataTemplate x:DataType="vm:RequestParameterItemViewModel">
                                  <Border Classes="ParameterRow HttpRequestParameterRow">
                                    <Grid ColumnDefinitions="2.4*,2.4*,1.2*,2.2*,Auto"
                                          ColumnSpacing="{StaticResource Space.3}">
                                      <TextBox Grid.Column="0"
                                               Classes="ParameterInput HttpTableInput"
                                               Text="{Binding Name}"
                                               Watermark="字段名" />
                                      <TextBox Grid.Column="1"
                                               Classes="ParameterInput HttpTableInput"
                                               Text="{Binding Value}"
                                               Watermark="字段值" />
                                      <TextBlock Grid.Column="2"
                                                 Classes="CaptionText"
                                                 Text="String"
                                                 VerticalAlignment="Center" />
                                      <TextBox Grid.Column="3"
                                               Classes="ParameterInput HttpTableInput"
                                               Text="{Binding Description}"
                                               Watermark="说明" />
                                      <u:IconButton Grid.Column="4"
                                                    Classes="Danger"
                                                    Theme="{DynamicResource BorderlessIconButton}"
                                                    Icon="{StaticResource SemiIconDelete}"
                                                      Command="{Binding $parent[Window].((vm:MainWindowViewModel)DataContext).ConfigTab.RemoveParameterCommand}"
                                                      CommandParameter="{Binding}" />
                                      </Grid>
                                    </Border>
                                  </DataTemplate>
                                </ItemsControl.ItemTemplate>
                              </ItemsControl>
                            </ScrollViewer>
                          </DockPanel>

                          <Border IsVisible="{Binding ConfigTab.HasRawBodyEditor}"
                                  Classes="RawEditorCard">
                            <TextBox AcceptsReturn="True"
                                     BorderThickness="0"
                                     Background="Transparent"
                                     TextWrapping="Wrap"
                                     VerticalContentAlignment="Top"
                                     Watermark="{Binding ConfigTab.RequestBodyWatermark}"
                                     Text="{Binding ConfigTab.RequestBody}"
                                     FontFamily="{StaticResource Font.Monospace}" />
                          </Border>
                        </DockPanel>
                      </TabItem>

                      <TabItem Header="Headers">
                        <DockPanel Margin="{StaticResource Pad.3}">
                          <Border DockPanel.Dock="Top"
                                  Classes="HttpRequestTableHeader">
                            <Grid ColumnDefinitions="2.4*,2.4*,1.2*,2.2*,Auto"
                                  ColumnSpacing="{StaticResource Space.3}">
                              <TextBlock Grid.Column="0"
                                         Classes="CaptionText"
                                         Text="Header 名" />
                              <TextBlock Grid.Column="1"
                                         Classes="CaptionText"
                                         Text="Header 值" />
                              <TextBlock Grid.Column="2"
                                         Classes="CaptionText"
                                         Text="类型" />
                              <TextBlock Grid.Column="3"
                                         Classes="CaptionText"
                                         Text="说明" />
                            </Grid>
                          </Border>
                          <Button DockPanel.Dock="Bottom"
                                  Classes="AddButton"
                                  HorizontalAlignment="Left"
                                  Margin="0,8,0,0"
                                  Content="添加 Header"
                                  Command="{Binding ConfigTab.AddHeaderCommand}" />
                          <ScrollViewer>
                            <ItemsControl ItemsSource="{Binding ConfigTab.Headers}">
                              <ItemsControl.ItemTemplate>
                                <DataTemplate x:DataType="vm:RequestParameterItemViewModel">
                                  <Border Classes="ParameterRow HttpRequestParameterRow">
                                    <Grid ColumnDefinitions="2.4*,2.4*,1.2*,2.2*,Auto"
                                          ColumnSpacing="{StaticResource Space.3}">
                                      <TextBox Grid.Column="0"
                                               Classes="ParameterInput HttpTableInput"
                                               Text="{Binding Name}"
                                               Watermark="Header 名" />
                                      <TextBox Grid.Column="1"
                                               Classes="ParameterInput HttpTableInput"
                                               Text="{Binding Value}"
                                               Watermark="Header 值" />
                                      <TextBlock Grid.Column="2"
                                                 Classes="CaptionText"
                                                 Text="String"
                                                 VerticalAlignment="Center" />
                                      <TextBox Grid.Column="3"
                                               Classes="ParameterInput HttpTableInput"
                                               Text="{Binding Description}"
                                               Watermark="说明" />
                                      <u:IconButton Grid.Column="4"
                                                    Classes="Danger"
                                                    Theme="{DynamicResource BorderlessIconButton}"
                                                    Icon="{StaticResource SemiIconDelete}"
                                                    Command="{Binding $parent[Window].((vm:MainWindowViewModel)DataContext).ConfigTab.RemoveParameterCommand}"
                                                    CommandParameter="{Binding}" />
                                    </Grid>
                                  </Border>
                                </DataTemplate>
                              </ItemsControl.ItemTemplate>
                            </ItemsControl>
                          </ScrollViewer>
                        </DockPanel>
                      </TabItem>
                    </TabControl>
                  </Grid>
                </Border>
              </Grid>

              <ScrollViewer Grid.Row="2"
                            HorizontalScrollBarVisibility="Disabled"
                            IsVisible="{Binding ShowHttpDocumentPreviewContent}">
                <StackPanel Spacing="{StaticResource Space.4}">
                  <Border Classes="PanelCard HttpDocumentHeroCard">
                    <StackPanel Spacing="{StaticResource Space.3}">
                      <StackPanel Orientation="Horizontal"
                                  Spacing="{StaticResource Space.2}">
                        <Border Classes="HttpDocumentMethodBadge">
                          <TextBlock Text="{Binding SelectedMethod}" />
                        </Border>
                        <Border Classes="HttpDocumentStatusBadge">
                          <TextBlock Text="{Binding CurrentResponseValidationResultText}" />
                        </Border>
                      </StackPanel>

                      <StackPanel Spacing="4">
                        <TextBlock Classes="PageTitle"
                                   Text="{Binding CurrentHttpInterfaceDisplayName}" />
                        <TextBlock Classes="CaptionText"
                                   Text="{Binding ConfigTab.RequestDescription}"
                                   TextWrapping="Wrap" />
                      </StackPanel>

                      <Border Classes="HttpDocumentUrlCard">
                        <StackPanel Spacing="4">
                          <TextBlock Classes="CaptionText"
                                     Text="请求地址" />
                          <TextBlock Text="{Binding CurrentHttpDocumentUrl}"
                                     TextWrapping="Wrap" />
                        </StackPanel>
                      </Border>
                    </StackPanel>
                  </Border>

                  <Grid ColumnDefinitions="1.3*,*"
                        ColumnSpacing="{StaticResource Space.3}">
                    <StackPanel Spacing="{StaticResource Space.3}">
                      <Border Classes="PanelCard HttpDocumentPreviewCard">
                        <StackPanel Spacing="{StaticResource Space.3}">
                          <TextBlock Classes="SectionTitle"
                                     Text="请求概览" />
                          <Grid ColumnDefinitions="Auto,*"
                                ColumnSpacing="{StaticResource Space.3}"
                                RowDefinitions="Auto,Auto,Auto,Auto"
                                RowSpacing="{StaticResource Space.2}">
                            <TextBlock Grid.Row="0"
                                       Classes="CaptionText"
                                       Text="接口目录" />
                            <TextBlock Grid.Row="0"
                                       Grid.Column="1"
                                       Text="{Binding CurrentInterfaceFolderPath}" />
                            <TextBlock Grid.Row="1"
                                       Classes="CaptionText"
                                       Text="BaseUrl" />
                            <TextBlock Grid.Row="1"
                                       Grid.Column="1"
                                       Text="{Binding CurrentEditorBaseUrlCaption}"
                                       TextWrapping="Wrap" />
                            <TextBlock Grid.Row="2"
                                       Classes="CaptionText"
                                       Text="接口用例" />
                            <TextBlock Grid.Row="2"
                                       Grid.Column="1"
                                       Text="{Binding CurrentHttpCaseName}" />
                            <TextBlock Grid.Row="3"
                                       Classes="CaptionText"
                                       Text="Body 模式" />
                            <TextBlock Grid.Row="3"
                                       Grid.Column="1"
                                       Text="{Binding CurrentHttpDocumentBodyModeText}" />
                          </Grid>

                          <TextBlock Classes="CaptionText"
                                     IsVisible="{Binding ShowHttpDocumentRequestEmpty}"
                                     Text="当前还没有补充参数、Header 或请求体内容。" />
                        </StackPanel>
                      </Border>

                      <Border Classes="PanelCard HttpDocumentPreviewCard"
                              IsVisible="{Binding HasHttpDocumentParameters}">
                        <StackPanel Spacing="{StaticResource Space.3}">
                          <TextBlock Classes="SectionTitle"
                                     Text="Query 参数" />
                          <ItemsControl ItemsSource="{Binding ConfigTab.QueryParameters}">
                            <ItemsControl.ItemTemplate>
                              <DataTemplate x:DataType="vm:RequestParameterItemViewModel">
                                <Border Classes="HttpDocumentKeyValueRow">
                                  <Grid ColumnDefinitions="*,*"
                                        ColumnSpacing="{StaticResource Space.3}">
                                    <TextBlock Grid.Column="0"
                                               Text="{Binding Name}" />
                                    <TextBlock Grid.Column="1"
                                               Classes="CaptionText"
                                               Text="{Binding Value}"
                                               TextWrapping="Wrap" />
                                  </Grid>
                                </Border>
                              </DataTemplate>
                            </ItemsControl.ItemTemplate>
                          </ItemsControl>
                        </StackPanel>
                      </Border>

                      <Border Classes="PanelCard HttpDocumentPreviewCard"
                              IsVisible="{Binding HasHttpDocumentHeaders}">
                        <StackPanel Spacing="{StaticResource Space.3}">
                          <TextBlock Classes="SectionTitle"
                                     Text="Headers" />
                          <ItemsControl ItemsSource="{Binding ConfigTab.Headers}">
                            <ItemsControl.ItemTemplate>
                              <DataTemplate x:DataType="vm:RequestParameterItemViewModel">
                                <Border Classes="HttpDocumentKeyValueRow">
                                  <Grid ColumnDefinitions="*,*"
                                        ColumnSpacing="{StaticResource Space.3}">
                                    <TextBlock Grid.Column="0"
                                               Text="{Binding Name}" />
                                    <TextBlock Grid.Column="1"
                                               Classes="CaptionText"
                                               Text="{Binding Value}"
                                               TextWrapping="Wrap" />
                                  </Grid>
                                </Border>
                              </DataTemplate>
                            </ItemsControl.ItemTemplate>
                          </ItemsControl>
                        </StackPanel>
                      </Border>
                    </StackPanel>

                    <StackPanel Grid.Column="1"
                                Spacing="{StaticResource Space.3}">
                      <Border Classes="PanelCard HttpDocumentPreviewCard">
                        <StackPanel Spacing="{StaticResource Space.3}">
                          <TextBlock Classes="SectionTitle"
                                     Text="响应示例" />
                          <TextBlock Classes="CaptionText"
                                     Text="{Binding CurrentHttpDocumentResponseSummary}" />
                          <TextBox Classes="HttpDocumentReadonlyCode"
                                   AcceptsReturn="True"
                                   IsReadOnly="True"
                                   Text="{Binding CurrentHttpDocumentBodyPreview}"
                                   TextWrapping="Wrap"
                                   VerticalContentAlignment="Top" />
                        </StackPanel>
                      </Border>

                      <Border Classes="PanelCard HttpDocumentPreviewCard">
                        <StackPanel Spacing="{StaticResource Space.3}">
                          <TextBlock Classes="SectionTitle"
                                     Text="请求示例" />
                          <TextBox Classes="HttpDocumentReadonlyCode"
                                   AcceptsReturn="True"
                                   IsReadOnly="True"
                                   Text="{Binding CurrentHttpDocumentCurlSnippet}"
                                   TextWrapping="Wrap"
                                   VerticalContentAlignment="Top" />
                        </StackPanel>
                      </Border>
                    </StackPanel>
                  </Grid>
                </StackPanel>
              </ScrollViewer>

            <Border Grid.Column="2"
                    Classes="PanelCard ProjectWorkspaceCanvas"
                    IsVisible="{Binding IsRequestHistorySection}">
              <Grid RowDefinitions="Auto,*"
                    RowSpacing="{StaticResource Space.3}">
                <Grid ColumnDefinitions="*,Auto"
                      ColumnSpacing="{StaticResource Space.2}">
                  <StackPanel Spacing="2">
                    <TextBlock Classes="SectionTitle"
                               Text="请求历史详情" />
                    <TextBlock Classes="CaptionText"
                               Text="从左侧选择历史记录后，可在这里查看响应并一键回到快捷请求。" />
                  </StackPanel>
                  <Button Grid.Column="1"
                          Classes="SecondaryButton"
                          Content="打开快捷请求"
                          Command="{Binding OpenQuickRequestWorkspaceCommand}" />
                </Grid>

                <Border Grid.Row="1"
                        Classes="PanelCard ResponsePanelCard">
                  <DockPanel>
                    <Grid DockPanel.Dock="Top"
                          ColumnDefinitions="*,Auto"
                          Margin="0,0,0,12">
                      <TextBlock Classes="SectionTitle"
                                 Text="最近一次载入的响应" />
                      <TextBlock Grid.Column="1"
                                 Classes="CaptionText"
                                 Text="{Binding CurrentEnvironmentLabel}"
                                 VerticalAlignment="Center" />
                    </Grid>

                    <StackPanel IsVisible="{Binding ResponseSection.ShowPlaceholder}"
                                HorizontalAlignment="Center"
                                VerticalAlignment="Center"
                                Spacing="{StaticResource Space.2}">
                      <TextBlock Classes="SubtleText"
                                 Text="选择左侧历史记录后，可在这里查看最近一次载入的响应内容。" />
                    </StackPanel>

                    <Grid IsVisible="{Binding ResponseSection.HasResponse}"
                          RowDefinitions="Auto,*"
                          RowSpacing="{StaticResource Space.2}">
                      <Grid ColumnDefinitions="Auto,Auto,Auto,*"
                            ColumnSpacing="{StaticResource Space.3}">
                        <u:Badge Grid.Column="0"
                                 Header="{Binding ResponseSection.StatusText}"
                                 iri:ClassHelper.Classes="{Binding ResponseSection.StatusBadgeClass}" />
                        <TextBlock Grid.Column="1"
                                   Classes="CaptionText"
                                   Text="{Binding ResponseSection.DurationText}" />
                        <TextBlock Grid.Column="2"
                                   Classes="CaptionText"
                                   Text="{Binding ResponseSection.SizeText}" />
                      </Grid>

                      <TabControl Grid.Row="1"
                                  Classes="ResponseTabs"
                                  SelectedIndex="{Binding ResponseSection.SelectedResponseTab}">
                        <TabItem Header="Body">
                          <TextBox AcceptsReturn="True"
                                   BorderThickness="0"
                                   Background="Transparent"
                                   IsReadOnly="True"
                                   TextWrapping="Wrap"
                                   VerticalContentAlignment="Top"
                                   Text="{Binding ResponseSection.BodyText}"
                                   FontFamily="{StaticResource Font.Monospace}" />
                        </TabItem>
                        <TabItem Header="Headers">
                          <TextBox AcceptsReturn="True"
                                   BorderThickness="0"
                                   Background="Transparent"
                                   IsReadOnly="True"
                                   TextWrapping="Wrap"
                                   VerticalContentAlignment="Top"
                                   Text="{Binding ResponseSection.HeadersText}"
                                   FontFamily="{StaticResource Font.Monospace}" />
                        </TabItem>
                      </TabControl>
                    </Grid>
                  </DockPanel>
                </Border>
              </Grid>
            </Border>

            <Border Grid.Column="2"
                    Classes="PanelCard ProjectWorkspaceCanvas"
                    IsVisible="{Binding IsProjectSettingsSection}">
              <Grid RowDefinitions="Auto,*"
                    RowSpacing="{StaticResource Space.4}">
                <Grid ColumnDefinitions="*,Auto"
                      ColumnSpacing="{StaticResource Space.3}">
                  <StackPanel Spacing="2">
                    <TextBlock Classes="SectionTitle"
                               Text="{Binding CurrentProjectSettingsTitle}" />
                    <TextBlock Classes="CaptionText"
                               Text="{Binding CurrentProjectSettingsSubtitle}"
                               IsVisible="{Binding ShowProjectSettingsImportDataSection}" />
                  </StackPanel>
                  <StackPanel Grid.Column="1"
                              Orientation="Horizontal"
                              Spacing="{StaticResource Space.2}">
                    <Button Classes="SecondaryButton"
                            Content="刷新数据"
                            Command="{Binding RefreshImportedApiDocumentsCommand}"
                            IsVisible="{Binding ShowProjectSettingsImportDataSection}" />
                    <Button Classes="PrimaryButton"
                            Content="打开环境设置"
                            Command="{Binding $parent[Window].((vm:MainWindowViewModel)DataContext).OpenEnvironmentManagerCommand}"
                            IsVisible="{Binding ShowProjectSettingsImportDataSection}" />
                  </StackPanel>
                </Grid>

                <StackPanel Grid.Row="1"
                            Spacing="{StaticResource Space.4}"
                            IsVisible="{Binding ShowProjectSettingsOverviewSection}">
                  <Border Classes="ProjectSettingsSectionDivider" />
                  <StackPanel Spacing="{StaticResource Space.3}">
                    <TextBlock Classes="SectionTitle"
                               Text="基本信息" />
                    <Border Classes="ProjectSettingsBasicCard">
                      <StackPanel>
                        <Border Classes="ProjectSettingsBasicRow">
                          <Grid ColumnDefinitions="180,*,Auto"
                                ColumnSpacing="{StaticResource Space.4}">
                            <TextBlock Classes="ProjectSettingsRowLabel"
                                       Text="项目名称" />
                            <TextBlock Grid.Column="1"
                                       Text="{Binding Project.Name}"
                                       VerticalAlignment="Center" />
                            <Button Grid.Column="2"
                                    Classes="ProjectSettingsInlineActionButton"
                                    Click="OnOpenProjectDrawer"
                                    Content="编辑" />
                          </Grid>
                        </Border>

                        <Border Classes="ProjectSettingsBasicRow">
                          <Grid ColumnDefinitions="180,*"
                                ColumnSpacing="{StaticResource Space.4}">
                            <TextBlock Classes="ProjectSettingsRowLabel"
                                       Text="项目 ID" />
                            <TextBlock Grid.Column="1"
                                       Text="{Binding ProjectId}"
                                       VerticalAlignment="Center" />
                          </Grid>
                        </Border>

                        <Border Classes="ProjectSettingsBasicRow ProjectSettingsBasicRowLast">
                          <Grid ColumnDefinitions="180,*,Auto"
                                ColumnSpacing="{StaticResource Space.4}">
                            <TextBlock Classes="ProjectSettingsRowLabel"
                                       Text="简介" />
                            <TextBlock Grid.Column="1"
                                       Text="{Binding ProjectSettingsDescription}"
                                       TextWrapping="Wrap"
                                       VerticalAlignment="Center" />
                            <Button Grid.Column="2"
                                    Classes="ProjectSettingsInlineActionButton"
                                    Click="OnOpenProjectDrawer"
                                    Content="编辑" />
                          </Grid>
                        </Border>
                      </StackPanel>
                    </Border>
                  </StackPanel>
                </StackPanel>

                <ScrollViewer Grid.Row="1"
                              IsVisible="{Binding ShowProjectSettingsImportDataSection}">
                  <StackPanel Spacing="{StaticResource Space.4}">
                    <Border Classes="ProjectSettingsInfoCard">
                      <StackPanel Spacing="{StaticResource Space.3}">
                        <TextBlock Classes="SectionTitle"
                                   Text="导入 API 数据" />
                        <TextBlock Classes="CaptionText"
                                   Text="当前项目仅保留 OpenAPI / Swagger 导入入口，点击后可选择上传文件或 URL 导入。" />
                        <Button Classes="ProjectImportCatalogButton"
                                Command="{Binding OpenProjectImportDialogCommand}">
                          <Grid ColumnDefinitions="Auto,*"
                                ColumnSpacing="{StaticResource Space.3}">
                            <Border Width="42"
                                    Height="42"
                                    Classes="ProjectImportFormatIcon">
                              <TextBlock HorizontalAlignment="Center"
                                         VerticalAlignment="Center"
                                         FontSize="{StaticResource Font.Size.BodyLarge}"
                                         FontWeight="Bold"
                                         Text="S" />
                            </Border>
                            <StackPanel Grid.Column="1"
                                        Spacing="2"
                                        VerticalAlignment="Center">
                              <TextBlock Text="OpenAPI / Swagger"
                                         FontWeight="SemiBold" />
                              <TextBlock Classes="CaptionText"
                                         Text="支持导入 OpenAPI 3.x 与 Swagger 2.0 的 JSON 或 YAML 文档。" />
                            </StackPanel>
                          </Grid>
                        </Button>
                      </StackPanel>
                    </Border>

                    <Border Classes="ProjectSettingsInfoCard">
                      <Grid RowDefinitions="Auto,Auto,*"
                            RowSpacing="{StaticResource Space.3}">
                        <Grid ColumnDefinitions="*,Auto"
                              ColumnSpacing="{StaticResource Space.2}">
                          <StackPanel Spacing="2">
                            <TextBlock Classes="SectionTitle"
                                       Text="已导入数据" />
                            <TextBlock Classes="CaptionText"
                                       Text="{Binding ImportedApiDocumentCountText, StringFormat='当前项目共保存 {0} 份 Swagger 文档'}" />
                          </StackPanel>
                          <Button Grid.Column="1"
                                  Classes="SecondaryButton"
                                  Content="刷新列表"
                                  Command="{Binding RefreshImportedApiDocumentsCommand}" />
                        </Grid>

                        <Border Grid.Row="1"
                                Classes="EmptyStateCard"
                                IsVisible="{Binding ShowImportedApiDocumentsEmptyState}">
                          <StackPanel Spacing="{StaticResource Space.2}"
                                      HorizontalAlignment="Center">
                            <TextBlock Classes="SectionTitle"
                                       Text="还没有导入数据" />
                            <TextBlock Classes="CaptionText"
                                       Text="选择文件上传或 URL 导入后，文档会出现在这里并持久化保存。" />
                          </StackPanel>
                        </Border>

                        <ItemsControl Grid.Row="2"
                                      ItemsSource="{Binding ImportedApiDocuments}"
                                      IsVisible="{Binding HasImportedApiDocuments}">
                          <ItemsControl.ItemTemplate>
                            <DataTemplate x:DataType="vm:ProjectImportedDocumentItemViewModel">
                              <Border Classes="ProjectImportDocumentCard">
                                <Grid ColumnDefinitions="*,Auto"
                                      ColumnSpacing="{StaticResource Space.3}">
                                  <StackPanel Spacing="{StaticResource Space.2}">
                                    <Grid ColumnDefinitions="Auto,*"
                                          ColumnSpacing="{StaticResource Space.2}">
                                      <u:Badge Grid.Column="0"
                                               Header="{Binding SourceTypeText}"
                                               iri:ClassHelper.Classes="Light Primary" />
                                      <TextBlock Grid.Column="1"
                                                 Text="{Binding Name}"
                                                 FontWeight="SemiBold"
                                                 VerticalAlignment="Center" />
                                    </Grid>
                                    <TextBlock Classes="CaptionText"
                                               Text="{Binding SourceValueText}"
                                               TextWrapping="Wrap" />
                                    <TextBlock Classes="CaptionText"
                                               Text="{Binding BaseUrlText, StringFormat='BaseUrl：{0}'}"
                                               TextWrapping="Wrap" />
                                    <TextBlock Classes="CaptionText"
                                               Text="{Binding ImportedAtText, StringFormat='导入时间：{0}'}" />
                                  </StackPanel>
                                  <Border Grid.Column="1"
                                          Classes="ProjectImportCountBadge">
                                    <StackPanel Spacing="2">
                                      <TextBlock Classes="CaptionText"
                                                 HorizontalAlignment="Center"
                                                 Text="接口数" />
                                      <TextBlock Classes="SectionTitle"
                                                 HorizontalAlignment="Center"
                                                 Text="{Binding EndpointCountText}" />
                                    </StackPanel>
                                  </Border>
                                </Grid>
                              </Border>
                            </DataTemplate>
                          </ItemsControl.ItemTemplate>
                        </ItemsControl>
                      </Grid>
                    </Border>
                  </StackPanel>
                </ScrollViewer>
              </Grid>
            </Border>
            </Grid>
          </Grid>
        </Grid>
      </Border>

      <Border Classes="NotificationFlyoutCard"
              IsVisible="{Binding IsNotificationCenterOpen}"
              HorizontalAlignment="Right"
              VerticalAlignment="Top"
              Margin="0,16,160,0">
        <Grid RowDefinitions="Auto,*,Auto"
              RowSpacing="{StaticResource Space.3}">
          <Grid ColumnDefinitions="*,Auto">
            <StackPanel Spacing="2">
              <TextBlock Classes="SectionTitle"
                         Text="通知中心" />
              <TextBlock Classes="CaptionText"
                         Text="近期更新和系统提醒都会显示在这里。" />
            </StackPanel>
            <Button Grid.Column="1"
                    Classes="DialogIconButton"
                    Command="{Binding MarkAllNotificationsReadCommand}"
                    Content="全部已读" />
          </Grid>

          <ItemsControl Grid.Row="1"
                        ItemsSource="{Binding Notifications}">
            <ItemsControl.ItemTemplate>
              <DataTemplate x:DataType="vm:NotificationItemViewModel">
                <Border Classes="NotificationItemCard">
                  <Grid ColumnDefinitions="Auto,*"
                        ColumnSpacing="{StaticResource Space.3}">
                    <Border Width="10"
                            Height="10"
                            Classes="NotificationItemDot"
                            IsVisible="{Binding IsUnread}" />
                    <StackPanel Grid.Column="1"
                                Spacing="4">
                      <Grid ColumnDefinitions="*,Auto"
                            ColumnSpacing="{StaticResource Space.2}">
                        <TextBlock Text="{Binding Title}"
                                   FontWeight="SemiBold" />
                        <TextBlock Grid.Column="1"
                                   Classes="CaptionText"
                                   Text="{Binding RelativeTimeText}" />
                      </Grid>
                      <TextBlock Classes="CaptionText"
                                 Text="{Binding Message}"
                                 TextWrapping="Wrap" />
                    </StackPanel>
                  </Grid>
                </Border>
              </DataTemplate>
            </ItemsControl.ItemTemplate>
          </ItemsControl>

          <TextBlock Grid.Row="2"
                     Classes="CaptionText"
                     Text="点击铃铛可再次收起此面板。" />
        </Grid>
      </Border>

      <Border Classes="SettingsDialogBackdrop"
              IsVisible="{Binding IsEnvironmentManagerOpen}">
        <Grid HorizontalAlignment="Center"
              VerticalAlignment="Center">
          <Border Classes="EnvironmentManagerDialogCard">
            <Grid ColumnDefinitions="280,*"
                  RowDefinitions="Auto,*,Auto">
              <Border Grid.RowSpan="3"
                      Classes="EnvironmentManagerSidebar">
                <Grid RowDefinitions="Auto,Auto,*"
                      RowSpacing="{StaticResource Space.3}">
                  <StackPanel Spacing="{StaticResource Space.2}">
                    <TextBlock Classes="SectionTitle"
                               Text="环境设置" />
                    <TextBlock Classes="CaptionText"
                               Text="项目级环境会影响右侧快捷请求的 BaseUrl 与变量解析。" />
                  </StackPanel>
                  <Button Grid.Row="1"
                          Classes="PrimaryButton"
                          Content="新增环境"
                          Command="{Binding EnvironmentPanel.AddEnvironmentCommand}" />
                  <ListBox Grid.Row="2"
                           Classes="FlatListBox EnvironmentListBox"
                           ItemsSource="{Binding EnvironmentPanel.Environments}"
                           SelectedItem="{Binding EnvironmentPanel.SelectedEnvironment}">
                    <ListBox.ItemTemplate>
                      <DataTemplate x:DataType="vm:ProjectEnvironmentItemViewModel">
                        <Border Classes="EnvironmentListItem">
                          <StackPanel Spacing="4">
                            <Grid ColumnDefinitions="*,Auto"
                                  ColumnSpacing="{StaticResource Space.2}">
                              <TextBlock Text="{Binding Name}"
                                         FontWeight="SemiBold" />
                              <u:Badge Grid.Column="1"
                                       Header="当前"
                                       IsVisible="{Binding IsActive}"
                                       iri:ClassHelper.Classes="Light Success" />
                            </Grid>
                            <TextBlock Classes="CaptionText"
                                       Text="{Binding BaseUrl}" />
                          </StackPanel>
                        </Border>
                      </DataTemplate>
                    </ListBox.ItemTemplate>
                  </ListBox>
                </Grid>
              </Border>

              <Grid Grid.Column="1"
                    Margin="{StaticResource Pad.5}"
                    RowDefinitions="Auto,*,Auto"
                    RowSpacing="{StaticResource Space.4}">
                <Grid ColumnDefinitions="*,Auto">
                  <StackPanel Spacing="2">
                    <TextBlock Classes="PageTitle"
                               Text="环境详情" />
                    <TextBlock Classes="CaptionText"
                               Text="这里只保留环境名称、前置 URL 和变量列表，便于快速维护。" />
                  </StackPanel>
                  <Button Grid.Column="1"
                          Classes="DialogIconButton"
                          Command="{Binding CloseEnvironmentManagerCommand}"
                          Content="×" />
                </Grid>

                <ScrollViewer Grid.Row="1">
                  <StackPanel Spacing="{StaticResource Space.4}"
                              IsVisible="{Binding EnvironmentPanel.HasSelectedEnvironment}">
                    <Border Classes="EnvironmentDetailCard">
                      <u:Form LabelPosition="Top">
                        <TextBox Classes="SectionInput"
                                 u:FormItem.Label="环境名称"
                                 Watermark="例如 开发 / 测试 / 生产"
                                 Text="{Binding EnvironmentPanel.SelectedEnvironment.Name}" />
                        <TextBox Classes="SectionInput"
                                 u:FormItem.Label="前置 URL"
                                 Watermark="例如 https://api.example.com"
                                 Text="{Binding EnvironmentPanel.SelectedEnvironment.BaseUrl}" />
                      </u:Form>
                    </Border>

                    <Border Classes="EnvironmentDetailCard">
                      <Grid RowDefinitions="Auto,Auto,*"
                            RowSpacing="{StaticResource Space.3}">
                        <Grid ColumnDefinitions="*,Auto"
                              ColumnSpacing="{StaticResource Space.2}">
                          <StackPanel Spacing="2">
                            <TextBlock Classes="SectionTitle"
                                       Text="环境变量" />
                            <TextBlock Classes="CaptionText"
                                       Text="变量会随当前环境一起参与请求地址、Header 与 Body 的占位替换。" />
                          </StackPanel>
                          <Button Grid.Column="1"
                                  Classes="SecondaryButton"
                                  Content="新增变量"
                                  Command="{Binding EnvironmentPanel.AddVariableCommand}" />
                        </Grid>

                        <Border Grid.Row="1"
                                Classes="EnvironmentVariableHeader">
                          <Grid ColumnDefinitions="80,180,*,Auto"
                                ColumnSpacing="{StaticResource Space.2}">
                            <TextBlock Grid.Column="0"
                                       Classes="CaptionText"
                                       Text="启用" />
                            <TextBlock Grid.Column="1"
                                       Classes="CaptionText"
                                       Text="变量名" />
                            <TextBlock Grid.Column="2"
                                       Classes="CaptionText"
                                       Text="变量值" />
                          </Grid>
                        </Border>

                        <ItemsControl Grid.Row="2"
                                      ItemsSource="{Binding EnvironmentPanel.EnvironmentVariables}">
                          <ItemsControl.ItemTemplate>
                            <DataTemplate x:DataType="vm:EnvironmentVariableItemViewModel">
                              <Border Classes="EnvironmentVariableRow">
                                <Grid ColumnDefinitions="80,180,*,Auto"
                                      ColumnSpacing="{StaticResource Space.2}">
                                  <CheckBox Grid.Column="0"
                                            HorizontalAlignment="Center"
                                            VerticalAlignment="Center"
                                            IsChecked="{Binding IsEnabled}" />
                                  <TextBox Grid.Column="1"
                                           Classes="SectionInput"
                                           Watermark="变量键"
                                           Text="{Binding Key}" />
                                  <TextBox Grid.Column="2"
                                           Classes="SectionInput"
                                           Watermark="变量值"
                                           Text="{Binding Value}" />
                                  <u:PopConfirm Grid.Column="3"
                                                PopupHeader="确认删除该变量？"
                                                PopupContent="删除后当前环境下对应变量会立即失效。"
                                                ConfirmCommand="{Binding $parent[Window].((vm:MainWindowViewModel)DataContext).EnvironmentPanel.RemoveVariableCommand}"
                                                ConfirmCommandParameter="{Binding}">
                                    <u:IconButton Classes="Danger"
                                                  Theme="{DynamicResource BorderlessIconButton}"
                                                  Icon="{StaticResource SemiIconDelete}" />
                                  </u:PopConfirm>
                                </Grid>
                              </Border>
                            </DataTemplate>
                          </ItemsControl.ItemTemplate>
                        </ItemsControl>
                      </Grid>
                    </Border>
                  </StackPanel>
                </ScrollViewer>

                <Grid Grid.Row="2"
                      ColumnDefinitions="Auto,*,Auto,Auto"
                      ColumnSpacing="{StaticResource Space.2}">
                  <u:PopConfirm Grid.Column="0"
                                PopupHeader="确认删除当前环境？"
                                PopupContent="若这是当前激活环境，系统会自动切换到其他环境。"
                                ConfirmCommand="{Binding EnvironmentPanel.RemoveEnvironmentCommand}">
                    <Button Classes="SecondaryButton"
                            Content="删除环境" />
                  </u:PopConfirm>
                  <TextBlock Grid.Column="1"
                             Classes="CaptionText"
                             Text="保存后会立即同步到当前项目工作区。"
                             VerticalAlignment="Center" />
                  <Button Grid.Column="2"
                          Classes="SecondaryButton"
                          Content="保存"
                          Command="{Binding SaveEnvironmentManagerCommand}" />
                  <Button Grid.Column="3"
                          Classes="PrimaryButton"
                          Content="保存并关闭"
                          Command="{Binding SaveAndCloseEnvironmentManagerCommand}" />
                </Grid>
              </Grid>
            </Grid>
          </Border>
        </Grid>
      </Border>

      <Border Classes="CreateProjectDialogBackdrop"
              IsVisible="{Binding ShowQuickRequestSaveDialog}">
        <Grid HorizontalAlignment="Center"
              VerticalAlignment="Center">
          <Border Classes="QuickRequestSaveDialogCard">
            <Grid RowDefinitions="Auto,Auto,Auto"
                  RowSpacing="{StaticResource Space.3}">
              <StackPanel Spacing="2">
                <TextBlock Classes="DialogTitle"
                           Text="保存快捷请求" />
                <TextBlock Classes="CaptionText"
                           Text="保存时再输入名称，已保存的快捷请求会继续保留在左侧目录中。" />
              </StackPanel>

              <Border Grid.Row="1"
                      Classes="CreateProjectFormShell">
                <u:Form LabelPosition="Top">
                  <TextBox Classes="SectionInput DialogInput"
                           u:FormItem.Label="快捷请求名称"
                           Watermark="请输入保存名称"
                           Text="{Binding ActiveProjectTab.QuickRequestSaveName}" />
                  <TextBox Classes="SectionInput DialogInput"
                           u:FormItem.Label="备注"
                           AcceptsReturn="True"
                           Height="96"
                           TextWrapping="Wrap"
                           Watermark="可选，补充请求用途说明"
                           Text="{Binding ActiveProjectTab.QuickRequestSaveDescription}" />
                </u:Form>
              </Border>

              <StackPanel Grid.Row="2"
                          Orientation="Horizontal"
                          HorizontalAlignment="Right"
                          Spacing="{StaticResource Space.2}">
                <Button Classes="DialogSecondaryButton"
                        Content="取消"
                        Command="{Binding ActiveProjectTab.CloseQuickRequestSaveDialogCommand}" />
                <Button Classes="DialogPrimaryButton"
                        Content="保存"
                        Command="{Binding ActiveProjectTab.ConfirmQuickRequestSaveCommand}" />
              </StackPanel>
            </Grid>
          </Border>
        </Grid>
      </Border>

      <Border Classes="SettingsDialogBackdrop"
              IsVisible="{Binding ShowProjectImportDialog}">
        <Grid HorizontalAlignment="Center"
              VerticalAlignment="Center">
          <Border Classes="ProjectImportDialogCard">
            <Grid RowDefinitions="Auto,Auto,Auto,*"
                  RowSpacing="{StaticResource Space.3}">
              <Grid ColumnDefinitions="*,Auto">
                <TextBlock Classes="DialogTitle"
                           Text="导入数据" />
                <Button Grid.Column="1"
                        Classes="DialogIconButton"
                        Content="×"
                        Command="{Binding ActiveProjectTab.CloseProjectImportDialogCommand}" />
              </Grid>

              <Border Grid.Row="1"
                      Classes="ProjectImportDialogHeaderCard">
                <Grid ColumnDefinitions="Auto,*"
                      ColumnSpacing="{StaticResource Space.3}">
                  <Border Width="44"
                          Height="44"
                          Classes="ProjectImportFormatIcon">
                    <TextBlock HorizontalAlignment="Center"
                               VerticalAlignment="Center"
                               FontSize="{StaticResource Font.Size.BodyLarge}"
                               FontWeight="Bold"
                               Text="S" />
                  </Border>
                  <StackPanel Grid.Column="1"
                              Spacing="2"
                              VerticalAlignment="Center">
                    <TextBlock Classes="CaptionText"
                               Text="数据源格式" />
                    <TextBlock Text="OpenAPI/Swagger"
                               FontSize="{StaticResource Font.Size.BodyLarge}"
                               FontWeight="SemiBold" />
                  </StackPanel>
                </Grid>
              </Border>

              <Border Grid.Row="2"
                      Classes="ProjectImportDialogNoticeCard">
                <TextBlock Text="支持导入 OpenAPI 3.0、3.1 或 Swagger 2.0 数据格式的 JSON 或 YAML 文件。"
                           TextWrapping="Wrap"
                           TextAlignment="Center" />
              </Border>

              <StackPanel Grid.Row="3"
                          Spacing="{StaticResource Space.3}">
                <Grid ColumnDefinitions="*,*"
                      ColumnSpacing="{StaticResource Space.2}">
                  <ToggleButton Grid.Column="0"
                                Classes="SettingsNavButton ProjectImportModeButton"
                                Command="{Binding ActiveProjectTab.ShowImportFileModeCommand}"
                                IsChecked="{Binding ActiveProjectTab.IsImportFileMode, Mode=OneWay}">
                    <TextBlock Text="上传文件" />
                  </ToggleButton>
                  <ToggleButton Grid.Column="1"
                                Classes="SettingsNavButton ProjectImportModeButton"
                                Command="{Binding ActiveProjectTab.ShowImportUrlModeCommand}"
                                IsChecked="{Binding ActiveProjectTab.IsImportUrlMode, Mode=OneWay}">
                    <TextBlock Text="URL 导入" />
                  </ToggleButton>
                </Grid>

                <Border Classes="StatusInfo"
                        IsVisible="{Binding ActiveProjectTab.ShowImportStatusInfo}">
                  <TextBlock Text="{Binding ActiveProjectTab.ImportDataStatusText}"
                             TextWrapping="Wrap" />
                </Border>
                <Border Classes="StatusSuccess"
                        IsVisible="{Binding ActiveProjectTab.ShowImportStatusSuccess}">
                  <TextBlock Text="{Binding ActiveProjectTab.ImportDataStatusText}"
                             TextWrapping="Wrap" />
                </Border>
                <Border Classes="StatusError"
                        IsVisible="{Binding ActiveProjectTab.ShowImportStatusError}">
                  <TextBlock Text="{Binding ActiveProjectTab.ImportDataStatusText}"
                             TextWrapping="Wrap" />
                </Border>

                <Border Classes="ProjectImportDropZoneCard"
                        IsVisible="{Binding ActiveProjectTab.IsImportFileMode}">
                  <StackPanel Spacing="{StaticResource Space.3}"
                              VerticalAlignment="Center"
                              HorizontalAlignment="Center">
                    <TextBlock FontFamily="Segoe Fluent Icons, Segoe MDL2 Assets"
                               FontSize="28"
                               HorizontalAlignment="Center"
                               Text="&#xE898;" />
                    <TextBlock Text="{Binding ActiveProjectTab.SelectedImportFileName}"
                               FontWeight="SemiBold"
                               TextAlignment="Center" />
                    <TextBlock Classes="CaptionText"
                               Text="{Binding ActiveProjectTab.SelectedImportFileSummary}"
                               TextWrapping="Wrap"
                               TextAlignment="Center" />
                    <StackPanel Orientation="Horizontal"
                                HorizontalAlignment="Center"
                                Spacing="{StaticResource Space.2}">
                      <Button Classes="DialogSecondaryButton"
                              Content="选择文件"
                              Command="{Binding ActiveProjectTab.PickSwaggerImportFileCommand}" />
                      <Button Classes="DialogPrimaryButton"
                              Content="开始导入"
                              Command="{Binding ActiveProjectTab.ImportSwaggerFileCommand}" />
                    </StackPanel>
                  </StackPanel>
                </Border>

                <Border Classes="ProjectImportUrlCard"
                        IsVisible="{Binding ActiveProjectTab.IsImportUrlMode}">
                  <StackPanel Spacing="{StaticResource Space.3}">
                    <TextBlock Classes="SectionTitle"
                               Text="URL 导入" />
                    <TextBlock Classes="CaptionText"
                               Text="输入可直接访问的 OpenAPI / Swagger 文档地址。" />
                    <TextBox Classes="SectionInput DialogInput"
                             Watermark="https://example.com/swagger/v1/swagger.json"
                             Text="{Binding ActiveProjectTab.ImportUrl}" />
                    <StackPanel Orientation="Horizontal"
                                HorizontalAlignment="Right"
                                Spacing="{StaticResource Space.2}">
                      <Button Classes="DialogPrimaryButton"
                              Content="导入 URL"
                              Command="{Binding ActiveProjectTab.ImportSwaggerUrlCommand}" />
                    </StackPanel>
                  </StackPanel>
                </Border>
              </StackPanel>
            </Grid>
          </Border>
        </Grid>
      </Border>

      <Border Classes="SettingsDialogBackdrop"
              IsVisible="{Binding IsSettingsDialogOpen}">
        <Grid HorizontalAlignment="Center"
              VerticalAlignment="Center">
          <Border Classes="SettingsDialogCard">
            <Grid ColumnDefinitions="220,*"
                  RowDefinitions="*">
              <Border Classes="SettingsSidebar">
                <StackPanel Spacing="{StaticResource Space.2}">
                  <TextBlock Classes="SectionTitle"
                             Text="设置中心" />
                  <TextBlock Classes="CaptionText"
                             Text="先保留通用和关于两个分组。" />
                  <ToggleButton Classes="SettingsNavButton"
                                Command="{Binding ShowGeneralSettingsCommand}"
                                IsChecked="{Binding ShowGeneralSettingsSection, Mode=OneWay}">
                    <TextBlock Text="通用" />
                  </ToggleButton>
                  <ToggleButton Classes="SettingsNavButton"
                                Command="{Binding ShowAboutSettingsCommand}"
                                IsChecked="{Binding ShowAboutSettingsSection, Mode=OneWay}">
                    <TextBlock Text="关于" />
                  </ToggleButton>
                </StackPanel>
              </Border>

              <Grid Grid.Column="1"
                    RowDefinitions="Auto,*"
                    RowSpacing="{StaticResource Space.4}"
                    Margin="{StaticResource Pad.5}">
                <Grid ColumnDefinitions="*,Auto">
                  <StackPanel Spacing="2">
                    <TextBlock Classes="PageTitle"
                               Text="{Binding CurrentSettingsTitle}" />
                    <TextBlock Classes="CaptionText"
                               Text="设置会自动保存到本地工作目录，并在后续请求中生效。" />
                  </StackPanel>
                  <Button Grid.Column="1"
                          Classes="DialogIconButton"
                          Command="{Binding CloseSettingsDialogCommand}"
                          Content="×" />
                </Grid>

                <ScrollViewer Grid.Row="1">
                  <StackPanel>
                    <Grid RowDefinitions="Auto,Auto"
                          IsVisible="{Binding ShowGeneralSettingsSection}"
                          RowSpacing="{StaticResource Space.4}">
                      <Border Classes="SettingsPageSection">
                        <Grid ColumnDefinitions="*,Auto"
                              ColumnSpacing="{StaticResource Space.4}">
                          <StackPanel Spacing="4">
                            <TextBlock Classes="SettingsGroupTitle"
                                       Text="请求超时时间" />
                            <TextBlock Classes="CaptionText"
                                       Text="输入 0 表示不限时，其余值会作为请求超时毫秒数。" />
                          </StackPanel>
                          <NumericUpDown Grid.Column="1"
                                         Classes="SettingsNumberInput"
                                         Minimum="0"
                                         Maximum="120000"
                                         Increment="1000"
                                         Value="{Binding RequestTimeoutMilliseconds}" />
                        </Grid>
                      </Border>

                      <StackPanel Grid.Row="1"
                                  Spacing="{StaticResource Space.3}">
                        <Border Classes="SettingsPageSection">
                          <Grid ColumnDefinitions="*,Auto"
                                ColumnSpacing="{StaticResource Space.4}">
                            <StackPanel Spacing="4">
                              <TextBlock Classes="SettingsGroupTitle"
                                         Text="SSL 证书验证" />
                              <TextBlock Classes="CaptionText"
                                         Text="关闭后会忽略证书校验，适合本地或自签名环境调试。" />
                            </StackPanel>
                            <ToggleSwitch Grid.Column="1"
                                          IsChecked="{Binding ValidateSslCertificate}" />
                          </Grid>
                        </Border>
                        <Border Classes="SettingsPageSection">
                          <Grid ColumnDefinitions="*,Auto"
                                ColumnSpacing="{StaticResource Space.4}">
                            <StackPanel Spacing="4">
                              <TextBlock Classes="SettingsGroupTitle"
                                         Text="自动跟随重定向" />
                              <TextBlock Classes="CaptionText"
                                         Text="开启后，请求会自动处理 3xx 跳转响应。" />
                            </StackPanel>
                            <ToggleSwitch Grid.Column="1"
                                          IsChecked="{Binding AutoFollowRedirects}" />
                          </Grid>
                        </Border>
                        <Border Classes="SettingsPageSection">
                          <Grid ColumnDefinitions="*,Auto"
                                ColumnSpacing="{StaticResource Space.4}">
                            <StackPanel Spacing="4">
                              <TextBlock Classes="SettingsGroupTitle"
                                         Text="发送无缓存头" />
                              <TextBlock Classes="CaptionText"
                                         Text="开启后会自动补充 no-cache / no-store 请求头。" />
                            </StackPanel>
                            <ToggleSwitch Grid.Column="1"
                                          IsChecked="{Binding SendNoCacheHeader}" />
                          </Grid>
                        </Border>
                        <Border Classes="SettingsPageSection">
                          <Grid ColumnDefinitions="*,Auto"
                                ColumnSpacing="{StaticResource Space.4}">
                            <StackPanel Spacing="4">
                              <TextBlock Classes="SettingsGroupTitle"
                                         Text="详细日志 (Verbose Logging)" />
                              <TextBlock Classes="CaptionText"
                                         Text="当前先保存为本地偏好项，后续会继续扩展到更完整的调试输出。" />
                            </StackPanel>
                            <ToggleSwitch Grid.Column="1"
                                          IsChecked="{Binding EnableVerboseLogging}" />
                          </Grid>
                        </Border>
                        <Border Classes="SettingsPageSection">
                          <Grid ColumnDefinitions="*,Auto"
                                ColumnSpacing="{StaticResource Space.4}">
                            <StackPanel Spacing="4">
                              <TextBlock Classes="SettingsGroupTitle"
                                         Text="新版本提醒" />
                              <TextBlock Classes="CaptionText"
                                         Text="控制是否在设置中心展示 mock 更新提示。" />
                            </StackPanel>
                            <ToggleSwitch Grid.Column="1"
                                          IsChecked="{Binding EnableUpdateReminder}" />
                          </Grid>
                        </Border>
                        <TextBlock Classes="CaptionText"
                                   Text="{Binding GeneralSettingsSaveStatus}" />
                      </StackPanel>
                    </Grid>

                    <Grid IsVisible="{Binding ShowAboutSettingsSection}">
                      <StackPanel Spacing="{StaticResource Space.4}">
                        <Border Classes="AboutHeroCard">
                          <Grid ColumnDefinitions="Auto,*"
                                ColumnSpacing="{StaticResource Space.4}">
                            <Border Width="88"
                                    Height="88"
                                    Classes="AboutIconBadge">
                              <Path Width="42"
                                    Height="42"
                                    HorizontalAlignment="Center"
                                    VerticalAlignment="Center"
                                    Fill="{DynamicResource Brush.Text.Inverse}"
                                    Data="M12,2 C17.5,2 22,6.5 22,12 C22,17.5 17.5,22 12,22 C6.5,22 2,17.5 2,12 C2,6.5 6.5,2 12,2 Z M7,8 L17,8 L17,10 L7,10 Z M7,12 L14,12 L14,14 L7,14 Z" />
                            </Border>
                            <StackPanel Grid.Column="1"
                                        Spacing="{StaticResource Space.2}"
                                        VerticalAlignment="Center">
                              <TextBlock Classes="HeroTitle"
                                         Text="{Binding AppDisplayName}" />
                              <TextBlock Classes="SubtleText"
                                         Text="{Binding CurrentAppVersion, StringFormat='当前版本 {0}'}" />
                              <TextBlock Classes="CaptionText"
                                         Text="{Binding LatestMockVersion, StringFormat='Mock 最新版本 {0}'}" />
                              <StackPanel Orientation="Horizontal"
                                          Spacing="{StaticResource Space.2}">
                                <Button Classes="PrimaryButton"
                                        Content="检查更新"
                                        Command="{Binding CheckForUpdatesCommand}" />
                                <Border Classes="VersionTag">
                                  <TextBlock Classes="CaptionText"
                                             Text="Mock 通道" />
                                </Border>
                              </StackPanel>
                            </StackPanel>
                          </Grid>
                        </Border>
                        <Border Classes="SettingsPageSection">
                          <StackPanel Spacing="{StaticResource Space.2}">
                            <TextBlock Classes="SettingsGroupTitle"
                                       Text="更新状态" />
                            <TextBlock Classes="CaptionText"
                                       Text="{Binding AboutUpdateStatus}" />
                            <TextBlock Classes="CaptionText"
                                       Text="{Binding LastUpdateCheckText, StringFormat='最近检查：{0}'}" />
                          </StackPanel>
                        </Border>
                        <Border Classes="SettingsPageSection">
                          <StackPanel Spacing="{StaticResource Space.2}">
                            <TextBlock Classes="SettingsGroupTitle"
                                       Text="软件信息" />
                            <TextBlock Classes="CaptionText"
                                       Text="{Binding AppDisplayName, StringFormat='软件名称：{0}'}" />
                            <TextBlock Classes="CaptionText"
                                       Text="{Binding CurrentAppVersion, StringFormat='版本号：{0}'}" />
                            <TextBlock Classes="CaptionText"
                                       Text="{Binding RuntimeStackText, StringFormat='技术栈：{0}'}" />
                            <TextBlock Classes="CaptionText"
                                       Text="本地数据：SQLite / 项目级工作目录隔离" />
                          </StackPanel>
                        </Border>
                      </StackPanel>
                    </Grid>
                  </StackPanel>
                </ScrollViewer>
              </Grid>
            </Grid>
          </Border>
        </Grid>
      </Border>

      <Border Classes="CreateProjectDialogBackdrop"
              IsVisible="{Binding IsCreateProjectDialogOpen}">
        <Grid HorizontalAlignment="Center"
              VerticalAlignment="Center">
          <Border Classes="CreateProjectDialogCard">
            <Grid RowDefinitions="Auto,Auto,Auto"
                  RowSpacing="{StaticResource Space.3}">
              <StackPanel Spacing="2">
                <TextBlock Classes="DialogTitle"
                           Text="新建项目" />
                <TextBlock Classes="CaptionText"
                           Text="只需要填写项目名称和备注信息。创建后会自动生成该项目的默认环境。" />
              </StackPanel>
              <Border Grid.Row="1"
                      Classes="CreateProjectFormShell">
                <u:Form LabelPosition="Top">
                  <TextBox Classes="SectionInput DialogInput"
                           u:FormItem.Label="项目名称"
                           Watermark="请输入项目名称"
                           Text="{Binding ProjectPanel.DraftProjectName}" />
                  <TextBox Classes="SectionInput DialogInput"
                           u:FormItem.Label="备注信息"
                           AcceptsReturn="True"
                           Height="112"
                           TextWrapping="Wrap"
                           Watermark="补充项目用途、团队或说明"
                           Text="{Binding ProjectPanel.DraftProjectDescription}" />
                </u:Form>
              </Border>
              <StackPanel Grid.Row="2"
                          Orientation="Horizontal"
                          HorizontalAlignment="Right"
                          Spacing="{StaticResource Space.2}">
                <Button Classes="DialogSecondaryButton"
                        Content="取消"
                        Command="{Binding CloseCreateProjectDialogCommand}" />
                <Button Classes="DialogPrimaryButton"
                        Content="创建项目"
                        Command="{Binding ProjectPanel.CreateProjectCommand}" />
              </StackPanel>
            </Grid>
          </Border>
        </Grid>
      </Border>

      <u:OverlayDialogHost />
    </Grid>
  </Grid>
</Window>
